---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
import { getAllComments, getCommentStats, getArticleById } from '../../lib/turso-helpers.js';

const comments = await getAllComments();
const commentStats = await getCommentStats();

const enrichedComments = await Promise.all(comments.map(async (c: any) => {
  const article = await getArticleById(c.article_id);
  return { ...c, articleSlug: article?.slug || null, articleTitle: article?.title || `Artikel #${c.article_id}` };
}));
---

<DashboardLayout title="Kelola Komentar - Admin Panel" activePage="komentar">
  <div class="p-4 md:p-6 lg:p-8">

    <!-- Page Header -->
    <div class="mb-6">
      <h2 class="text-xl md:text-2xl font-extrabold text-gray-900 dark:text-white">Moderasi Komentar</h2>
      <p class="text-sm text-gray-500 dark:text-gray-400 mt-1">Kelola dan moderasi komentar dari pembaca.</p>
    </div>

    <!-- Stats -->
    <div class="flex gap-3 mb-6">
      <div class="bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-800 rounded-xl px-4 py-3 flex items-center gap-3">
        <span class="material-symbols-outlined text-violet-500">comment</span>
        <div>
          <p class="text-xs text-gray-500 dark:text-gray-400">Total Komentar</p>
          <p class="text-xl font-extrabold text-gray-900 dark:text-white">{commentStats.total}</p>
        </div>
      </div>
    </div>

    <!-- Comment Cards -->
    {enrichedComments.length === 0 ? (
      <div class="bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-800 rounded-xl p-12 text-center">
        <span class="material-symbols-outlined text-4xl text-gray-300 dark:text-gray-600 block mb-3">chat_bubble</span>
        <p class="text-gray-500 dark:text-gray-400 text-sm">Belum ada komentar.</p>
      </div>
    ) : (
      <div class="space-y-3">
        {enrichedComments.map((comment: any) => (
          <div class="bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-800 rounded-xl p-4 md:p-5 hover:border-gray-300 dark:hover:border-gray-700 transition-colors">
            <!-- Top row: avatar + author + date + action -->
            <div class="flex items-start justify-between gap-3 mb-3">
              <div class="flex items-center gap-3 min-w-0">
                <div class="w-9 h-9 rounded-full bg-violet-100 dark:bg-violet-900/30 flex items-center justify-center flex-shrink-0">
                  <span class="material-symbols-outlined text-violet-500 text-[18px]">person</span>
                </div>
                <div class="min-w-0">
                  <p class="text-sm font-bold text-gray-900 dark:text-white truncate">{comment.author_name}</p>
                  <p class="text-xs text-gray-400 dark:text-gray-500 truncate">{comment.author_email}</p>
                </div>
              </div>
              <div class="flex items-center gap-2 flex-shrink-0">
                <span class="text-xs text-gray-400 dark:text-gray-500 hidden sm:block">
                  {new Date(comment.created_at).toLocaleDateString('id-ID', { day: 'numeric', month: 'short', year: 'numeric' })}
                </span>
                <button
                  onclick={`deleteComment('${comment.id}')`}
                  class="flex items-center gap-1 px-2.5 py-1.5 text-xs font-semibold text-red-600 dark:text-red-400 bg-red-50 dark:bg-red-900/20 hover:bg-red-100 dark:hover:bg-red-900/40 rounded-lg transition-colors"
                >
                  <span class="material-symbols-outlined text-[14px]">delete</span>
                  <span>Hapus</span>
                </button>
              </div>
            </div>

            <!-- Article ref -->
            <div class="flex items-center gap-1.5 mb-2 px-1">
              <span class="material-symbols-outlined text-[14px] text-gray-400">article</span>
              {comment.articleSlug
                ? <a href={`/artikel/${comment.articleSlug}`} class="text-xs font-semibold text-violet-600 dark:text-violet-400 hover:underline line-clamp-1">{comment.articleTitle}</a>
                : <span class="text-xs text-gray-400 dark:text-gray-500 line-clamp-1">{comment.articleTitle}</span>
              }
            </div>

            <!-- Comment body -->
            <div class="bg-gray-50 dark:bg-gray-800/50 rounded-lg px-4 py-3">
              <p class="text-sm text-gray-700 dark:text-gray-300 leading-relaxed">{comment.content}</p>
            </div>

            <!-- Date mobile -->
            <p class="text-xs text-gray-400 dark:text-gray-500 mt-2 sm:hidden">
              {new Date(comment.created_at).toLocaleDateString('id-ID', { day: 'numeric', month: 'short', year: 'numeric' })}
            </p>
          </div>
        ))}
      </div>
    )}
  </div>
</DashboardLayout>


  <script>
    async function deleteComment(id: string) {
      (window as any).showConfirm({
        title: 'Hapus Komentar?',
        message: 'Komentar ini akan dihapus permanen.',
        okText: 'Hapus',
        okIcon: 'delete',
        okClass: 'bg-red-500 hover:bg-red-600',
        iconBg: 'bg-red-100',
        iconColor: 'text-red-500',
        icon: 'delete'
      }, async (confirmed) => {
        if (!confirmed) return;
        try {
          const response = await fetch('/api/comments/delete', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ id }) });
          const result = await response.json();
          if (result.success) {
            alert('✅ Komentar berhasil dihapus!');
            window.location.reload();
          } else {
            alert('❌ Error: ' + result.message);
          }
        } catch (error) {
          alert('❌ Terjadi kesalahan: ' + error);
        }
      });
    }

    // Make functions available globally
    (window as any).deleteComment = deleteComment;
  </script>
