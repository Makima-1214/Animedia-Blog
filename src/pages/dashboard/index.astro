---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
import { getAllArticles, getDetailedStats, getDailyViews, getRecentActivities } from '../../lib/turso-helpers.js';

const articles = await getAllArticles();
const stats = await getDetailedStats();
const dailyViews = await getDailyViews();
const activities = await getRecentActivities();
---

<DashboardLayout title="Dashboard - Admin Panel" activePage="dashboard">
  <div class="p-4 md:p-8 lg:p-12">
    <!-- Header Section -->
    <header class="mb-8 md:mb-12">
      <h2 class="text-2xl md:text-4xl font-extrabold tracking-tighter text-gray-900 dark:text-white mb-2">Ikhtisar Dashboard</h2>
      <p class="text-sm text-gray-600 dark:text-gray-400">Selamat datang kembali. Berikut adalah performa editorial Anda hari ini.</p>
    </header>

    <!-- Quick Stats Bento Grid -->
    <section class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-5 gap-3 md:gap-6 mb-8 md:mb-12">
      {[
        { icon: 'article', label: 'Total Postingan', value: stats.totalArticles, growth: stats.articlesGrowth },
        { icon: 'visibility', label: 'Total Pembaca', value: stats.totalViews?.toLocaleString() || '0', growth: stats.viewsGrowth },
        { icon: 'group', label: 'Total Pengguna', value: stats.totalUsers, growth: stats.usersGrowth },
        { icon: 'forum', label: 'Komentar Baru', value: stats.totalComments, growth: stats.commentsGrowth },
        { icon: 'mark_email_unread', label: 'Total Subscriber', value: stats.totalSubscribers?.toLocaleString() || '0', growth: stats.subscribersGrowth },
      ].map((s) => (
        <div class="bg-white dark:bg-gray-900 p-4 md:p-6 rounded-xl border border-gray-200 dark:border-gray-800">
          <div class="flex items-center justify-between mb-3 md:mb-4">
            <span class="material-symbols-outlined text-gray-400 dark:text-gray-500 text-xl">{s.icon}</span>
            <span class={`text-[10px] font-bold px-2 py-0.5 rounded-full ${
              s.growth > 0 ? 'text-green-600 bg-green-50 dark:bg-green-900/30 dark:text-green-400' :
              s.growth < 0 ? 'text-red-600 bg-red-50 dark:bg-red-900/30 dark:text-red-400' :
              'text-gray-400 bg-gray-100 dark:bg-gray-800 dark:text-gray-500'
            }`}>
              {s.growth > 0 ? `+${s.growth}%` : s.growth < 0 ? `${s.growth}%` : 'Tetap'}
            </span>
          </div>
          <p class="text-xs uppercase tracking-widest text-gray-500 dark:text-gray-400 font-bold mb-1">{s.label}</p>
          <p class="text-2xl md:text-3xl font-bold text-gray-900 dark:text-white">{s.value}</p>
        </div>
      ))}
    </section>

    <!-- Main Insights Section -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 md:gap-8">
      <!-- Visitor Trend Graph -->
      <section class="lg:col-span-2 bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-800 p-5 md:p-8 rounded-2xl">
        <div class="flex items-center justify-between mb-2">
          <div>
            <h3 class="text-base md:text-lg font-bold text-gray-900 dark:text-white">Tren Pengunjung</h3>
            <p class="text-xs text-gray-400 dark:text-gray-500 mt-0.5">7 hari terakhir</p>
          </div>
          <div class="text-right">
            <p class="text-xl md:text-2xl font-black text-violet-600 dark:text-violet-400">
              {dailyViews.reduce((s: number, d: any) => s + (d.views || 0), 0).toLocaleString()}
            </p>
            <p class="text-[10px] text-gray-400 dark:text-gray-500 uppercase tracking-widest">total views</p>
          </div>
        </div>

        <div class="mt-6 relative">
          <div class="absolute inset-0 flex flex-col justify-between pointer-events-none pb-8">
            {[100, 75, 50, 25, 0].map((pct) => (
              <div class="flex items-center gap-2 w-full">
                <span class="text-[9px] text-gray-300 dark:text-gray-600 w-6 text-right flex-shrink-0">{pct}%</span>
                <div class="flex-1 border-t border-dashed border-gray-100 dark:border-gray-800"></div>
              </div>
            ))}
          </div>

          <div class="pl-8 flex items-end justify-between gap-1.5 md:gap-2 h-52 pb-8">
            {dailyViews.map((day: any, index: number) => {
              const isToday = index === dailyViews.length - 1;
              const isMax = day.percentage === Math.max(...dailyViews.map((d: any) => d.percentage));
              return (
                <div class="flex-1 flex flex-col items-center gap-1.5 h-full justify-end group relative">
                  <div class="absolute bottom-full mb-2 left-1/2 -translate-x-1/2 bg-gray-900 dark:bg-gray-700 text-white text-[10px] font-bold px-2 py-1 rounded-lg whitespace-nowrap opacity-0 group-hover:opacity-100 transition-opacity pointer-events-none z-10">
                    {day.views.toLocaleString()} views
                    <div class="absolute top-full left-1/2 -translate-x-1/2 border-4 border-transparent border-t-gray-900 dark:border-t-gray-700"></div>
                  </div>
                  <div
                    class={`w-full rounded-t-lg transition-all duration-500 ${
                      isToday
                        ? 'bg-violet-600 dark:bg-violet-400 shadow-lg'
                        : day.views === 0
                        ? 'bg-gray-100 dark:bg-gray-800'
                        : isMax
                        ? 'bg-gray-700 dark:bg-gray-300 group-hover:bg-gray-900 dark:group-hover:bg-gray-100'
                        : 'bg-gray-300 dark:bg-gray-600 group-hover:bg-gray-700 dark:group-hover:bg-gray-300'
                    }`}
                    style={`height: ${day.views === 0 ? 6 : Math.max(15, day.percentage)}%`}
                  ></div>
                </div>
              );
            })}
          </div>

          <div class="pl-8 flex justify-between gap-1.5 md:gap-2 mt-1">
            {dailyViews.map((day: any, index: number) => {
              const isToday = index === dailyViews.length - 1;
              return (
                <div class="flex-1 text-center">
                  <span class={`text-[10px] font-bold ${
                    isToday ? 'text-violet-600 dark:text-violet-400' : 'text-gray-400 dark:text-gray-500'
                  }`}>{day.day}</span>
                </div>
              );
            })}
          </div>
        </div>

        {(() => {
          const peak = dailyViews.reduce((max: any, d: any) => d.views > (max?.views || 0) ? d : max, null);
          return peak && peak.views > 0 ? (
            <div class="mt-4 pt-4 border-t border-gray-100 dark:border-gray-800 flex items-center gap-2 text-xs text-gray-500 dark:text-gray-400">
              <span class="material-symbols-outlined text-sm text-violet-500">trending_up</span>
              Hari terbaik: <span class="font-bold text-gray-900 dark:text-white">{peak.day}</span> dengan <span class="font-bold text-violet-600 dark:text-violet-400">{peak.views.toLocaleString()} views</span>
            </div>
          ) : null;
        })()}
      </section>

      <!-- Activity Feed -->
      <section class="bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-800 p-5 md:p-8 rounded-xl">
        <h3 class="text-base md:text-xl font-bold text-gray-900 dark:text-white mb-6">Aktivitas Terbaru</h3>
        <div class="space-y-5">
          {activities.slice(0, 4).map((activity: any) => (
            <div class="flex space-x-4">
              <div class={`w-2 h-2 rounded-full mt-2 flex-shrink-0 ${
                activity.priority === 'high' ? 'bg-violet-600 dark:bg-violet-400' : 'bg-gray-300 dark:bg-gray-600'
              }`}></div>
              <div>
                <p class="text-sm font-bold text-gray-900 dark:text-white leading-tight">{activity.title}</p>
                <p class="text-[11px] text-gray-500 dark:text-gray-400 mt-1">{activity.description}</p>
              </div>
            </div>
          ))}
        </div>
        <button class="w-full mt-8 text-xs font-bold text-gray-400 dark:text-gray-500 border-t border-gray-100 dark:border-gray-800 pt-4 hover:text-gray-900 dark:hover:text-white transition-colors">
          Lihat Semua Aktivitas
        </button>
      </section>
    </div>

    <!-- Secondary Section: Popular Content -->
    <section class="mt-8 md:mt-12">
      <div class="flex items-center justify-between mb-5">
        <h3 class="text-lg md:text-2xl font-bold text-gray-900 dark:text-white">Postingan Populer</h3>
        <a class="text-sm font-bold text-violet-600 dark:text-violet-400 hover:underline" href="/dashboard/artikel">Semua</a>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {articles.slice(0, 3).map((article: any) => (
          <a href={`/artikel/${article.slug}`} class="group block">
            <div class="aspect-[16/10] bg-gray-100 dark:bg-gray-800 overflow-hidden rounded-xl mb-3">
              <img
                alt={article.title}
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                src={article.cover_image || 'https://via.placeholder.com/800x400'}
              />
            </div>
            <h4 class="text-base font-bold text-gray-900 dark:text-white leading-tight mb-2 group-hover:text-violet-600 dark:group-hover:text-violet-400 transition-colors">{article.title}</h4>
            <div class="flex items-center gap-4 text-xs text-gray-500 dark:text-gray-400">
              <span class="flex items-center gap-1">
                <span class="material-symbols-outlined text-sm">visibility</span>
                {article.views?.toLocaleString()}
              </span>
              <span class="flex items-center gap-1">
                <span class="material-symbols-outlined text-sm">schedule</span>
                {article.read_time} min
              </span>
            </div>
          </a>
        ))}
      </div>
    </section>
  </div>
</DashboardLayout>
