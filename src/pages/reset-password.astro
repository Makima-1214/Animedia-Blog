---
import BaseLayout from '../layouts/BaseLayout.astro';

const email = Astro.url.searchParams.get('email') || '';
---

<BaseLayout title="Reset Password">
  <!-- Toast -->
  <div id="toast" class="fixed bottom-4 left-4 right-4 md:bottom-auto md:top-6 md:left-auto md:right-6 md:w-auto z-50 transform translate-y-24 md:translate-y-0 md:translate-x-[420px] transition-all duration-500 ease-out">
    <div class="bg-white dark:bg-gray-800 rounded-2xl shadow-2xl p-4 flex items-center gap-3 md:min-w-[340px] border border-gray-100 dark:border-gray-700">
      <span id="toastIcon" class="material-symbols-outlined text-2xl"></span>
      <p id="toastMessage" class="text-sm font-medium flex-1 dark:text-white"></p>
    </div>
  </div>

  <main class="min-h-screen flex items-center justify-center px-4 py-16 relative overflow-hidden bg-white dark:bg-gray-950">
    <!-- Background -->
    <div class="absolute inset-0 bg-gradient-to-br from-violet-50 via-white to-blue-50 dark:from-gray-900 dark:via-gray-950 dark:to-gray-900"></div>
    <div class="absolute top-20 -right-40 w-96 h-96 bg-violet-200 dark:bg-violet-900/30 rounded-full mix-blend-multiply filter blur-3xl opacity-30 animate-blob"></div>
    <div class="absolute -bottom-20 -left-40 w-96 h-96 bg-blue-200 dark:bg-blue-900/30 rounded-full mix-blend-multiply filter blur-3xl opacity-30 animate-blob animation-delay-2000"></div>
    
    <div class="w-full max-w-md relative z-10">
      <!-- Logo -->
      <div class="text-center mb-8">
        <h1 class="font-headline text-4xl font-black tracking-tight text-gray-900 dark:text-white mb-1">
          Animedia
        </h1>
        <p class="text-gray-500 dark:text-gray-400 text-sm">Portal Berita Teknologi & Pop Culture</p>
      </div>

      <!-- Form Card -->
      <div class="bg-white/70 dark:bg-gray-900/70 backdrop-blur-xl rounded-3xl shadow-xl border border-white/20 dark:border-gray-800/50 p-8">
        <div class="mb-7 text-center">
          <div class="w-16 h-16 bg-violet-100 dark:bg-violet-900/30 rounded-full flex items-center justify-center mx-auto mb-4">
            <span class="material-symbols-outlined text-3xl text-violet-600 dark:text-violet-400">vpn_key</span>
          </div>
          <h2 class="text-2xl font-bold text-gray-900 dark:text-white mb-1">Reset Password</h2>
          <p class="text-gray-500 dark:text-gray-400 text-sm">Masukkan kode dan password baru Anda</p>
        </div>

        {email && (
          <div class="mb-6 p-4 bg-gradient-to-r from-blue-50 to-purple-50 dark:from-blue-900/20 dark:to-purple-900/20 rounded-xl border-2 border-blue-100 dark:border-blue-800">
            <p class="text-sm text-gray-700 dark:text-gray-300 flex items-center gap-2">
              <span class="material-symbols-outlined text-blue-600 dark:text-blue-400">email</span>
              <strong class="font-semibold">{email}</strong>
            </p>
          </div>
        )}
        
        <form id="resetForm" class="space-y-4">
          <input type="hidden" name="email" value={email} />
          
          <!-- Code -->
          <div>
            <label class="text-xs font-semibold text-gray-600 dark:text-gray-400 uppercase tracking-wider mb-2 block">Kode Verifikasi (6 digit)</label>
            <div class="relative">
              <span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-gray-400 dark:text-gray-500 text-xl">pin</span>
              <input
                type="text"
                name="code"
                id="code"
                required
                maxlength="6"
                pattern="[0-9]{6}"
                class="w-full pl-12 pr-4 py-3.5 bg-gray-50 dark:bg-gray-800 border-2 border-transparent rounded-xl focus:border-violet-400 focus:bg-white dark:focus:bg-gray-900 transition-all outline-none text-gray-900 dark:text-white text-center text-2xl font-bold tracking-widest placeholder:text-gray-400 dark:placeholder:text-gray-500"
                placeholder="000000"
                autocomplete="off"
              />
            </div>
          </div>

          <!-- New Password -->
          <div>
            <label class="text-xs font-semibold text-gray-600 dark:text-gray-400 uppercase tracking-wider mb-2 block">Password Baru</label>
            <div class="relative">
              <span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-gray-400 dark:text-gray-500 text-xl">lock</span>
              <input
                type="password"
                name="password"
                id="password"
                required
                minlength="6"
                class="w-full pl-12 pr-12 py-3.5 bg-gray-50 dark:bg-gray-800 border-2 border-transparent rounded-xl focus:border-violet-400 focus:bg-white dark:focus:bg-gray-900 transition-all outline-none text-gray-900 dark:text-white placeholder:text-gray-400 dark:placeholder:text-gray-500"
                placeholder="Minimal 6 karakter"
              />
              <button
                type="button"
                id="togglePassword"
                class="absolute right-4 top-1/2 -translate-y-1/2 text-gray-400 dark:text-gray-500 hover:text-gray-600 dark:hover:text-gray-300"
              >
                <span class="material-symbols-outlined text-xl">visibility</span>
              </button>
            </div>
          </div>

          <button
            type="submit"
            class="w-full bg-gradient-to-r from-violet-600 to-blue-600 text-white py-4 rounded-xl font-bold text-base hover:shadow-xl hover:shadow-violet-500/30 active:scale-[0.98] transition-all mt-6"
          >
            <span id="btnText">Reset Password</span>
            <span id="btnLoader" class="hidden">Memproses...</span>
          </button>
        </form>

        <div class="mt-6 text-center">
          <a href="/login" class="text-sm text-violet-600 dark:text-violet-400 font-semibold hover:underline">
            ← Kembali ke Login
          </a>
        </div>
      </div>
    </div>
  </main>

  <style>
    @keyframes blob {
      0%, 100% { transform: translate(0, 0) scale(1); }
      33% { transform: translate(30px, -50px) scale(1.1); }
      66% { transform: translate(-20px, 20px) scale(0.9); }
    }
    .animate-blob {
      animation: blob 7s infinite;
    }
    .animation-delay-2000 {
      animation-delay: 2s;
    }
  </style>

  <script is:inline>
    function showToast(message, type = 'success') {
      const toast = document.getElementById('toast');
      const toastIcon = document.getElementById('toastIcon');
      const toastMessage = document.getElementById('toastMessage');
      
      if (type === 'success') {
        toastIcon.textContent = 'check_circle';
        toastIcon.className = 'material-symbols-outlined text-2xl text-emerald-500';
      } else {
        toastIcon.textContent = 'error';
        toastIcon.className = 'material-symbols-outlined text-2xl text-rose-500';
      }
      
      toastMessage.textContent = message;
      toast.style.transform = 'translateY(0) translateX(0)';
      
      setTimeout(() => {
        toast.style.transform = window.innerWidth < 768 ? 'translateY(6rem)' : 'translateX(420px)';
      }, 4000);
    }

    // Auto-format code input
    const codeInput = document.getElementById('code');
    codeInput?.addEventListener('input', (e) => {
      e.target.value = e.target.value.replace(/[^0-9]/g, '');
    });

    // Toggle password
    const togglePassword = document.getElementById('togglePassword');
    const passwordInput = document.getElementById('password');
    
    togglePassword?.addEventListener('click', () => {
      const type = passwordInput.type === 'password' ? 'text' : 'password';
      passwordInput.type = type;
      togglePassword.querySelector('span').textContent = type === 'password' ? 'visibility' : 'visibility_off';
    });

    // Handle form submission
    const resetForm = document.getElementById('resetForm');
    resetForm?.addEventListener('submit', async (e) => {
      e.preventDefault();
      
      const formData = new FormData(resetForm);
      const submitBtn = resetForm.querySelector('button[type="submit"]');
      const btnText = document.getElementById('btnText');
      const btnLoader = document.getElementById('btnLoader');
      
      btnText.classList.add('hidden');
      btnLoader.classList.remove('hidden');
      submitBtn.disabled = true;
      
      try {
        const response = await fetch('/api/auth/reset-password', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            email: formData.get('email'),
            code: formData.get('code'),
            password: formData.get('password')
          })
        });
        
        const result = await response.json();
        
        if (result.success) {
          showToast(result.message, 'success');
          setTimeout(() => {
            window.location.href = '/login';
          }, 2000);
        } else {
          showToast(result.message, 'error');
          btnText.classList.remove('hidden');
          btnLoader.classList.add('hidden');
          submitBtn.disabled = false;
          codeInput.value = '';
          codeInput.focus();
        }
      } catch (error) {
        showToast('Terjadi kesalahan: ' + error.message, 'error');
        btnText.classList.remove('hidden');
        btnLoader.classList.add('hidden');
        submitBtn.disabled = false;
      }
    });
  </script>
</BaseLayout>
