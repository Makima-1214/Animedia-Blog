---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
import { getAllArticlesAdmin, getAllCategories } from '../../lib/turso-helpers.js';

const articles = await getAllArticlesAdmin();
const categories = await getAllCategories();
---

<DashboardLayout title="Kelola Artikel - Admin Panel" activePage="artikel">
  <div class="p-4 md:p-8 lg:p-12">
    <!-- Header Section -->
    <header class="flex flex-col md:flex-row md:items-end justify-between gap-4 md:gap-6 mb-8 md:mb-12">
      <div class="space-y-1">
        <nav class="flex items-center gap-2 text-xs font-medium text-on-surface-variant uppercase tracking-widest mb-2">
          <span>Admin</span>
          <span class="material-symbols-outlined text-[10px]">chevron_right</span>
          <span class="text-on-surface">Manajemen Artikel</span>
        </nav>
        <h2 class="text-2xl md:text-4xl lg:text-5xl font-headline font-extrabold tracking-tighter text-on-surface">Pustaka Tulisan</h2>
        <p class="text-sm md:text-base text-on-surface-variant max-w-md font-body leading-relaxed">Kelola semua konten editorial Anda dengan presisi. Draft, revisi, dan publikasikan karya terbaik.</p>
      </div>
      <div>
        <a href="/dashboard/artikel/buat" class="bg-on-surface text-surface px-4 md:px-8 py-3 md:py-4 rounded-md font-headline font-bold flex items-center justify-center gap-2 md:gap-3 hover:bg-primary transition-all group editorial-shadow text-sm md:text-base w-full md:w-auto">
          <span class="material-symbols-outlined">edit_note</span>
          <span class="hidden sm:inline">Buat Artikel Baru</span>
          <span class="sm:hidden">Buat Baru</span>
        </a>
      </div>
    </header>

    <!-- Filters & Search Shell -->
    <section class="bg-surface-container-lowest rounded-xl p-6 editorial-shadow mb-8 flex flex-col md:flex-row gap-4 items-center border-b-0">
      <div class="relative flex-1 w-full">
        <span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-outline">search</span>
        <input id="searchInput" class="w-full bg-surface-container-low border-none rounded-lg pl-12 py-3 text-sm focus:ring-1 focus:ring-primary font-body placeholder:text-outline-variant" placeholder="Cari judul artikel atau penulis..." type="text" />
      </div>
      <div class="flex items-center gap-3 w-full md:w-auto">
        <div class="relative w-full md:w-48">
          <select id="categoryFilter" class="w-full bg-surface-container-low border-none rounded-lg px-4 py-3 text-sm appearance-none focus:ring-1 focus:ring-primary font-body text-on-surface">
            <option value="">Semua Kategori</option>
            {categories.map((cat: any) => <option value={cat.id}>{cat.name}</option>)}
          </select>
        </div>
        <div class="relative w-full md:w-40">
          <select id="statusFilter" class="w-full bg-surface-container-low border-none rounded-lg px-4 py-3 text-sm appearance-none focus:ring-1 focus:ring-primary font-body text-on-surface">
            <option value="">Semua Status</option>
            <option value="published">Terbit</option>
            <option value="draft">Draft</option>
          </select>
        </div>
      </div>
    </section>

    <!-- Table Canvas (Desktop) / Card List (Mobile) -->
    <div class="bg-surface-container-lowest rounded-xl overflow-hidden editorial-shadow">
      <!-- Desktop Table View -->
      <div class="hidden md:block overflow-x-auto">
        <table class="w-full text-left border-collapse">
          <thead>
            <tr class="bg-surface-container-low/50">
              <th class="px-6 py-5 text-xs font-bold uppercase tracking-widest text-on-surface-variant">Judul Artikel</th>
              <th class="px-6 py-5 text-xs font-bold uppercase tracking-widest text-on-surface-variant">Kategori</th>
              <th class="px-6 py-5 text-xs font-bold uppercase tracking-widest text-on-surface-variant">Penulis</th>
              <th class="px-6 py-5 text-xs font-bold uppercase tracking-widest text-on-surface-variant">Tanggal</th>
              <th class="px-6 py-5 text-xs font-bold uppercase tracking-widest text-on-surface-variant">Status</th>
              <th class="px-6 py-5 text-xs font-bold uppercase tracking-widest text-on-surface-variant text-right">Aksi</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-surface-container-low font-body">
            {articles.map((article: any) => {
              const category = categories.find((c: any) => c.id === article.category_id);
              return (
                <tr class="hover:bg-surface-container-low/30 transition-colors" data-category-id={article.category_id} data-status={article.status}>
                  <td class="px-6 py-6 max-w-sm">
                    <div class="flex items-center gap-4">
                      <img alt={article.title} class="w-12 h-12 rounded-lg object-cover bg-surface-container" src={article.cover_image || 'https://via.placeholder.com/100'} />
                      <div>
                        <p class="font-bold text-on-surface leading-tight mb-1">{article.title}</p>
                        <span class="text-[10px] text-tertiary font-bold tracking-widest uppercase">Edisi #{article.id}</span>
                      </div>
                    </div>
                  </td>
                  <td class="px-6 py-6">
                    <span class="bg-tertiary-container text-on-tertiary-container px-3 py-1 rounded-full text-[11px] font-bold uppercase tracking-tight">{category?.name || 'Uncategorized'}</span>
                  </td>
                  <td class="px-6 py-6 text-sm text-on-surface-variant">Editor Utama</td>
                  <td class="px-6 py-6 text-sm text-on-surface-variant">{article.published_at ? new Date(article.published_at).toLocaleDateString('id-ID', { day: 'numeric', month: 'short', year: 'numeric' }) : '-'}</td>
                  <td class="px-6 py-6">
                    <div class={`flex items-center gap-2 font-bold text-xs ${
                      article.status === 'published' ? 'text-green-600' : 'text-amber-500'
                    }`}>
                      <span class={`w-2 h-2 rounded-full ${
                        article.status === 'published' ? 'bg-green-500' : 'bg-amber-400'
                      }`}></span>
                      {article.status === 'published' ? 'Terbit' : 'Draft'}
                    </div>
                  </td>
                  <td class="px-6 py-6 text-right">
                    <div class="flex justify-end gap-2">
                      <a href={`/artikel/${article.slug}`} target="_blank" class="p-2 hover:bg-surface-container-high rounded-md transition-colors text-on-surface-variant hover:text-on-surface">
                        <span class="material-symbols-outlined">visibility</span>
                      </a>
                      <a href={`/dashboard/artikel/edit/${article.id}`} class="p-2 hover:bg-primary-container/20 rounded-md transition-colors text-on-surface-variant hover:text-primary">
                        <span class="material-symbols-outlined">edit</span>
                      </a>
                      <button 
                        onclick={`deleteArticle('${article.id}', '${article.title.replace(/'/g, "\\'")}')`}
                        class="p-2 hover:bg-error-container/20 rounded-md transition-colors text-outline-variant hover:text-error"
                      >
                        <span class="material-symbols-outlined">delete</span>
                      </button>
                    </div>
                  </td>
                </tr>
              );
            })}
          </tbody>
        </table>
      </div>

      <!-- Mobile Card View -->
      <div class="md:hidden divide-y divide-surface-container-low">
        {articles.map((article: any) => {
          const category = categories.find((c: any) => c.id === article.category_id);
          return (
            <div class="p-4 hover:bg-surface-container-low/30 transition-colors" data-category-id={article.category_id} data-status={article.status}>
              <div class="flex gap-3 mb-3">
                <img alt={article.title} class="w-20 h-20 rounded-lg object-cover bg-surface-container flex-shrink-0" src={article.cover_image || 'https://via.placeholder.com/100'} />
                <div class="flex-1 min-w-0">
                  <h3 class="font-bold text-on-surface leading-tight mb-1 line-clamp-2">{article.title}</h3>
                  <span class="bg-tertiary-container text-on-tertiary-container px-2 py-0.5 rounded-full text-[10px] font-bold uppercase">{category?.name || 'Uncategorized'}</span>
                </div>
              </div>
              <div class="flex items-center justify-between text-xs text-on-surface-variant mb-3">
                <span>{article.published_at ? new Date(article.published_at).toLocaleDateString('id-ID', { day: 'numeric', month: 'short', year: 'numeric' }) : '-'}</span>
                <div class={`flex items-center gap-2 font-bold ${
                  article.status === 'published' ? 'text-green-600' : 'text-amber-500'
                }`}>
                  <span class={`w-2 h-2 rounded-full ${
                    article.status === 'published' ? 'bg-green-500' : 'bg-amber-400'
                  }`}></span>
                  {article.status === 'published' ? 'Terbit' : 'Draft'}
                </div>
              </div>
              <div class="flex gap-2">
                <a href={`/artikel/${article.slug}`} target="_blank" class="flex-1 flex items-center justify-center gap-2 p-2 bg-surface-container-high rounded-md text-sm font-medium text-on-surface">
                  <span class="material-symbols-outlined text-[18px]">visibility</span>
                  Lihat
                </a>
                <a href={`/dashboard/artikel/edit/${article.id}`} class="flex-1 flex items-center justify-center gap-2 p-2 bg-primary-container/20 rounded-md text-sm font-medium text-primary">
                  <span class="material-symbols-outlined text-[18px]">edit</span>
                  Edit
                </a>
                <button 
                  onclick={`deleteArticle('${article.id}', '${article.title.replace(/'/g, "\\'")}')`}
                  class="flex-1 flex items-center justify-center gap-2 p-2 bg-error-container/20 rounded-md text-sm font-medium text-error"
                >
                  <span class="material-symbols-outlined text-[18px]">delete</span>
                  Hapus
                </button>
              </div>
            </div>
          );
        })}
      </div>

      <!-- Pagination -->
      <footer id="paginationFooter" class="px-6 py-5 flex items-center justify-between border-t border-surface-container-low bg-surface-container-lowest/50">
        <p class="text-xs text-on-surface-variant">Menampilkan <span id="showingCount" class="font-bold text-on-surface">0</span> dari <span class="font-bold text-on-surface">{articles.length}</span> artikel</p>
        <div class="flex items-center gap-1" id="paginationBtns"></div>
      </footer>
    </div>

    <!-- Asymmetric Stats Grid -->
    <section class="mt-12 grid grid-cols-1 md:grid-cols-3 gap-8">
      <div class="md:col-span-2 bg-gradient-to-br from-primary to-primary-dim p-8 rounded-xl text-surface flex flex-col justify-between editorial-shadow min-h-[200px]">
        <div class="flex justify-between items-start">
          <span class="material-symbols-outlined text-4xl opacity-40">trending_up</span>
          <span class="text-[10px] font-bold tracking-widest uppercase py-1 px-3 border border-surface/20 rounded-full">Statistik Terkini</span>
        </div>
        <div>
          <h3 class="text-3xl font-headline font-bold leading-none mb-2">{articles.reduce((sum: number, a: any) => sum + (a.views || 0), 0).toLocaleString()}</h3>
          <p class="text-surface/70 text-sm font-body">Total pembaca bulan ini melalui seluruh artikel yang terbit.</p>
        </div>
      </div>
      <div class="bg-tertiary-container p-8 rounded-xl flex flex-col justify-between editorial-shadow">
        <div class="space-y-4">
          <p class="text-[10px] font-bold tracking-widest uppercase text-tertiary">Top Kategori</p>
          <div class="space-y-3">
            <div class="flex justify-between items-center">
              <span class="text-sm font-medium text-on-tertiary-container">{categories[0]?.name || 'N/A'}</span>
              <span class="text-xs font-bold text-tertiary">42%</span>
            </div>
            <div class="w-full bg-surface-container-lowest h-1 rounded-full">
              <div class="bg-tertiary h-full rounded-full w-[42%]"></div>
            </div>
          </div>
        </div>
        <button class="text-tertiary text-xs font-bold uppercase tracking-tighter hover:underline text-left mt-8">Lihat Analitik Lengkap</button>
      </div>
    </section>
  </div>
</DashboardLayout>


  <script is:inline>
    const PAGE_SIZE = 10;
    let currentPage = 1;

    const searchInput = document.getElementById('searchInput');
    const categoryFilter = document.getElementById('categoryFilter');
    const statusFilter = document.getElementById('statusFilter');
    const tableRows = Array.from(document.querySelectorAll('tbody tr'));
    const mobileCards = Array.from(document.querySelectorAll('.md\\:hidden > div'));

    function getFilteredRows() {
      const searchTerm = searchInput.value.toLowerCase();
      const selectedCategory = categoryFilter.value;
      const selectedStatus = statusFilter.value;

      return tableRows.filter(row => {
        const title = row.querySelector('td:first-child')?.textContent?.toLowerCase() || '';
        const categoryId = row.getAttribute('data-category-id') || '';
        const status = row.getAttribute('data-status') || '';
        return title.includes(searchTerm)
          && (!selectedCategory || categoryId === selectedCategory)
          && (!selectedStatus || status === selectedStatus);
      });
    }

    function getFilteredCards() {
      const searchTerm = searchInput.value.toLowerCase();
      const selectedCategory = categoryFilter.value;
      const selectedStatus = statusFilter.value;

      return mobileCards.filter(card => {
        const title = card.querySelector('h3')?.textContent?.toLowerCase() || '';
        const categoryId = card.getAttribute('data-category-id') || '';
        const status = card.getAttribute('data-status') || '';
        return title.includes(searchTerm)
          && (!selectedCategory || categoryId === selectedCategory)
          && (!selectedStatus || status === selectedStatus);
      });
    }

    function renderPage() {
      const filteredRows = getFilteredRows();
      const filteredCards = getFilteredCards();
      const total = filteredRows.length;
      const totalPages = Math.max(1, Math.ceil(total / PAGE_SIZE));
      if (currentPage > totalPages) currentPage = totalPages;

      const start = (currentPage - 1) * PAGE_SIZE;
      const end = start + PAGE_SIZE;

      // Show/hide desktop rows
      tableRows.forEach(row => row.style.display = 'none');
      filteredRows.slice(start, end).forEach(row => row.style.display = '');

      // Show/hide mobile cards
      mobileCards.forEach(card => card.style.display = 'none');
      filteredCards.slice(start, end).forEach(card => card.style.display = '');

      // Update count
      document.getElementById('showingCount').textContent = Math.min(end, total) - start > 0
        ? `${start + 1}–${Math.min(end, total)}`
        : '0';

      // Render pagination buttons
      const btns = document.getElementById('paginationBtns');
      btns.innerHTML = '';

      if (totalPages <= 1) {
        document.getElementById('paginationFooter').style.display = total === 0 ? 'none' : '';
        return;
      }

      const prevBtn = document.createElement('button');
      prevBtn.className = `p-2 rounded-md transition-colors ${
        currentPage <= 1 ? 'text-outline pointer-events-none opacity-40' : 'hover:bg-surface-container-high text-on-surface'
      }`;
      prevBtn.innerHTML = '<span class="material-symbols-outlined">chevron_left</span>';
      prevBtn.onclick = () => { if (currentPage > 1) { currentPage--; renderPage(); } };
      btns.appendChild(prevBtn);

      for (let i = 1; i <= totalPages; i++) {
        const btn = document.createElement('button');
        btn.className = `w-8 h-8 flex items-center justify-center rounded-md text-xs font-bold transition-colors ${
          i === currentPage ? 'bg-on-surface text-surface' : 'hover:bg-surface-container-low text-on-surface'
        }`;
        btn.textContent = i;
        btn.onclick = ((p) => () => { currentPage = p; renderPage(); })(i);
        btns.appendChild(btn);
      }

      const nextBtn = document.createElement('button');
      nextBtn.className = `p-2 rounded-md transition-colors ${
        currentPage >= totalPages ? 'text-outline pointer-events-none opacity-40' : 'hover:bg-surface-container-high text-on-surface'
      }`;
      nextBtn.innerHTML = '<span class="material-symbols-outlined">chevron_right</span>';
      nextBtn.onclick = () => { if (currentPage < totalPages) { currentPage++; renderPage(); } };
      btns.appendChild(nextBtn);
    }

    function onFilterChange() {
      currentPage = 1;
      renderPage();
    }

    searchInput?.addEventListener('input', onFilterChange);
    categoryFilter?.addEventListener('change', onFilterChange);
    statusFilter?.addEventListener('change', onFilterChange);

    renderPage();

    // Delete article function
    async function deleteArticle(id, title) {
      window.showConfirm({
        title: 'Hapus Artikel?',
        message: `"${title}" akan dihapus permanen dan tidak bisa dikembalikan.`,
        okText: 'Hapus',
        okIcon: 'delete',
        okClass: 'bg-red-500 hover:bg-red-600',
        iconBg: 'bg-red-100',
        iconColor: 'text-red-500',
        icon: 'delete'
      }, async (confirmed) => {
        if (!confirmed) return;

        const formData = new FormData();
        formData.append('id', id);

        fetch('/api/articles/delete', {
          method: 'POST',
          body: formData
        })
        .then(response => response.json())
        .then(result => {
          if (result.success) {
            alert('✅ Artikel berhasil dihapus!');
            window.location.reload();
          } else {
            alert('❌ Error: ' + result.message);
          }
        })
        .catch(error => {
          alert('❌ Terjadi kesalahan: ' + error.message);
        });
      });
    }

    window.deleteArticle = deleteArticle;
  </script>
