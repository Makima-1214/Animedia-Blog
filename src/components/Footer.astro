---
import { getSiteConfig } from '../lib/settings.js';
const site = await getSiteConfig();
---

<footer class="w-full bg-gray-900 text-gray-400 mt-auto">
  <div class="max-w-7xl mx-auto px-4 md:px-6 pt-12 pb-8">
    <!-- Grid: brand full → nav+kategori 2col → newsletter full → desktop 4col -->
    <div class="grid grid-cols-2 lg:grid-cols-[2fr_1fr_1fr_1fr] gap-8 mb-10">

      <!-- Brand & Desc -->
      <div class="col-span-2 lg:col-span-1">
        <a href="/" class="inline-flex items-center gap-2 mb-4">
          {site.logoUrl ? (
            <img src={site.logoUrl} alt={site.name} class="h-8 w-auto object-contain" />
          ) : (
            <>
              <span class="material-symbols-outlined text-violet-400 text-2xl">architecture</span>
              <span class="text-xl font-black tracking-tighter text-white">{site.name}</span>
            </>
          )}
        </a>
        <p class="text-sm text-gray-400 leading-relaxed mb-5 max-w-xs">
          Portal berita teknologi, game, anime, film, dan gadget terkini untuk kamu.
        </p>
        <div class="flex items-center gap-3">
          <a href="#" aria-label="Twitter/X" class="w-9 h-9 rounded-full bg-gray-800 hover:bg-violet-600 flex items-center justify-center transition-colors">
            <svg class="w-4 h-4 fill-current text-white" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.744l7.737-8.835L1.254 2.25H8.08l4.253 5.622zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
          </a>
          <a href="#" aria-label="Instagram" class="w-9 h-9 rounded-full bg-gray-800 hover:bg-violet-600 flex items-center justify-center transition-colors">
            <svg class="w-4 h-4 fill-current text-white" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
          </a>
          <a href="#" aria-label="YouTube" class="w-9 h-9 rounded-full bg-gray-800 hover:bg-violet-600 flex items-center justify-center transition-colors">
            <svg class="w-4 h-4 fill-current text-white" viewBox="0 0 24 24"><path d="M23.498 6.186a3.016 3.016 0 00-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 00.502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 002.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 002.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
          </a>
          <a href="#" aria-label="TikTok" class="w-9 h-9 rounded-full bg-gray-800 hover:bg-violet-600 flex items-center justify-center transition-colors">
            <svg class="w-4 h-4 fill-current text-white" viewBox="0 0 24 24"><path d="M12.525.02c1.31-.02 2.61-.01 3.91-.02.08 1.53.63 3.09 1.75 4.17 1.12 1.11 2.7 1.62 4.24 1.79v4.03c-1.44-.05-2.89-.35-4.2-.97-.57-.26-1.1-.59-1.62-.93-.01 2.92.01 5.84-.02 8.75-.08 1.4-.54 2.79-1.35 3.94-1.31 1.92-3.58 3.17-5.91 3.21-1.43.08-2.86-.31-4.08-1.03-2.02-1.19-3.44-3.37-3.65-5.71-.02-.5-.03-1-.01-1.49.18-1.9 1.12-3.72 2.58-4.96 1.66-1.44 3.98-2.13 6.15-1.72.02 1.48-.04 2.96-.04 4.44-.99-.32-2.15-.23-3.02.37-.63.41-1.11 1.04-1.36 1.75-.21.51-.15 1.07-.14 1.61.24 1.64 1.82 3.02 3.5 2.87 1.12-.01 2.19-.66 2.77-1.61.19-.33.4-.67.41-1.06.1-1.79.06-3.57.07-5.36.01-4.03-.01-8.05.02-12.07z"/></svg>
          </a>
        </div>
      </div>

      <!-- Navigasi -->
      <div>
        <h4 class="text-white font-bold text-sm uppercase tracking-widest mb-4">Navigasi</h4>
        <ul class="space-y-2.5">
          <li><a href="/" class="text-sm hover:text-violet-400 transition-colors">Beranda</a></li>
          <li><a href="/artikel" class="text-sm hover:text-violet-400 transition-colors">Semua Artikel</a></li>
          <li><a href="/toko" class="text-sm hover:text-violet-400 transition-colors">Toko Afiliasi</a></li>
          <li><a href="/berlangganan" class="text-sm hover:text-violet-400 transition-colors">Newsletter</a></li>
        </ul>
      </div>

      <!-- Kategori -->
      <div>
        <h4 class="text-white font-bold text-sm uppercase tracking-widest mb-4">Kategori</h4>
        <ul class="space-y-2.5">
          <li><a href="/kategori/anime" class="text-sm hover:text-violet-400 transition-colors">Anime</a></li>
          <li><a href="/kategori/teknologi" class="text-sm hover:text-violet-400 transition-colors">Teknologi</a></li>
          <li><a href="/kategori/game" class="text-sm hover:text-violet-400 transition-colors">Game</a></li>
          <li><a href="/kategori/film" class="text-sm hover:text-violet-400 transition-colors">Film</a></li>
          <li><a href="/kategori/gadget" class="text-sm hover:text-violet-400 transition-colors">Gadget</a></li>
        </ul>
      </div>

      <!-- Newsletter CTA -->
      <div class="col-span-2 lg:col-span-1">
        <h4 class="text-white font-bold text-sm uppercase tracking-widest mb-4">Newsletter</h4>
        <p class="text-sm text-gray-400 mb-4 leading-relaxed">Dapatkan artikel terbaru langsung di inbox kamu. Gratis!</p>
        <a
          href="/berlangganan"
          class="inline-flex items-center justify-center gap-2 bg-violet-600 hover:bg-violet-700 text-white text-sm font-bold px-4 py-2.5 rounded-xl transition-colors w-full sm:w-auto lg:w-full"
        >
          <span class="material-symbols-outlined text-[18px]">mail</span>
          Berlangganan Gratis
        </a>
      </div>
    </div>

    <!-- Divider -->
    <div class="border-t border-gray-800 pt-6 flex flex-col sm:flex-row items-center justify-between gap-3">
      <p class="text-xs text-gray-500 text-center sm:text-left">
        © {new Date().getFullYear()} <span class="text-gray-400 font-semibold">{site.name}</span>. All rights reserved.
      </p>
      <div class="flex flex-wrap items-center justify-center gap-x-4 gap-y-1 text-xs text-gray-500">
        <a href="/privasi" class="hover:text-gray-300 transition-colors">Privasi</a>
        <span aria-hidden="true">·</span>
        <a href="/syarat" class="hover:text-gray-300 transition-colors">Syarat & Ketentuan</a>
        <span aria-hidden="true">·</span>
        <a href="/sitemap.xml" class="hover:text-gray-300 transition-colors">Sitemap</a>
      </div>
    </div>
  </div>
</footer>
