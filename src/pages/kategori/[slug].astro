---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import { getArticlesByCategory, getCategoryBySlug, getAllCategories, getAllArticles, getAllTags } from '../../lib/turso-helpers.js';

const { slug } = Astro.params;
if (!slug) return Astro.redirect('/');

const category: any = await getCategoryBySlug(slug);
if (!category) return Astro.redirect('/');

const allArticles = await getArticlesByCategory(category.id);
const allCategories = await getAllCategories();
const allArticlesAll = await getAllArticles();
const allTags: any[] = await getAllTags();

const PAGE_SIZE = 10;
const page = Math.max(1, parseInt(Astro.url.searchParams.get('page') || '1'));
const totalPages = Math.ceil(allArticles.length / PAGE_SIZE);
const articles = allArticles.slice((page - 1) * PAGE_SIZE, page * PAGE_SIZE);

const title = `${category.name} - Animedia`;
const description = category.description || `Artikel tentang ${category.name}`;
---

<BaseLayout title={title} description={description}>
  <Header />

  <!-- Main Content Canvas -->
  <main class="flex-grow max-w-7xl mx-auto px-6 py-12 w-full">
    <!-- Breadcrumb & Title -->
    <div class="mb-12">
      <div class="flex items-center gap-2 text-xs font-bold tracking-widest text-on-surface-variant mb-4 uppercase">
        <a class="hover:text-primary" href="/">BERANDA</a>
        <span class="material-symbols-outlined text-xs">chevron_right</span>
        <span class="text-primary">{category.name.toUpperCase()}</span>
      </div>
      <h1 class="text-4xl md:text-5xl font-extrabold tracking-tighter text-on-surface">
        Katalog {category.name} & <span class="text-primary">Ulasan Eksklusif</span>
      </h1>
      <p class="mt-4 text-on-surface-variant max-w-2xl leading-relaxed">
        {category.description || `Menjelajahi dunia ${category.name} melalui sudut pandang editorial yang tajam.`}
      </p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12">
      <!-- Main Feed (8 cols) -->
      <div class="lg:col-span-8 space-y-12">
        <!-- Featured News (Asymmetric Layout) -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          {articles.slice(0, 1).map((article: any) => (
            <article class="bg-surface-container-lowest rounded-xl overflow-hidden group">
              <div class="relative h-64 overflow-hidden">
                <img
                  alt={article.title}
                  class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
                  src={article.cover_image || 'https://via.placeholder.com/800x400'}
                />
                <div class="absolute top-4 left-4 bg-primary text-on-primary text-[10px] font-black px-3 py-1 rounded-full uppercase tracking-widest">
                  UTAMA
                </div>
              </div>
              <div class="p-8">
                <div class="flex items-center gap-3 mb-4 text-xs font-semibold text-tertiary">
                  <span>{article.published_at ? new Date(article.published_at).toLocaleDateString('id-ID', { day: 'numeric', month: 'short', year: 'numeric' }).toUpperCase() : ''}</span>
                  <span class="w-1 h-1 rounded-full bg-outline-variant"></span>
                  <span>ARTIKEL</span>
                </div>
                <h2 class="text-2xl font-bold leading-tight mb-4 group-hover:text-primary transition-colors">
                  {article.title}
                </h2>
                <p class="text-on-surface-variant text-sm leading-relaxed mb-6">
                  {article.excerpt}
                </p>
                <a href={`/artikel/${article.slug}`} class="inline-flex items-center gap-2 text-primary font-bold text-sm">
                  BACA SELENGKAPNYA <span class="material-symbols-outlined text-sm">arrow_forward</span>
                </a>
              </div>
            </article>
          ))}

          <div class="flex flex-col gap-6">
            {articles.slice(1, 4).map((article: any) => (
              <article class="bg-surface-container-lowest rounded-xl p-6 flex gap-4 hover:bg-surface transition-colors">
                <div class="w-24 h-24 shrink-0 rounded-lg overflow-hidden">
                  <img alt={article.title} class="w-full h-full object-cover" src={article.cover_image || 'https://via.placeholder.com/200'} />
                </div>
                <div>
                  <a href={`/artikel/${article.slug}`}>
                    <h3 class="font-bold leading-snug mb-2 line-clamp-2 hover:text-primary">{article.title}</h3>
                  </a>
                  <div class="text-[10px] font-bold text-on-surface-variant uppercase tracking-wider">
                    {category.name.toUpperCase()}
                  </div>
                </div>
              </article>
            ))}
          </div>
        </div>

        <!-- Review Grid (Editorial Style) -->
        <div class="space-y-8">
          <div class="flex items-center justify-between">
            <h2 class="text-xl font-black tracking-tight flex items-center gap-2">
              <span class="w-2 h-8 bg-primary"></span>
              ARTIKEL TERBARU
            </h2>
            <a class="text-xs font-bold text-primary hover:underline" href="/artikel">LIHAT SEMUA</a>
          </div>

          <div class="space-y-6">
            {articles.map((article: any) => (
              <article class="flex gap-4 group cursor-pointer">
                <a href={`/artikel/${article.slug}`} class="flex gap-4 w-full">
                  <div class="w-32 md:w-56 h-32 md:h-40 flex-shrink-0 overflow-hidden rounded-xl bg-surface-container shadow-sm border border-outline-variant/30">
                    <img
                      alt={article.title}
                      class="w-full h-full object-cover transition-transform group-hover:scale-105"
                      src={article.cover_image || 'https://via.placeholder.com/800x400'}
                    />
                  </div>
                  <div class="flex-grow">
                    <div class="flex items-center gap-2 mb-1 md:mb-2">
                      <span class="text-[10px] font-bold text-primary uppercase tracking-wider">
                        {category.name}
                      </span>
                      <span class="text-[10px] text-on-surface-variant/60 font-medium uppercase hidden md:inline">
                        {article.published_at ? new Date(article.published_at).toLocaleDateString('id-ID', { day: 'numeric', month: 'short', year: 'numeric' }) : ''}
                      </span>
                    </div>
                    <h4 class="text-base md:text-xl font-extrabold text-on-surface group-hover:text-primary transition-colors leading-tight mb-1 md:mb-2 line-clamp-2">
                      {article.title}
                    </h4>
                    <p class="text-on-surface-variant text-xs md:text-sm leading-relaxed line-clamp-2 mb-2 md:mb-4 hidden md:block">
                      {article.excerpt}
                    </p>
                    <div class="flex items-center text-[10px] font-bold text-on-surface-variant uppercase tracking-wider">
                      <span class="material-symbols-outlined text-sm mr-1">person</span> Editor •
                      <span class="material-symbols-outlined text-sm mx-1">schedule</span> {article.read_time} Menit
                    </div>
                  </div>
                </a>
              </article>
            ))}
          </div>
        </div>

        <!-- Pagination -->
        {totalPages > 1 && (
          <div class="pt-8 border-t border-outline-variant/20 flex justify-between items-center">
            <a
              href={page > 1 ? `/kategori/${slug}?page=${page - 1}` : '#'}
              class={`flex items-center gap-2 text-sm font-bold transition-colors ${page <= 1 ? 'text-outline pointer-events-none' : 'text-on-surface-variant hover:text-primary'}`}
            >
              <span class="material-symbols-outlined">west</span> SEBELUMNYA
            </a>
            <div class="flex items-center gap-2">
              {Array.from({ length: totalPages }, (_, i) => i + 1).map(p => (
                <a
                  href={`/kategori/${slug}?page=${p}`}
                  class={`w-8 h-8 flex items-center justify-center rounded-lg font-bold text-sm transition-all ${
                    p === page ? 'bg-primary text-on-primary shadow-md' : 'hover:bg-surface-container-highest'
                  }`}
                >{p}</a>
              ))}
            </div>
            <a
              href={page < totalPages ? `/kategori/${slug}?page=${page + 1}` : '#'}
              class={`flex items-center gap-2 text-sm font-bold transition-colors ${page >= totalPages ? 'text-outline pointer-events-none' : 'text-on-surface-variant hover:text-primary'}`}
            >
              BERIKUTNYA <span class="material-symbols-outlined">east</span>
            </a>
          </div>
        )}
      </div>

      <!-- Sidebar (4 cols) -->
      <aside class="lg:col-span-4 space-y-10">
        <!-- Trending Topics -->
        <div class="bg-surface-container-lowest rounded-2xl p-8 border border-outline-variant/10">
          <h3 class="text-sm font-black tracking-widest text-on-surface uppercase mb-6">Trending Tags</h3>
          {allTags.length > 0 ? (
            <div class="flex flex-wrap gap-2">
              {allTags.slice(0, 8).map((tag: any) => (
                <a class="px-4 py-2 bg-white text-on-surface-variant text-xs font-semibold rounded-full border border-slate-100 hover:border-primary hover:text-primary transition-all" href={`/tag/${tag.slug}`}>#{tag.name}</a>
              ))}
            </div>
          ) : (
            <p class="text-xs text-on-surface-variant">Belum ada tag tersedia.</p>
          )}
        </div>

        <!-- Newsletter -->
        <div class="bg-primary rounded-2xl p-8 text-on-primary">
          <h3 class="text-xl font-black leading-tight mb-4">Dapatkan Update Mingguan</h3>
          <p class="text-sm opacity-80 mb-6">Kurasi artikel terbaik dan berita terbaru langsung ke inbox Anda.</p>
          <a href="/berlangganan" class="block w-full bg-white text-primary font-bold py-3 rounded-xl shadow-lg hover:bg-primary-fixed transition-all text-center text-sm">
            BERLANGGANAN
          </a>
        </div>

        <!-- All Categories -->
        <div class="bg-surface-container/30 rounded-2xl p-6 border border-outline-variant/50">
          <h3 class="text-[11px] font-black tracking-[0.2em] text-on-surface-variant uppercase mb-4 border-l-4 border-secondary pl-4">Indeks Kategori</h3>
          <div class="flex flex-col gap-1">
            {allCategories.map((cat: any) => (
              <a
                href={`/kategori/${cat.slug}`}
                class={`flex items-center justify-between py-2 px-3 rounded-lg transition-all group ${
                  cat.id === category.id
                    ? 'bg-primary text-on-primary shadow-md'
                    : 'hover:bg-white hover:shadow-sm'
                }`}
              >
                <span class={`text-sm font-bold ${
                  cat.id === category.id ? 'text-on-primary' : 'text-on-surface group-hover:text-primary'
                }`}>{cat.name}</span>
                <span class={`text-xs px-2 py-0.5 rounded-full font-bold ${
                  cat.id === category.id ? 'bg-white/20 text-on-primary' : 'bg-primary-container text-on-primary-container'
                }`}>
                  {allArticlesAll.filter((a: any) => a.category_id === cat.id).length}
                </span>
              </a>
            ))}
          </div>
        </div>
      </aside>
    </div>
  </main>

  <!-- Footer -->
  <footer class="w-full mt-auto border-t border-slate-200 bg-slate-50">
    <div class="max-w-7xl mx-auto px-6 py-12 flex flex-col md:flex-row justify-between items-center gap-8">
      <div class="flex flex-col items-center md:items-start gap-4">
        <div class="font-bold text-slate-900 text-xl">Animedia</div>
        <div class="text-sm text-slate-500">© {new Date().getFullYear()} Animedia. All rights reserved.</div>
      </div>
      <div class="flex flex-wrap justify-center gap-8">
        <a class="text-sm text-slate-500 hover:text-blue-500 transition-all" href="/">Beranda</a>
        <a class="text-sm text-slate-500 hover:text-blue-500 transition-all" href="/artikel">Artikel</a>
        <a class="text-sm text-slate-500 hover:text-blue-500 transition-all" href="/berlangganan">Newsletter</a>
        <a class="text-sm text-slate-500 hover:text-blue-500 transition-all" href="/toko">Toko</a>
      </div>
    </div>
  </footer>
</BaseLayout>
