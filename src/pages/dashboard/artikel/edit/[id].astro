---
import DashboardLayout from '../../../../layouts/DashboardLayout.astro';
import { getAllCategories, getAffiliatesAdminByArticle, getAllAffiliates, getArticleById } from '../../../../lib/turso-helpers.js';

interface Category {
  id: number;
  name: string;
  slug: string;
}

const { id } = Astro.params;

if (!id) {
  return Astro.redirect('/dashboard/artikel');
}

const article = await getArticleById(id);

if (!article) {
  return Astro.redirect('/dashboard/artikel');
}

const categories = await getAllCategories() as Category[];
const affiliates = await getAffiliatesAdminByArticle(id) as any[];
const allAffiliates = (await getAllAffiliates() as any[]).filter((p: any) => p.article_id !== id);
---

<DashboardLayout title="Edit Artikel" activePage="artikel">
  <div class="p-4 md:p-8 lg:p-12">
    <header class="mb-8 md:mb-12">
      <nav class="flex items-center gap-2 text-xs font-medium text-on-surface-variant uppercase tracking-widest mb-4">
        <a href="/dashboard" class="hover:text-primary">Admin</a>
        <span class="material-symbols-outlined text-[10px]">chevron_right</span>
        <a href="/dashboard/artikel" class="hover:text-primary">Artikel</a>
        <span class="material-symbols-outlined text-[10px]">chevron_right</span>
        <span class="text-on-surface">Edit</span>
      </nav>
      <h2 class="text-2xl md:text-4xl lg:text-5xl font-headline font-extrabold tracking-tighter text-on-surface mb-2">Edit Artikel</h2>
      <p class="text-sm md:text-base text-on-surface-variant font-body">Perbarui konten artikel Anda</p>
    </header>

    <form id="editArticleForm" class="max-w-4xl">
      <input type="hidden" name="id" value={article.id} />
      <input type="hidden" name="published_at" value={article.published_at || ''} />
      
      <div class="bg-surface-container-lowest p-4 md:p-8 rounded-xl editorial-shadow space-y-6 md:space-y-8">
        <!-- Title -->
        <div class="space-y-2">
          <label class="text-xs font-bold uppercase tracking-widest text-on-surface-variant">Judul Artikel *</label>
          <input
            type="text"
            name="title"
            id="title"
            required
            value={article.title}
            class="w-full border-b-2 border-outline-variant bg-transparent py-3 text-xl md:text-2xl font-bold focus:border-primary focus:ring-0 transition-colors"
            placeholder="Masukkan judul artikel..."
          />
        </div>

        <!-- Slug -->
        <div class="space-y-2">
          <label class="text-xs font-bold uppercase tracking-widest text-on-surface-variant">Slug (URL) *</label>
          <input
            type="text"
            name="slug"
            id="slug"
            required
            value={article.slug}
            class="w-full border-b border-outline-variant bg-transparent py-2 focus:border-primary focus:ring-0 transition-colors font-mono text-sm"
            placeholder="judul-artikel-anda"
          />
          <p class="text-[10px] text-on-surface-variant/60">URL artikel: /artikel/{article.slug}</p>
        </div>

        <!-- Excerpt -->
        <div class="space-y-2">
          <label class="text-xs font-bold uppercase tracking-widest text-on-surface-variant">Ringkasan *</label>
          <textarea
            name="excerpt"
            required
            rows="3"
            class="w-full border border-outline-variant bg-transparent rounded-lg p-4 focus:border-primary focus:ring-1 focus:ring-primary transition-colors"
            placeholder="Tulis ringkasan singkat artikel..."
          >{article.excerpt}</textarea>
        </div>

        <!-- Content Editor -->
        <div class="space-y-2">
          <label class="text-xs font-bold uppercase tracking-widest text-on-surface-variant">Konten Artikel *</label>
          <div class="border border-outline-variant rounded-xl overflow-hidden">
            <!-- Toolbar -->
            <div id="editor-toolbar" class="bg-gray-50 border-b border-outline-variant px-2 py-1.5 flex flex-wrap items-center gap-0.5">
              <button type="button" data-cmd="undo" title="Undo" class="tbtn"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 7v6h6"/><path d="M21 17a9 9 0 00-9-9 9 9 0 00-6 2.3L3 13"/></svg></button>
              <button type="button" data-cmd="redo" title="Redo" class="tbtn"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 7v6h-6"/><path d="M3 17a9 9 0 019-9 9 9 0 016 2.3L21 13"/></svg></button>
              <div class="tbtn-sep"></div>
              <select id="formatBlock" title="Format" class="tbtn-select">
                <option value="p">Paragraf</option>
                <option value="h1">Heading 1</option>
                <option value="h2">Heading 2</option>
                <option value="h3">Heading 3</option>
                <option value="h4">Heading 4</option>
                <option value="pre">Code Block</option>
              </select>
              <div class="tbtn-sep"></div>
              <button type="button" data-cmd="bold" title="Bold (Ctrl+B)" class="tbtn font-bold">B</button>
              <button type="button" data-cmd="italic" title="Italic (Ctrl+I)" class="tbtn italic">I</button>
              <button type="button" data-cmd="underline" title="Underline (Ctrl+U)" class="tbtn underline">U</button>
              <button type="button" data-cmd="strikeThrough" title="Strikethrough" class="tbtn line-through">S</button>
              <div class="tbtn-sep"></div>
              <label title="Text Color" class="tbtn cursor-pointer relative">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M11 3L5.5 17h2.25l1.12-3h6.25l1.12 3H18.5L13 3h-2zm-1.38 9L12 5.67 14.38 12H9.62z"/></svg>
                <input type="color" id="textColor" class="absolute inset-0 opacity-0 w-full h-full cursor-pointer" value="#000000" />
              </label>
              <label title="Highlight" class="tbtn cursor-pointer relative">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M15.5 14h-.79l-.28-.27A6.47 6.47 0 0016 9.5 6.5 6.5 0 109.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14z"/></svg>
                <input type="color" id="bgColor" class="absolute inset-0 opacity-0 w-full h-full cursor-pointer" value="#ffff00" />
              </label>
              <div class="tbtn-sep"></div>
              <button type="button" data-cmd="justifyLeft" title="Align Left" class="tbtn"><svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M3 3h18v2H3zm0 4h12v2H3zm0 4h18v2H3zm0 4h12v2H3zm0 4h18v2H3z"/></svg></button>
              <button type="button" data-cmd="justifyCenter" title="Align Center" class="tbtn"><svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M3 3h18v2H3zm3 4h12v2H6zm-3 4h18v2H3zm3 4h12v2H6zm-3 4h18v2H3z"/></svg></button>
              <button type="button" data-cmd="justifyRight" title="Align Right" class="tbtn"><svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M3 3h18v2H3zm6 4h12v2H9zm-6 4h18v2H3zm6 4h12v2H9zm-6 4h18v2H3z"/></svg></button>
              <div class="tbtn-sep"></div>
              <button type="button" data-cmd="insertUnorderedList" title="Bullet List" class="tbtn"><svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M4 6h2v2H4zm0 5h2v2H4zm0 5h2v2H4zM8 6h13v2H8zm0 5h13v2H8zm0 5h13v2H8z"/></svg></button>
              <button type="button" data-cmd="insertOrderedList" title="Numbered List" class="tbtn"><svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M2 17h2v.5H3v1h1v.5H2v1h3v-4H2v1zm1-9h1V4H2v1h1v3zm-1 3h1.8L2 13.1v.9h3v-1H3.2L5 10.9V10H2v1zm5-8v2h14V3H7zm0 14h14v-2H7v2zm0-6h14v-2H7v2z"/></svg></button>
              <button type="button" data-cmd="outdent" title="Outdent" class="tbtn"><svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M11 17h10v-2H11v2zm-8-5l4 4V8l-4 4zm0 9h18v-2H3v2zM3 3v2h18V3H3zm8 6h10V7H11v2zm0 4h10v-2H11v2z"/></svg></button>
              <button type="button" data-cmd="indent" title="Indent" class="tbtn"><svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M3 21h18v-2H3v2zM3 8v8l4-4-4-4zm8 9h10v-2H11v2zM3 3v2h18V3H3zm8 6h10V7H11v2zm0 4h10v-2H11v2z"/></svg></button>
              <div class="tbtn-sep"></div>
              <button type="button" id="btnLink" title="Insert Link" class="tbtn"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M10 13a5 5 0 007.54.54l3-3a5 5 0 00-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 00-7.54-.54l-3 3a5 5 0 007.07 7.07l1.71-1.71"/></svg></button>
              <button type="button" id="btnImage" title="Insert Image" class="tbtn"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg></button>
              <button type="button" id="btnTable" title="Insert Table" class="tbtn"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="1"/><line x1="3" y1="9" x2="21" y2="9"/><line x1="3" y1="15" x2="21" y2="15"/><line x1="9" y1="3" x2="9" y2="21"/><line x1="15" y1="3" x2="15" y2="21"/></svg></button>
              <button type="button" data-cmd="insertHorizontalRule" title="Horizontal Rule" class="tbtn"><svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M19 11H5v2h14v-2z"/></svg></button>
              <div class="tbtn-sep"></div>
              <button type="button" id="btnQuote" title="Blockquote" class="tbtn"><svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M6 17h3l2-4V7H5v6h3zm8 0h3l2-4V7h-6v6h3z"/></svg></button>
              <button type="button" data-cmd="removeFormat" title="Clear Formatting" class="tbtn"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg></button>
            </div>
            <div id="content-editor" contenteditable="true"
              class="min-h-[500px] p-5 text-base leading-relaxed bg-white focus:outline-none"
              spellcheck="true"></div>
          </div>
          <textarea name="content" id="content" required class="hidden"></textarea>
          <p class="text-[10px] text-on-surface-variant/60">Tip: Ctrl+B bold · Ctrl+I italic · Ctrl+U underline · Ctrl+Z undo</p>
        </div>

        <!-- Cover Image -->
        <div class="space-y-2">
          <label class="text-xs font-bold uppercase tracking-widest text-on-surface-variant">URL Gambar Cover</label>
          <input
            type="url"
            name="coverImage"
            value={article.cover_image || ''}
            class="w-full border-b border-outline-variant bg-transparent py-2 focus:border-primary focus:ring-0 transition-colors"
            placeholder="https://example.com/image.jpg"
          />
        </div>

        <!-- Category & Settings -->
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          <div class="space-y-2">
            <label class="text-xs font-bold uppercase tracking-widest text-on-surface-variant">Kategori *</label>
            <select
              name="categoryId"
              required
              class="w-full border border-outline-variant bg-transparent rounded-lg px-4 py-3 focus:border-primary focus:ring-1 focus:ring-primary"
            >
              <option value="">Pilih Kategori</option>
              {categories.map(cat => (
                <option value={cat.id} selected={cat.id === article.category_id}>{cat.name}</option>
              ))}
            </select>
          </div>

          <div class="space-y-2">
            <label class="text-xs font-bold uppercase tracking-widest text-on-surface-variant">Waktu Baca (menit)</label>
            <input
              type="number"
              name="readTime"
              value={article.read_time || 5}
              min="1"
              class="w-full border border-outline-variant bg-transparent rounded-lg px-4 py-3 focus:border-primary focus:ring-1 focus:ring-primary"
            />
          </div>

          <div class="space-y-2">
            <label class="text-xs font-bold uppercase tracking-widest text-on-surface-variant">Status *</label>
            <select
              name="status"
              required
              class="w-full border border-outline-variant bg-transparent rounded-lg px-4 py-3 focus:border-primary focus:ring-1 focus:ring-primary"
            >
              <option value="draft" selected={article.status === 'draft'}>Draft</option>
              <option value="published" selected={article.status === 'published'}>Published</option>
            </select>
          </div>
        </div>

        <!-- Affiliate Products -->
        <div class="space-y-4 pt-6 border-t border-outline-variant/30">
          <div class="flex items-center justify-between">
            <div>
              <label class="text-xs font-bold uppercase tracking-widest text-on-surface-variant">Produk Afiliasi</label>
              <p class="text-[10px] text-on-surface-variant/60 mt-1">Produk rekomendasi yang tampil di halaman baca artikel</p>
            </div>
            <label class="flex items-center gap-2 cursor-pointer">
              <span class="text-xs text-on-surface-variant">Tampilkan</span>
              <div class="relative">
                <input type="checkbox" id="affiliateToggle" class="sr-only peer" checked />
                <div class="w-10 h-6 bg-outline-variant rounded-full peer peer-checked:bg-primary transition-colors"></div>
                <div class="absolute top-1 left-1 w-4 h-4 bg-white rounded-full transition-transform peer-checked:translate-x-4"></div>
              </div>
            </label>
          </div>

          <div id="affiliateSection" class="space-y-4">
            <!-- Product List -->
            <div id="affiliateList" class="space-y-2">
              {affiliates.map((p: any) => (
                <div class="flex items-center gap-3 bg-surface-container p-3 rounded-lg" data-id={p.id}>
                  {p.image && <img src={p.image} class="w-12 h-12 rounded object-cover" />}
                  <div class="flex-1 min-w-0">
                    <p class="font-bold text-sm text-on-surface truncate">{p.name}</p>
                    <p class="text-xs text-on-surface-variant">{p.price && `Rp ${p.price} · `}{p.platform}</p>
                  </div>
                  <span class={`text-[10px] font-bold px-2 py-1 rounded-full ${p.is_active ? 'bg-green-100 text-green-700' : 'bg-gray-100 text-gray-500'}`}>
                    {p.is_active ? 'Aktif' : 'Nonaktif'}
                  </span>
                  <button type="button" onclick={`deleteAffiliate('${p.id}')`} class="p-1 hover:text-error transition-colors">
                    <span class="material-symbols-outlined text-[18px]">delete</span>
                  </button>
                </div>
              ))}
            </div>

            <!-- Add Product Form -->
            <div class="bg-surface-container-low rounded-xl p-4 space-y-3">
              <!-- Tabs -->
              <div class="flex gap-2 border-b border-outline-variant/30 pb-3">
                <button type="button" id="tabNew" onclick="switchTab('new')" class="text-xs font-bold px-3 py-1.5 rounded-lg bg-on-surface text-surface transition-all">+ Buat Baru</button>
                <button type="button" id="tabLibrary" onclick="switchTab('library')" class="text-xs font-bold px-3 py-1.5 rounded-lg bg-surface-container text-on-surface-variant transition-all">📦 Pilih dari Library {allAffiliates.length > 0 ? `(${allAffiliates.length})` : ''}</button>
              </div>

              <!-- New Product Form -->
              <div id="formNew" class="space-y-3">
                <p class="text-xs font-bold uppercase tracking-widest text-on-surface-variant">Tambah Produk Baru</p>
              <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
                <input id="aff_name" type="text" placeholder="Nama produk *" class="border border-outline-variant bg-transparent rounded-lg px-3 py-2 text-sm focus:border-primary focus:ring-1 focus:ring-primary" />
                <input id="aff_price" type="text" placeholder="Harga (contoh: 299.000)" class="border border-outline-variant bg-transparent rounded-lg px-3 py-2 text-sm focus:border-primary focus:ring-1 focus:ring-primary" />
                <input id="aff_url" type="url" placeholder="URL afiliasi (Tokopedia/Shopee/dll) *" class="border border-outline-variant bg-transparent rounded-lg px-3 py-2 text-sm focus:border-primary focus:ring-1 focus:ring-primary md:col-span-2" />
                <input id="aff_image" type="url" placeholder="URL gambar produk" class="border border-outline-variant bg-transparent rounded-lg px-3 py-2 text-sm focus:border-primary focus:ring-1 focus:ring-primary" />
                <select id="aff_platform" class="border border-outline-variant bg-transparent rounded-lg px-3 py-2 text-sm focus:border-primary focus:ring-1 focus:ring-primary">
                  <option value="">Platform</option>
                  <option value="Tokopedia">Tokopedia</option>
                  <option value="Shopee">Shopee</option>
                  <option value="Lazada">Lazada</option>
                  <option value="Amazon">Amazon</option>
                  <option value="Blibli">Blibli</option>
                  <option value="Lainnya">Lainnya</option>
                </select>
                <input id="aff_desc" type="text" placeholder="Deskripsi singkat" class="border border-outline-variant bg-transparent rounded-lg px-3 py-2 text-sm focus:border-primary focus:ring-1 focus:ring-primary" />
                <label class="flex items-center gap-2 text-sm text-on-surface-variant">
                  <input type="checkbox" id="aff_active" checked class="rounded" />
                  Aktifkan produk ini
                </label>
              </div>
              <button type="button" id="addAffiliateBtn" class="bg-primary text-on-primary px-4 py-2 rounded-lg text-sm font-bold hover:opacity-90 transition-opacity flex items-center gap-2">
                <span class="material-symbols-outlined text-[18px]">add</span>
                Tambah Produk
              </button>
            </div>

              <!-- Library Picker -->
              <div id="formLibrary" class="hidden space-y-3">
                <p class="text-xs font-bold uppercase tracking-widest text-on-surface-variant">Pilih dari Library</p>
                {allAffiliates.length === 0 ? (
                  <p class="text-xs text-on-surface-variant py-4 text-center">Belum ada produk di library. <a href="/dashboard/afiliasi" class="text-primary underline">Tambah di sini</a></p>
                ) : (
                  <div class="space-y-2 max-h-60 overflow-y-auto">
                    {allAffiliates.map((p: any) => (
                      <div class="flex items-center gap-3 bg-surface-container p-3 rounded-lg">
                        {p.image && <img src={p.image} class="w-10 h-10 rounded object-cover flex-shrink-0" />}
                        <div class="flex-1 min-w-0">
                          <p class="font-bold text-sm text-on-surface truncate">{p.name}</p>
                          <p class="text-xs text-on-surface-variant">{p.platform || ''}{p.price ? ` · Rp ${p.price}` : ''}</p>
                        </div>
                        <button
                          type="button"
                          onclick={`attachProduct('${p.id}')`}
                          class="text-xs font-bold px-3 py-1.5 bg-primary text-on-primary rounded-lg hover:opacity-90 transition-opacity flex-shrink-0"
                        >Pilih</button>
                      </div>
                    ))}
                  </div>
                )}
              </div>
            </div>
          </div>
        </div>

        <!-- Submit Buttons -->
        <div class="flex flex-col sm:flex-row gap-4 pt-8 border-t border-outline-variant/30">
          <button
            type="submit"
            class="w-full sm:w-auto bg-on-surface text-surface px-6 md:px-8 py-3 md:py-4 rounded-lg font-bold hover:bg-primary transition-all flex items-center justify-center gap-2"
          >
            <span class="material-symbols-outlined">save</span>
            Update Artikel
          </button>
          <a
            href="/dashboard/artikel"
            class="w-full sm:w-auto bg-surface-container text-on-surface px-6 md:px-8 py-3 md:py-4 rounded-lg font-bold hover:bg-surface-container-high transition-all text-center"
          >
            Batal
          </a>
        </div>
      </div>
    </form>
  </div>

  <style>
    .tbtn { display:flex; align-items:center; justify-content:center; width:1.75rem; height:1.75rem; border-radius:0.25rem; color:#4b5563; transition:background 0.15s; font-size:0.875rem; }
    .tbtn:hover { background:#e5e7eb; color:#111827; }
    .tbtn-sep { width:1px; height:1.25rem; background:#d1d5db; margin:0 0.25rem; }
    .tbtn-select { font-size:0.75rem; border:1px solid #d1d5db; border-radius:0.25rem; padding:0 0.375rem; background:white; color:#374151; height:1.75rem; }
    #content-editor { caret-color:#111; }
    #content-editor:empty:before { content:'Tulis konten artikel di sini...'; color:#9ca3af; pointer-events:none; display:block; }
    #content-editor h1 { font-size:2rem; font-weight:800; margin:1.25rem 0 0.5rem; line-height:1.2; }
    #content-editor h2 { font-size:1.5rem; font-weight:700; margin:1rem 0 0.5rem; }
    #content-editor h3 { font-size:1.25rem; font-weight:700; margin:0.75rem 0 0.5rem; }
    #content-editor h4 { font-size:1.1rem; font-weight:600; margin:0.75rem 0 0.5rem; }
    #content-editor p { margin:0.5rem 0; }
    #content-editor ul { list-style:disc; padding-left:1.75rem; margin:0.5rem 0; }
    #content-editor ol { list-style:decimal; padding-left:1.75rem; margin:0.5rem 0; }
    #content-editor li { margin:0.25rem 0; }
    #content-editor blockquote { border-left:4px solid #6366f1; padding:0.5rem 1rem; background:#f5f3ff; border-radius:0 0.5rem 0.5rem 0; margin:0.75rem 0; color:#4b5563; font-style:italic; }
    #content-editor pre { background:#1e1e2e; color:#cdd6f4; padding:1rem; border-radius:0.5rem; font-family:monospace; font-size:0.875rem; overflow-x:auto; margin:0.75rem 0; white-space:pre-wrap; }
    #content-editor a { color:#6366f1; text-decoration:underline; }
    #content-editor img { max-width:100%; border-radius:0.5rem; margin:0.5rem 0; }
    #content-editor table { border-collapse:collapse; width:100%; margin:0.75rem 0; }
    #content-editor table td, #content-editor table th { border:1px solid #e2e8f0; padding:0.5rem 0.75rem; }
    #content-editor table th { background:#f8fafc; font-weight:600; }
    #content-editor hr { border:none; border-top:2px solid #e2e8f0; margin:1.5rem 0; }
  </style>
  <script is:inline define:vars={{ initialContent: article.content || '' }}>
    var ed = document.getElementById('content-editor');
    if (initialContent) ed.innerHTML = initialContent;

    document.getElementById('editor-toolbar').addEventListener('mousedown', function(e) {
      var btn = e.target.closest('[data-cmd]');
      if (!btn) return;
      e.preventDefault();
      document.execCommand(btn.getAttribute('data-cmd'), false, null);
      ed.focus();
    });

    document.getElementById('formatBlock').addEventListener('change', function() {
      document.execCommand('formatBlock', false, this.value);
      ed.focus(); this.value = 'p';
    });

    document.getElementById('textColor').addEventListener('input', function() {
      document.execCommand('foreColor', false, this.value); ed.focus();
    });
    document.getElementById('bgColor').addEventListener('input', function() {
      document.execCommand('hiliteColor', false, this.value); ed.focus();
    });

    document.getElementById('btnLink').addEventListener('click', function() {
      var sel = window.getSelection();
      var url = prompt('URL link:', 'https://');
      if (url) {
        if (sel && sel.toString()) {
          document.execCommand('createLink', false, url);
        } else {
          var text = prompt('Teks link:', url);
          document.execCommand('insertHTML', false, '<a href="' + url + '" target="_blank">' + (text || url) + '</a>');
        }
      }
      ed.focus();
    });

    document.getElementById('btnImage').addEventListener('click', function() {
      var url = prompt('URL gambar:');
      if (url) document.execCommand('insertHTML', false, '<img src="' + url + '" alt="image" style="max-width:100%;border-radius:0.5rem;margin:0.5rem 0;" />');
      ed.focus();
    });

    document.getElementById('btnTable').addEventListener('click', function() {
      var rows = parseInt(prompt('Jumlah baris:', '3')) || 3;
      var cols = parseInt(prompt('Jumlah kolom:', '3')) || 3;
      var html = '<table><thead><tr>';
      for (var c = 0; c < cols; c++) html += '<th>Header ' + (c+1) + '</th>';
      html += '</tr></thead><tbody>';
      for (var r = 0; r < rows; r++) {
        html += '<tr>';
        for (var c = 0; c < cols; c++) html += '<td>Cell</td>';
        html += '</tr>';
      }
      html += '</tbody></table><p></p>';
      document.execCommand('insertHTML', false, html);
      ed.focus();
    });

    document.getElementById('btnQuote').addEventListener('click', function() {
      document.execCommand('formatBlock', false, 'blockquote'); ed.focus();
    });
  </script>
  <script is:inline>
    const ARTICLE_ID = document.querySelector('input[name="id"]').value;

    function switchTab(tab) {
      const isNew = tab === 'new';
      document.getElementById('formNew').classList.toggle('hidden', !isNew);
      document.getElementById('formLibrary').classList.toggle('hidden', isNew);
      document.getElementById('tabNew').className = `text-xs font-bold px-3 py-1.5 rounded-lg transition-all ${isNew ? 'bg-on-surface text-surface' : 'bg-surface-container text-on-surface-variant'}`;
      document.getElementById('tabLibrary').className = `text-xs font-bold px-3 py-1.5 rounded-lg transition-all ${!isNew ? 'bg-on-surface text-surface' : 'bg-surface-container text-on-surface-variant'}`;
    }
    window.switchTab = switchTab;

    async function attachProduct(productId) {
      const fd = new FormData();
      fd.append('product_id', productId);
      fd.append('article_id', ARTICLE_ID);
      const res = await fetch('/api/affiliate/attach', { method: 'POST', body: fd });
      const result = await res.json();
      if (result.success) window.location.reload();
      else alert('Error: ' + result.message);
    }
    window.attachProduct = attachProduct;

    // Toggle affiliate section
    document.getElementById('affiliateToggle').addEventListener('change', function() {
      document.getElementById('affiliateSection').classList.toggle('hidden', !this.checked);
    });

    // Add affiliate product
    document.getElementById('addAffiliateBtn').addEventListener('click', async function() {
      const name = document.getElementById('aff_name').value.trim();
      const url = document.getElementById('aff_url').value.trim();
      if (!name || !url) { alert('Nama dan URL afiliasi wajib diisi'); return; }

      const fd = new FormData();
      fd.append('article_id', ARTICLE_ID);
      fd.append('name', name);
      fd.append('price', document.getElementById('aff_price').value);
      fd.append('affiliate_url', url);
      fd.append('image', document.getElementById('aff_image').value);
      fd.append('platform', document.getElementById('aff_platform').value);
      fd.append('description', document.getElementById('aff_desc').value);
      fd.append('is_active', document.getElementById('aff_active').checked ? '1' : '0');

      const res = await fetch('/api/affiliate/save', { method: 'POST', body: fd });
      const result = await res.json();
      if (result.success) {
        renderAffiliates(result.products);
        ['aff_name','aff_price','aff_url','aff_image','aff_desc'].forEach(id => document.getElementById(id).value = '');
        document.getElementById('aff_platform').value = '';
        document.getElementById('aff_active').checked = true;
      } else {
        alert('Error: ' + result.message);
      }
    });

    async function deleteAffiliate(id) {
      window.showConfirm({
        title: 'Hapus Produk Afiliasi?',
        message: 'Produk ini akan dihapus dari artikel.',
        okText: 'Hapus',
        okIcon: 'delete',
        okClass: 'bg-red-500 hover:bg-red-600',
        iconBg: 'bg-red-100',
        iconColor: 'text-red-500',
        icon: 'delete'
      }, async (confirmed) => {
        if (!confirmed) return;
        const fd = new FormData();
        fd.append('id', id);
        const res = await fetch('/api/affiliate/delete', { method: 'POST', body: fd });
        const result = await res.json();
        if (result.success) {
          document.querySelector(`[data-id="${id}"]`)?.remove();
        }
      });
    }
    window.deleteAffiliate = deleteAffiliate;

    function renderAffiliates(products) {
      const list = document.getElementById('affiliateList');
      list.innerHTML = products.map(p => `
        <div class="flex items-center gap-3 bg-surface-container p-3 rounded-lg" data-id="${p.id}">
          ${p.image ? `<img src="${p.image}" class="w-12 h-12 rounded object-cover" />` : ''}
          <div class="flex-1 min-w-0">
            <p class="font-bold text-sm text-on-surface truncate">${p.name}</p>
            <p class="text-xs text-on-surface-variant">${p.price ? 'Rp ' + p.price + ' · ' : ''}${p.platform || ''}</p>
          </div>
          <span class="text-[10px] font-bold px-2 py-1 rounded-full ${p.is_active ? 'bg-green-100 text-green-700' : 'bg-gray-100 text-gray-500'}">
            ${p.is_active ? 'Aktif' : 'Nonaktif'}
          </span>
          <button type="button" onclick="deleteAffiliate('${p.id}')" class="p-1 hover:text-error transition-colors">
            <span class="material-symbols-outlined text-[18px]">delete</span>
          </button>
        </div>
      `).join('');
    }

    // Auto-generate slug from title
    const titleInput = document.getElementById('title');
    const slugInput = document.getElementById('slug');
    const originalSlug = slugInput.value;

    titleInput?.addEventListener('input', () => {
      if (slugInput.value === originalSlug || slugInput.value === '') {
        const slug = titleInput.value
          .toLowerCase()
          .replace(/[^a-z0-9]+/g, '-')
          .replace(/^-+|-+$/g, '');
        slugInput.value = slug;
      }
    });

    // Handle form submission
    const form = document.getElementById('editArticleForm');
    form?.addEventListener('submit', async (e) => {
      e.preventDefault();
      document.getElementById('content').value = document.getElementById('content-editor').innerHTML;
      const formData = new FormData(form);
      try {
        const response = await fetch('/api/articles/update', { method: 'POST', body: formData });
        const result = await response.json();
        if (result.success) {
          alert('✅ Artikel berhasil diupdate!');
          window.location.href = '/dashboard/artikel';
        } else {
          alert('❌ Error: ' + result.message);
        }
      } catch (error) {
        alert('❌ Terjadi kesalahan: ' + error);
      }
    });
  </script>
</DashboardLayout>
