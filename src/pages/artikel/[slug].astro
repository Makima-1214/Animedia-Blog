---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import { getArticleBySlug, getCategoryBySlug, getAllCategories, incrementArticleViews, getCommentsByArticle, getTagsByArticle, getAffiliatesByArticle, getAdminById, getRelatedArticles } from '../../lib/turso-helpers.js';
import { getSession } from '../../lib/simple-auth';

const { slug } = Astro.params;

if (!slug) {
  return Astro.redirect('/');
}

const article = await getArticleBySlug(slug);

if (!article) {
  return Astro.redirect('/');
}

await incrementArticleViews(article.id);

const categories = await getAllCategories();
const category: any = categories.find((c: any) => c.id === article.category_id);
const comments = await getCommentsByArticle(article.id);
const tags: any[] = await getTagsByArticle(article.id);
const affiliates: any[] = await getAffiliatesByArticle(article.id);

const adminData = await getAdminById((await import('../../lib/turso.js').then(m => m.default.execute("SELECT id FROM admins LIMIT 1")).then(r => r.rows[0]?.id as string || 'admin-1'))) as any;
const authorName = adminData?.name || 'Editor Utama';
const authorAvatar = adminData?.avatar || `https://ui-avatars.com/api/?name=${encodeURIComponent(authorName)}&background=7c3aed&color=fff&size=200&bold=true&rounded=true`;
const author = { name: authorName, image: authorAvatar };

const relatedArticles: any[] = await getRelatedArticles(article.category_id, article.id, 3);

// Cek session user yang login
const sessionToken = Astro.cookies.get('session_token')?.value;
const session = sessionToken ? await getSession(sessionToken) : null;
const loggedInUser = session ? { name: session.name as string, email: session.email as string } : null;
---

<BaseLayout 
  title={article.title} 
  description={article.excerpt}
  image={article.cover_image || ''}
  type="article"
  keywords={tags.map((t: any) => t.name).join(', ') || category?.name || 'artikel'}
  author="Editor Utama"
>
  <Header />

  <!-- Reading Progress Bar -->
  <div id="reading-progress" class="fixed top-0 left-0 z-[60] h-1 bg-violet-600 dark:bg-violet-400 transition-all duration-100 w-0"></div>

  <!-- Back to Top -->
  <button id="back-to-top" class="fixed bottom-6 left-6 z-50 w-10 h-10 bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-full shadow-lg flex items-center justify-center text-gray-600 dark:text-gray-300 hover:bg-violet-600 hover:text-white hover:border-violet-600 transition-all opacity-0 translate-y-4 pointer-events-none" aria-label="Kembali ke atas">
    <span class="material-symbols-outlined text-lg">arrow_upward</span>
  </button>

  <!-- Sticky Share (desktop) -->
  <div id="sticky-share" class="hidden lg:flex fixed left-6 top-1/2 -translate-y-1/2 z-40 flex-col gap-3 opacity-0 -translate-x-4 transition-all duration-300">
    <a href={`https://wa.me/?text=${encodeURIComponent(article.title + ' https://animedia.web.id/artikel/' + article.slug)}`} target="_blank"
      class="w-10 h-10 flex items-center justify-center rounded-full bg-green-500 text-white hover:scale-110 transition-transform shadow-md" title="WhatsApp">
      <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
    </a>
    <a href={`https://twitter.com/intent/tweet?text=${encodeURIComponent(article.title)}&url=${encodeURIComponent('https://animedia.web.id/artikel/' + article.slug)}`} target="_blank"
      class="w-10 h-10 flex items-center justify-center rounded-full bg-black text-white hover:scale-110 transition-transform shadow-md" title="X/Twitter">
      <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.744l7.737-8.835L1.254 2.25H8.08l4.253 5.622zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
    </a>
    <button id="copy-link-sticky" class="w-10 h-10 flex items-center justify-center rounded-full bg-gray-600 text-white hover:scale-110 transition-transform shadow-md" title="Salin link">
      <span class="material-symbols-outlined text-sm">link</span>
    </button>
  </div>

  <!-- Schema JSON-LD -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BlogPosting",
    "headline": article.title,
    "description": article.excerpt,
    "image": article.cover_image,
    "datePublished": article.published_at,
    "dateModified": article.updated_at || article.published_at,
    "author": { "@type": "Person", "name": "Editor Utama" },
    "publisher": { "@type": "Organization", "name": "Animedia" },
    "mainEntityOfPage": { "@type": "WebPage", "@id": `https://animedia.web.id/artikel/${article.slug}` }
  })} />

  <main class="max-w-7xl mx-auto px-3 md:px-6 py-6 md:py-12 bg-white dark:bg-gray-950">
    <!-- Breadcrumbs -->
    <nav class="flex items-center gap-1.5 mb-6 md:mb-8 text-xs font-['Inter'] uppercase tracking-widest text-gray-600 dark:text-gray-400 overflow-hidden">
      <a class="hover:text-violet-600 dark:hover:text-violet-400 transition-colors shrink-0" href="/">Home</a>
      <span class="material-symbols-outlined text-[12px] shrink-0">chevron_right</span>
      <a class="hover:text-violet-600 dark:hover:text-violet-400 transition-colors shrink-0" href={`/kategori/${category.slug}`}>{category.name}</a>
      <span class="material-symbols-outlined text-[12px] shrink-0">chevron_right</span>
      <span class="text-gray-900 dark:text-white font-semibold truncate">{article.title}</span>
    </nav>

    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12">
      <!-- Main Content Area -->
      <article class="lg:col-span-8">
        <header class="mb-10">
          <h1 class="text-2xl md:text-5xl lg:text-6xl font-extrabold tracking-tight text-gray-900 dark:text-white mb-6 leading-[1.1]">
            {article.title}
          </h1>
          
          <div class="flex items-center gap-4 border-l-4 border-violet-600 dark:border-violet-400 pl-4">
            <div class="h-12 w-12 rounded-full overflow-hidden bg-gray-200 dark:bg-gray-800 flex-shrink-0 ring-2 ring-violet-200 dark:ring-violet-800">
              <img class="h-full w-full object-cover" src={author.image || ''} alt={author.name} />
            </div>
            <div class="flex-1">
              <p class="text-gray-900 dark:text-white font-bold text-sm">{author.name}</p>
              <div class="flex flex-wrap items-center gap-x-3 gap-y-1 text-gray-500 dark:text-gray-400 text-xs mt-0.5">
                <span class="flex items-center gap-1">
                  <span class="material-symbols-outlined text-sm">calendar_today</span>
                  {article.published_at ? new Date(String(article.published_at)).toLocaleDateString('id-ID', { day: 'numeric', month: 'long', year: 'numeric' }) : ''}
                </span>
                <span class="flex items-center gap-1">
                  <span class="material-symbols-outlined text-sm">schedule</span>
                  {article.read_time} menit baca
                </span>
                <span class="flex items-center gap-1">
                  <span class="material-symbols-outlined text-sm">visibility</span>
                  {article.views || 0} views
                </span>
              </div>
            </div>
          </div>
        </header>

        {article.cover_image && (
          <div class="rounded-2xl overflow-hidden mb-12 shadow-sm">
            <img
              class="w-full aspect-video object-cover"
              src={article.cover_image}
              alt={article.title}
            />
          </div>
        )}

        <!-- Article Content -->
        <div class="prose prose-lg md:prose-xl prose-slate dark:prose-invert max-w-none prose-headings:text-gray-900 dark:prose-headings:text-white prose-p:text-gray-700 dark:prose-p:text-gray-300 prose-p:leading-[1.9] prose-p:text-[1.05rem] md:prose-p:text-[1.125rem] prose-a:text-violet-600 dark:prose-a:text-violet-400 prose-strong:text-gray-900 dark:prose-strong:text-white prose-blockquote:border-violet-600 dark:prose-blockquote:border-violet-400 prose-code:text-violet-600 dark:prose-code:text-violet-400 prose-li:text-gray-700 dark:prose-li:text-gray-300 prose-li:leading-[1.9] leading-[1.9] px-1 md:text-justify md:hyphens-auto">
          <p class="mb-8 text-lg md:text-xl leading-relaxed text-gray-600 dark:text-gray-400 italic border-l-4 border-violet-400 dark:border-violet-600 pl-4">
            {article.excerpt}
          </p>
          
          <div set:html={article.content} />
        </div>

        <!-- Tags and Share -->
        <div class="mt-10 md:mt-16 pt-6 md:pt-8 border-t border-gray-200 dark:border-gray-800">
          <!-- Tags -->
          <div class="flex flex-wrap gap-2 mb-5">
            <span class="bg-violet-100 dark:bg-violet-900/30 text-violet-900 dark:text-violet-300 px-3 py-1 rounded-lg text-xs font-bold uppercase tracking-wider">
              {category?.name || 'Uncategorized'}
            </span>
            {tags.map((tag: any) => (
              <a
                href={`/tag/${tag.slug}`}
                class="bg-gray-100 dark:bg-gray-800 text-gray-700 dark:text-gray-300 px-3 py-1 rounded-lg text-xs font-medium hover:bg-violet-600 hover:text-white dark:hover:bg-violet-600 transition-colors"
              >
                #{tag.name}
              </a>
            ))}
          </div>
          <!-- Share -->
          <div class="flex items-center gap-2 md:gap-3">
            <span class="text-xs font-bold uppercase tracking-widest text-gray-600 dark:text-gray-400 mr-1">Bagikan:</span>
            <a href={`https://wa.me/?text=${encodeURIComponent(article.title + ' https://animedia.web.id/artikel/' + article.slug)}`} target="_blank"
              class="h-9 w-9 md:h-10 md:w-10 flex items-center justify-center rounded-full bg-green-500 text-white hover:bg-green-600 transition-all" title="WhatsApp">
              <svg class="w-4 h-4 md:w-5 md:h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            </a>
            <a href={`https://twitter.com/intent/tweet?text=${encodeURIComponent(article.title)}&url=${encodeURIComponent('https://animedia.web.id/artikel/' + article.slug)}`} target="_blank"
              class="h-9 w-9 md:h-10 md:w-10 flex items-center justify-center rounded-full bg-black text-white hover:bg-gray-800 transition-all" title="X/Twitter">
              <svg class="w-3.5 h-3.5 md:w-4 md:h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.744l7.737-8.835L1.254 2.25H8.08l4.253 5.622zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
            </a>
            <a href={`https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent('https://animedia.web.id/artikel/' + article.slug)}`} target="_blank"
              class="h-9 w-9 md:h-10 md:w-10 flex items-center justify-center rounded-full bg-blue-600 text-white hover:bg-blue-700 transition-all hidden sm:flex" title="LinkedIn">
              <svg class="w-3.5 h-3.5 md:w-4 md:h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
            </a>
            <button id="copy-link" class="h-9 w-9 md:h-10 md:w-10 flex items-center justify-center rounded-full bg-gray-200 dark:bg-gray-700 text-gray-700 dark:text-gray-300 hover:bg-violet-600 hover:text-white transition-all" title="Salin link">
              <span class="material-symbols-outlined text-sm">link</span>
            </button>
          </div>
        </div>

        <!-- Comments Section -->
        <section class="mt-20">
          <h3 class="text-2xl font-bold text-gray-900 dark:text-white mb-8">Diskusi ({comments.length})</h3>
          
          {/* Display existing comments */}
          {comments.length > 0 && (
            <div class="space-y-6 mb-12" id="comments-list">
              {comments.map((comment: any) => (
                <div class="bg-gray-50 dark:bg-gray-900 p-6 rounded-xl border border-gray-200 dark:border-gray-800" id={`comment-${comment.id}`}>
                  <div class="flex items-start gap-4">
                    <div class="w-10 h-10 rounded-full bg-violet-100 dark:bg-violet-900/30 flex items-center justify-center flex-shrink-0">
                      <span class="material-symbols-outlined text-violet-500 dark:text-violet-400">person</span>
                    </div>
                    <div class="flex-1">
                      <div class="flex items-center gap-2 mb-2">
                        <p class="font-bold text-gray-900 dark:text-white">{comment.author_name}</p>
                        <span class="text-xs text-gray-500 dark:text-gray-400">
                          {new Date(comment.created_at).toLocaleDateString('id-ID', { day: 'numeric', month: 'short', year: 'numeric' })}
                        </span>
                      </div>
                      <p class="text-gray-700 dark:text-gray-300 leading-relaxed">{comment.content}</p>
                      {loggedInUser && (
                        <button
                          class="mt-3 text-xs font-semibold text-violet-600 dark:text-violet-400 hover:underline flex items-center gap-1 reply-btn"
                          data-id={comment.id}
                          data-name={comment.author_name}
                        >
                          <span class="material-symbols-outlined text-sm">reply</span> Balas
                        </button>
                      )}
                      {/* Reply form placeholder */}
                      <div class="reply-form hidden mt-4" data-for={comment.id}></div>
                      {/* Replies */}
                      {comment.replies && comment.replies.length > 0 && (
                        <div class="mt-4 space-y-4 pl-4 border-l-2 border-violet-200 dark:border-violet-800">
                          {comment.replies.map((reply: any) => (
                            <div class="flex items-start gap-3">
                              <div class="w-8 h-8 rounded-full bg-gray-200 dark:bg-gray-800 flex items-center justify-center flex-shrink-0">
                                <span class="material-symbols-outlined text-gray-500 text-sm">person</span>
                              </div>
                              <div class="flex-1">
                                <div class="flex items-center gap-2 mb-1">
                                  <p class="font-bold text-sm text-gray-900 dark:text-white">{reply.author_name}</p>
                                  <span class="text-xs text-gray-500 dark:text-gray-400">
                                    {new Date(reply.created_at).toLocaleDateString('id-ID', { day: 'numeric', month: 'short', year: 'numeric' })}
                                  </span>
                                </div>
                                <p class="text-sm text-gray-700 dark:text-gray-300 leading-relaxed">{reply.content}</p>
                              </div>
                            </div>
                          ))}
                        </div>
                      )}
                      <div class="replies-container" data-parent={comment.id}></div>
                    </div>
                  </div>
                </div>
              ))}
            </div>
          )}
          {comments.length === 0 && (
            <div id="comments-list" class="mb-12"></div>
          )}
          
          <div class="bg-gray-50 dark:bg-gray-900 p-8 rounded-2xl mb-12 shadow-sm border border-gray-200 dark:border-gray-800">
            {loggedInUser ? (
              <>
                <div class="flex items-center gap-3 mb-6 pb-4 border-b border-gray-200 dark:border-gray-700">
                  <div class="w-9 h-9 rounded-full bg-violet-100 dark:bg-violet-900/40 flex items-center justify-center flex-shrink-0">
                    <span class="material-symbols-outlined text-violet-600 dark:text-violet-400 text-lg">person</span>
                  </div>
                  <div>
                    <p class="text-sm font-bold text-gray-900 dark:text-white">{loggedInUser.name}</p>
                    <p class="text-xs text-gray-500 dark:text-gray-400">{loggedInUser.email}</p>
                  </div>
                  <a href="/api/auth/logout" class="ml-auto text-xs text-gray-400 hover:text-gray-600 dark:hover:text-gray-300 transition-colors">Keluar</a>
                </div>
                <form id="commentForm" class="space-y-4">
                  <input type="hidden" name="article_id" value={article.id} />
                  <input type="hidden" name="author_name" value={loggedInUser.name} />
                  <input type="hidden" name="author_email" value={loggedInUser.email} />
                  <textarea
                    name="content"
                    required
                    class="w-full bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-xl p-4 focus:ring-2 focus:ring-violet-600 dark:focus:ring-violet-400 min-h-[120px] text-gray-900 dark:text-white placeholder:text-gray-500 dark:placeholder:text-gray-400 resize-none"
                    placeholder="Bagikan pemikiran Anda tentang artikel ini..."
                  ></textarea>
                  <div id="comment-feedback" class="hidden text-sm px-4 py-3 rounded-xl"></div>
                  <div class="flex justify-end">
                    <button type="submit" class="bg-violet-600 hover:bg-violet-700 text-white px-8 py-3 rounded-xl text-sm font-bold active:scale-95 transition-all flex items-center gap-2">
                      <span class="material-symbols-outlined text-sm">send</span>
                      Kirim Komentar
                    </button>
                  </div>
                </form>
              </>
            ) : (
              <div class="text-center py-4">
                <div class="w-14 h-14 rounded-full bg-violet-100 dark:bg-violet-900/30 flex items-center justify-center mx-auto mb-4">
                  <span class="material-symbols-outlined text-violet-600 dark:text-violet-400 text-2xl">lock</span>
                </div>
                <p class="font-bold text-gray-900 dark:text-white mb-1">Login untuk berkomentar</p>
                <p class="text-sm text-gray-500 dark:text-gray-400 mb-6">Kamu perlu login terlebih dahulu untuk ikut berdiskusi.</p>
                <div class="flex items-center justify-center gap-3">
                  <a href={`/login?redirect=/artikel/${article.slug}`}
                    class="bg-violet-600 hover:bg-violet-700 text-white px-6 py-2.5 rounded-xl text-sm font-bold transition-all">
                    Login
                  </a>
                  <a href={`/register?redirect=/artikel/${article.slug}`}
                    class="bg-gray-100 dark:bg-gray-800 hover:bg-gray-200 dark:hover:bg-gray-700 text-gray-900 dark:text-white px-6 py-2.5 rounded-xl text-sm font-bold transition-all">
                    Daftar
                  </a>
                </div>
              </div>
            )}
          </div>
        </section>
      </article>

      <!-- Mobile: Artikel Terkait + Afiliasi strip (hidden on lg+) -->
      <div class="lg:hidden space-y-4 mt-2">
        {affiliates.length > 0 && (
          <div class="bg-gradient-to-br from-amber-50 to-orange-50 dark:from-gray-900 dark:to-gray-900 border border-amber-200 dark:border-amber-900/40 p-4 rounded-2xl">
            <div class="flex items-center gap-2 mb-3">
              <span class="material-symbols-outlined text-amber-500 text-lg">shopping_bag</span>
              <h4 class="text-xs font-black uppercase tracking-[0.2em] text-amber-700 dark:text-amber-400">Produk Rekomendasi</h4>
            </div>
            <div class="flex gap-3 overflow-x-auto pb-1 no-scrollbar">
              {affiliates.map((product: any) => (
                <a
                  href={product.affiliate_url}
                  target="_blank"
                  rel="noopener noreferrer sponsored"
                  class="flex-shrink-0 w-36 bg-white dark:bg-gray-800 rounded-xl p-3 border border-amber-100 dark:border-gray-700 group"
                >
                  {product.image ? (
                    <img src={product.image} alt={product.name} class="w-full h-20 rounded-lg object-cover mb-2" />
                  ) : (
                    <div class="w-full h-20 rounded-lg bg-amber-100 dark:bg-gray-700 flex items-center justify-center mb-2">
                      <span class="material-symbols-outlined text-amber-400">inventory_2</span>
                    </div>
                  )}
                  <p class="font-bold text-xs text-gray-900 dark:text-white leading-snug line-clamp-2 group-hover:text-amber-600 transition-colors">{product.name}</p>
                  {product.price && <p class="text-amber-600 font-black text-xs mt-1">Rp {product.price}</p>}
                </a>
              ))}
            </div>
          </div>
        )}

        {relatedArticles.length > 0 && (
          <div class="bg-gray-50 dark:bg-gray-900 p-4 rounded-2xl border border-gray-200 dark:border-gray-800">
            <h4 class="text-xs font-black uppercase tracking-[0.2em] text-gray-600 dark:text-gray-400 mb-3 flex items-center gap-2">
              <span class="w-6 h-[2px] bg-violet-600 dark:bg-violet-400"></span> Artikel Terkait
            </h4>
            <div class="flex gap-3 overflow-x-auto pb-1 no-scrollbar">
              {relatedArticles.map((related: any) => (
                <a href={`/artikel/${related.slug}`} class="flex-shrink-0 w-40 group">
                  <div class="h-24 rounded-xl overflow-hidden bg-gray-200 dark:bg-gray-800 mb-2">
                    <img
                      class="h-full w-full object-cover group-hover:scale-105 transition-transform duration-300"
                      src={related.cover_image || 'https://via.placeholder.com/200'}
                      alt={related.title}
                    />
                  </div>
                  <h5 class="text-xs font-bold text-gray-900 dark:text-white leading-snug line-clamp-2 group-hover:text-violet-600 dark:group-hover:text-violet-400 transition-colors">
                    {related.title}
                  </h5>
                  <span class="text-[10px] text-gray-500 dark:text-gray-400">{related.read_time} mnt baca</span>
                </a>
              ))}
            </div>
          </div>
        )}

        <!-- Mobile Newsletter -->
        <div class="bg-gradient-to-r from-violet-600 to-blue-600 rounded-xl p-4 flex items-center gap-4 text-white">
          <span class="material-symbols-outlined text-3xl flex-shrink-0">mail</span>
          <div class="flex-1 min-w-0">
            <p class="text-sm font-bold">Newsletter Gratis</p>
            <p class="text-xs opacity-80">Artikel terbaru langsung ke inbox kamu</p>
          </div>
          <a href="/berlangganan" class="flex-shrink-0 bg-white text-violet-600 font-bold text-xs px-3 py-2 rounded-lg hover:bg-gray-100 transition-colors whitespace-nowrap">
            Daftar
          </a>
        </div>
      </div>

      <!-- Sidebar -->
      <aside class="hidden lg:block lg:col-span-4 space-y-12">
        <!-- Affiliate Products -->
        {affiliates.length > 0 && (
          <div class="bg-gradient-to-br from-amber-50 to-orange-50 dark:from-gray-900 dark:to-gray-900 border border-amber-200 dark:border-amber-900/40 p-6 rounded-2xl">
            <div class="flex items-center gap-2 mb-4">
              <span class="material-symbols-outlined text-amber-500">shopping_bag</span>
              <h4 class="text-xs font-black uppercase tracking-[0.2em] text-amber-700 dark:text-amber-400">Produk Rekomendasi</h4>
            </div>
            <div class="space-y-3">
              {affiliates.map((product: any) => (
                <a
                  href={product.affiliate_url}
                  target="_blank"
                  rel="noopener noreferrer sponsored"
                  class="flex gap-3 bg-white dark:bg-gray-800 rounded-xl p-3 hover:shadow-md transition-all group border border-amber-100 dark:border-gray-700"
                >
                  {product.image ? (
                    <img src={product.image} alt={product.name} class="w-14 h-14 rounded-lg object-cover flex-shrink-0" />
                  ) : (
                    <div class="w-14 h-14 rounded-lg bg-amber-100 dark:bg-gray-700 flex items-center justify-center flex-shrink-0">
                      <span class="material-symbols-outlined text-amber-400">inventory_2</span>
                    </div>
                  )}
                  <div class="flex-1 min-w-0">
                    <p class="font-bold text-sm text-gray-900 dark:text-white leading-snug group-hover:text-amber-600 dark:group-hover:text-amber-400 transition-colors line-clamp-2">{product.name}</p>
                    {product.price && (
                      <p class="text-amber-600 dark:text-amber-400 font-black text-sm mt-1">Rp {product.price}</p>
                    )}
                    {product.platform && (
                      <span class="text-[10px] text-gray-500 dark:text-gray-400 font-medium">{product.platform}</span>
                    )}
                  </div>
                  <span class="material-symbols-outlined text-amber-400 group-hover:translate-x-1 transition-transform self-center flex-shrink-0">arrow_forward</span>
                </a>
              ))}
            </div>
            <p class="text-xs text-amber-600/70 dark:text-amber-500/50 mt-3 text-center">❤️ Support Animedia dengan belanja lewat link di bawah ini!</p>
          </div>
        )}

        <!-- Related Articles -->
        <div class="bg-gray-50 dark:bg-gray-900 p-6 rounded-2xl border border-gray-200 dark:border-gray-800">
          <h4 class="text-xs font-black uppercase tracking-[0.2em] text-gray-600 dark:text-gray-400 mb-6 flex items-center gap-2">
            <span class="w-8 h-[2px] bg-violet-600 dark:bg-violet-400"></span> Artikel Terkait
          </h4>
          <div class="space-y-6">
            {relatedArticles.map((related: any) => (
              <a class="group flex gap-4" href={`/artikel/${related.slug}`}>
                <div class="h-20 w-20 rounded-xl overflow-hidden shrink-0 bg-gray-200 dark:bg-gray-800">
                  <img
                    class="h-full w-full object-cover group-hover:scale-110 transition-transform duration-500"
                    src={related.cover_image || 'https://via.placeholder.com/200'}
                    alt={related.title}
                  />
                </div>
                <div>
                  <h5 class="text-sm font-bold text-gray-900 dark:text-white leading-snug group-hover:text-violet-600 dark:group-hover:text-violet-400 transition-colors">
                    {related.title}
                  </h5>
                  <span class="text-[10px] text-gray-600 dark:text-gray-400 font-medium">{related.read_time} MIN BACA</span>
                </div>
              </a>
            ))}
          </div>
        </div>

        <!-- Newsletter Widget -->
        <div class="bg-violet-600 dark:bg-violet-700 p-8 rounded-2xl text-white">
          <span class="material-symbols-outlined text-4xl mb-4">mail</span>
          <h4 class="text-xl font-bold mb-2">Jangan Ketinggalan</h4>
          <p class="text-sm opacity-90 mb-6">
            Dapatkan kurasi artikel terbaik setiap minggu langsung di inbox Anda.
          </p>
          <a href="/berlangganan" class="block w-full bg-white text-violet-600 font-bold py-3 rounded-xl text-sm hover:bg-gray-100 transition-colors text-center">
            Berlangganan Gratis
          </a>
        </div>
      </aside>
    </div>
  </main>
</BaseLayout>


<script>
  // ── Reading Progress Bar ──────────────────────────────────
  const progressBar = document.getElementById('reading-progress') as HTMLElement;
  const article = document.querySelector('article') as HTMLElement;

  function updateProgress() {
    if (!article || !progressBar) return;
    const articleTop = article.offsetTop;
    const articleHeight = article.offsetHeight;
    const scrolled = window.scrollY - articleTop;
    const pct = Math.min(100, Math.max(0, (scrolled / (articleHeight - window.innerHeight)) * 100));
    progressBar.style.width = pct + '%';
  }

  // ── Back to Top ───────────────────────────────────────────
  const backToTop = document.getElementById('back-to-top') as HTMLButtonElement;
  const stickyShare = document.getElementById('sticky-share') as HTMLElement;

  function onScroll() {
    updateProgress();
    const show = window.scrollY > 400;
    if (backToTop) {
      backToTop.style.opacity = show ? '1' : '0';
      backToTop.style.transform = show ? 'translateY(0)' : 'translateY(1rem)';
      backToTop.style.pointerEvents = show ? 'auto' : 'none';
    }
    if (stickyShare) {
      stickyShare.style.opacity = show ? '1' : '0';
      stickyShare.style.transform = show ? 'translateY(-50%) translateX(0)' : 'translateY(-50%) translateX(-1rem)';
    }
  }

  window.addEventListener('scroll', onScroll, { passive: true });
  backToTop?.addEventListener('click', () => window.scrollTo({ top: 0, behavior: 'smooth' }));

  // ── Copy Link ─────────────────────────────────────────────
  function copyLink(btn: HTMLElement | null) {
    if (!btn) return;
    navigator.clipboard.writeText(window.location.href).then(() => {
      const icon = btn.querySelector('.material-symbols-outlined');
      if (icon) { icon.textContent = 'check'; setTimeout(() => { icon.textContent = 'link'; }, 2000); }
    });
  }
  document.getElementById('copy-link')?.addEventListener('click', () => copyLink(document.getElementById('copy-link')));
  document.getElementById('copy-link-sticky')?.addEventListener('click', () => copyLink(document.getElementById('copy-link-sticky')));

  // ── Comment Form ──────────────────────────────────────────
  const commentForm = document.getElementById('commentForm') as HTMLFormElement;
  const feedback = document.getElementById('comment-feedback') as HTMLDivElement;
  const submitBtn = commentForm?.querySelector('button[type="submit"]') as HTMLButtonElement;

  function showFeedback(message: string, type: 'success' | 'error') {
    feedback.className = type === 'success'
      ? 'text-sm px-4 py-3 rounded-xl bg-green-50 text-green-700 border border-green-200 flex items-center gap-2'
      : 'text-sm px-4 py-3 rounded-xl bg-red-50 text-red-700 border border-red-200 flex items-center gap-2';
    feedback.innerHTML = `<span class="material-symbols-outlined text-base">${type === 'success' ? 'check_circle' : 'error'}</span>${message}`;
    feedback.classList.remove('hidden');
  }

  function buildCommentHTML(name: string, content: string, isReply = false) {
    const size = isReply ? 'w-8 h-8' : 'w-10 h-10';
    const iconSize = isReply ? 'text-sm' : '';
    return `
      <div class="flex items-start gap-${isReply ? '3' : '4'}">
        <div class="${size} rounded-full ${isReply ? 'bg-gray-200 dark:bg-gray-800' : 'bg-violet-100 dark:bg-violet-900/30'} flex items-center justify-center flex-shrink-0">
          <span class="material-symbols-outlined ${isReply ? 'text-gray-500' : 'text-violet-500 dark:text-violet-400'} ${iconSize}">person</span>
        </div>
        <div class="flex-1">
          <div class="flex items-center gap-2 mb-${isReply ? '1' : '2'}">
            <p class="font-bold ${isReply ? 'text-sm' : ''} text-gray-900 dark:text-white">${name}</p>
            <span class="text-xs text-gray-500 dark:text-gray-400">Baru saja</span>
          </div>
          <p class="${isReply ? 'text-sm' : ''} text-gray-700 dark:text-gray-300 leading-relaxed">${content}</p>
        </div>
      </div>`;
  }

  // Reply buttons
  document.querySelectorAll('.reply-btn').forEach(btn => {
    btn.addEventListener('click', function(this: HTMLElement) {
      const parentId = this.dataset.id!;
      const parentName = this.dataset.name!;
      document.querySelectorAll('.reply-form').forEach(f => f.classList.add('hidden'));
      const replyForm = document.querySelector(`.reply-form[data-for="${parentId}"]`) as HTMLElement;
      if (!replyForm) return;
      replyForm.classList.remove('hidden');
      replyForm.innerHTML = `
        <form class="space-y-3" data-parent="${parentId}">
          <textarea class="w-full bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-xl p-3 text-sm focus:ring-2 focus:ring-violet-500 min-h-[80px] resize-none text-gray-900 dark:text-white placeholder:text-gray-400" placeholder="Balas ke ${parentName}..." required></textarea>
          <div class="flex gap-2">
            <button type="submit" class="bg-violet-600 hover:bg-violet-700 text-white px-4 py-2 rounded-lg text-xs font-bold flex items-center gap-1 transition-all">
              <span class="material-symbols-outlined text-sm">send</span> Kirim Balasan
            </button>
            <button type="button" class="cancel-reply bg-gray-100 dark:bg-gray-800 text-gray-700 dark:text-gray-300 px-4 py-2 rounded-lg text-xs font-bold hover:bg-gray-200 dark:hover:bg-gray-700 transition-all">Batal</button>
          </div>
        </form>`;

      replyForm.querySelector('.cancel-reply')!.addEventListener('click', () => replyForm.classList.add('hidden'));
      replyForm.querySelector('form')!.addEventListener('submit', async (e) => {
        e.preventDefault();
        const textarea = replyForm.querySelector('textarea') as HTMLTextAreaElement;
        const content = textarea.value.trim();
        if (!content) return;
        const articleIdInput = commentForm.querySelector('[name="article_id"]') as HTMLInputElement;
        const fd = new FormData();
        fd.append('content', content);
        fd.append('article_id', articleIdInput.value);
        fd.append('parent_id', parentId);
        const submitReplyBtn = replyForm.querySelector('button[type="submit"]') as HTMLButtonElement;
        submitReplyBtn.disabled = true;
        submitReplyBtn.textContent = 'Mengirim...';
        try {
          const res = await fetch('/api/comments/create', { method: 'POST', body: fd });
          const result = await res.json();
          if (result.success) {
            let repliesContainer = document.querySelector(`.replies-container[data-parent="${parentId}"]`) as HTMLElement;
            if (!repliesContainer.previousElementSibling?.classList.contains('border-l-2')) {
              const wrapper = document.createElement('div');
              wrapper.className = 'mt-4 space-y-4 pl-4 border-l-2 border-violet-200 dark:border-violet-800';
              repliesContainer.parentNode!.insertBefore(wrapper, repliesContainer);
              repliesContainer = wrapper;
            } else {
              repliesContainer = repliesContainer.previousElementSibling as HTMLElement;
            }
            const div = document.createElement('div');
            div.innerHTML = buildCommentHTML(result.author_name, content, true);
            repliesContainer.appendChild(div);
            replyForm.classList.add('hidden');
          } else {
            submitReplyBtn.disabled = false;
            submitReplyBtn.innerHTML = '<span class="material-symbols-outlined text-sm">send</span> Kirim Balasan';
          }
        } catch { submitReplyBtn.disabled = false; }
      });
    });
  });

  commentForm?.addEventListener('submit', async (e) => {
    e.preventDefault();
    submitBtn.disabled = true;
    submitBtn.innerHTML = '<span class="material-symbols-outlined text-sm animate-spin">progress_activity</span> Mengirim...';
    const formData = new FormData(commentForm);
    try {
      const response = await fetch('/api/comments/create', { method: 'POST', body: formData });
      const result = await response.json();
      if (result.success) {
        showFeedback('Komentar berhasil dikirim!', 'success');
        const textarea = commentForm.querySelector('textarea')!;
        const commentsList = document.getElementById('comments-list') as HTMLElement;
        const newComment = document.createElement('div');
        newComment.className = 'bg-gray-50 dark:bg-gray-900 p-6 rounded-xl border border-gray-200 dark:border-gray-800';
        newComment.innerHTML = buildCommentHTML(result.author_name, textarea.value);
        commentsList.appendChild(newComment);
        const countEl = document.querySelector('h3');
        if (countEl) {
          const match = countEl.textContent?.match(/\d+/);
          countEl.textContent = `Diskusi (${match ? parseInt(match[0]) + 1 : 1})`;
        }
        textarea.value = '';
        submitBtn.innerHTML = '<span class="material-symbols-outlined text-sm">check</span> Terkirim';
      } else {
        showFeedback('Gagal: ' + result.message, 'error');
        submitBtn.disabled = false;
        submitBtn.innerHTML = '<span class="material-symbols-outlined text-sm">send</span> Kirim Komentar';
      }
    } catch {
      showFeedback('Terjadi kesalahan koneksi.', 'error');
      submitBtn.disabled = false;
      submitBtn.innerHTML = '<span class="material-symbols-outlined text-sm">send</span> Kirim Komentar';
    }
  });
</script>
