---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
---

<BaseLayout title="Langganan">
  <Header />
  <main class="pt-8 bg-white dark:bg-gray-950">
    <!-- Hero Section -->
    <section class="px-8 py-20 md:py-32 flex flex-col items-center text-center max-w-4xl mx-auto">
      <span class="text-xs uppercase tracking-[0.2em] text-gray-600 dark:text-gray-400 font-semibold mb-6">Subscription Plans</span>
      <h1 class="text-5xl md:text-7xl font-extrabold tracking-tighter leading-tight mb-8 text-gray-900 dark:text-white">Dukung Jurnalisme Berkualitas</h1>
      <p class="text-lg md:text-xl text-gray-600 dark:text-gray-400 max-w-2xl leading-relaxed">
        Dapatkan akses eksklusif ke laporan mendalam, analisis tajam, dan konten premium yang dikurasi khusus untuk pembaca cerdas. Pilih paket yang sesuai dengan kebutuhan Anda.
      </p>
    </section>

    <!-- Pricing Tiers -->
    <section class="px-8 pb-32">
      <div class="max-w-7xl mx-auto grid grid-cols-1 md:grid-cols-3 gap-0">
        <!-- Free Tier -->
        <div class="p-10 bg-surface border-r-0 md:border-r border-outline-variant/20 flex flex-col justify-between">
          <div>
            <h3 class="text-2xl font-bold mb-2">Gratis</h3>
            <p class="text-on-surface-variant text-sm mb-8 leading-relaxed">Mulailah perjalanan membaca Anda tanpa biaya sepeser pun.</p>
            <div class="flex items-baseline mb-10">
              <span class="text-4xl font-extrabold tracking-tighter">Rp 0</span>
              <span class="ml-2 text-outline">/bulan</span>
            </div>
            <ul class="space-y-4 mb-12">
              <li class="flex items-start gap-3">
                <span class="material-symbols-outlined text-primary text-xl">check</span>
                <span class="text-sm">Akses 3 artikel premium/bulan</span>
              </li>
              <li class="flex items-start gap-3">
                <span class="material-symbols-outlined text-primary text-xl">check</span>
                <span class="text-sm">Buletin mingguan via email</span>
              </li>
              <li class="flex items-start gap-3">
                <span class="material-symbols-outlined text-primary text-xl">check</span>
                <span class="text-sm">Komentar terbatas</span>
              </li>
            </ul>
          </div>
          <button type="button" onclick="window.location.href='/register'" class="w-full py-4 border border-outline text-sm font-bold tracking-tight hover:bg-surface-container transition-colors">
            Daftar Sekarang
          </button>
        </div>

        <!-- Premium Tier (Highlighted) -->
        <div class="p-10 bg-surface-container-lowest shadow-[0_40px_100px_rgba(0,0,0,0.04)] relative z-10 flex flex-col justify-between transform md:scale-105">
          <div class="absolute top-0 left-0 w-full h-1 bg-on-surface"></div>
          <div>
            <div class="flex justify-between items-start mb-2">
              <h3 class="text-2xl font-bold">Premium</h3>
              <span class="bg-primary-container text-on-primary-container text-[10px] font-bold px-2 py-1 rounded uppercase tracking-wider">Populer</span>
            </div>
            <p class="text-on-surface-variant text-sm mb-8 leading-relaxed">Pengalaman penuh bagi penikmat konten berkualitas tinggi.</p>
            <div class="flex items-baseline mb-10">
              <span class="text-4xl font-extrabold tracking-tighter">Rp 50.000</span>
              <span class="ml-2 text-outline">/bulan</span>
            </div>
            <ul class="space-y-4 mb-12">
              <li class="flex items-start gap-3">
                <span class="material-symbols-outlined text-on-surface text-xl" style="font-variation-settings: 'FILL' 1;">check</span>
                <span class="text-sm font-medium">Akses tanpa batas ke semua artikel</span>
              </li>
              <li class="flex items-start gap-3">
                <span class="material-symbols-outlined text-on-surface text-xl" style="font-variation-settings: 'FILL' 1;">check</span>
                <span class="text-sm font-medium">Konten eksklusif anggota</span>
              </li>
              <li class="flex items-start gap-3">
                <span class="material-symbols-outlined text-on-surface text-xl" style="font-variation-settings: 'FILL' 1;">check</span>
                <span class="text-sm font-medium">Bebas iklan (Ad-Free)</span>
              </li>
              <li class="flex items-start gap-3">
                <span class="material-symbols-outlined text-on-surface text-xl" style="font-variation-settings: 'FILL' 1;">check</span>
                <span class="text-sm font-medium">Akses komunitas eksklusif</span>
              </li>
            </ul>
          </div>
          <a href="https://wa.me/6285891015129?text=Halo%2C%20saya%20ingin%20berlangganan%20Animedia%20Premium" target="_blank" rel="noopener noreferrer" class="block w-full py-4 bg-on-surface text-surface text-sm font-bold tracking-tight hover:opacity-90 transition-all text-center">
            Mulai Langganan
          </a>
        </div>

        <!-- Institutional Tier -->
        <div class="p-10 bg-surface border-l-0 md:border-l border-outline-variant/20 flex flex-col justify-between">
          <div>
            <h3 class="text-2xl font-bold mb-2">Institusi</h3>
            <p class="text-on-surface-variant text-sm mb-8 leading-relaxed">Solusi lengkap untuk tim, perusahaan, dan organisasi pendidikan.</p>
            <div class="flex items-baseline mb-10">
              <span class="text-4xl font-extrabold tracking-tighter">Hubungi Kami</span>
            </div>
            <ul class="space-y-4 mb-12">
              <li class="flex items-start gap-3">
                <span class="material-symbols-outlined text-primary text-xl">check</span>
                <span class="text-sm">Lisensi multi-user kustom</span>
              </li>
              <li class="flex items-start gap-3">
                <span class="material-symbols-outlined text-primary text-xl">check</span>
                <span class="text-sm">Dukungan prioritas 24/7</span>
              </li>
              <li class="flex items-start gap-3">
                <span class="material-symbols-outlined text-primary text-xl">check</span>
                <span class="text-sm">Akses arsip sejarah lengkap</span>
              </li>
              <li class="flex items-start gap-3">
                <span class="material-symbols-outlined text-primary text-xl">check</span>
                <span class="text-sm">Tagihan korporat (Invoicing)</span>
              </li>
            </ul>
          </div>
          <a href="mailto:admin@animedia.com?subject=Pertanyaan%20Langganan%20Institusi" class="block w-full py-4 border border-outline text-sm font-bold tracking-tight hover:bg-surface-container transition-colors text-center">
            Hubungi Tim Sales
          </a>
        </div>
      </div>
    </section>

    <!-- Asymmetric Detail Section -->
    <section class="bg-surface-container-low py-32 overflow-hidden">
      <div class="max-w-7xl mx-auto px-8 grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        <div class="relative">
          <img
            alt="Reading Experience"
            class="w-full h-[600px] object-cover rounded-sm grayscale"
            src="https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?w=800&h=600&fit=crop"
          />
          <div class="absolute -bottom-8 -right-8 bg-on-surface text-surface p-12 hidden md:block">
            <p class="font-headline text-3xl font-bold leading-tight tracking-tighter italic">
              "Esensi dari literasi adalah pemahaman, bukan sekadar kecepatan."
            </p>
          </div>
        </div>
        <div class="space-y-8">
          <h2 class="text-4xl font-bold tracking-tighter leading-tight">Pengalaman Membaca yang Tak Tertandingi</h2>
          <p class="text-on-surface-variant leading-relaxed">
            Kami percaya bahwa desain adalah bagian dari narasi. Dengan berlangganan, Anda tidak hanya mendapatkan teks, tetapi sebuah pengalaman kurasi visual dan intelektual yang jernih, bebas dari gangguan pop-up atau clickbait yang merusak fokus Anda.
          </p>
          <div class="grid grid-cols-2 gap-8 pt-4">
            <div>
              <span class="text-3xl font-extrabold block mb-1">500+</span>
              <span class="text-xs uppercase tracking-widest text-outline">Arsip Eksklusif</span>
            </div>
            <div>
              <span class="text-3xl font-extrabold block mb-1">24/7</span>
              <span class="text-xs uppercase tracking-widest text-outline">Akses Digital</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- FAQ Section -->
    <section class="px-8 py-32 max-w-4xl mx-auto">
      <h2 class="text-3xl font-bold mb-16 tracking-tighter text-center">Pertanyaan Umum</h2>
      <div class="space-y-12">
        <div class="group">
          <h3 class="text-lg font-bold mb-3 flex items-center justify-between">
            Dapatkah saya membatalkan langganan kapan saja?
          </h3>
          <p class="text-on-surface-variant text-sm leading-relaxed max-w-2xl">
            Ya, Anda memiliki kendali penuh. Anda dapat membatalkan langganan kapan saja melalui menu pengaturan akun tanpa biaya tambahan atau proses yang rumit.
          </p>
        </div>
        <div class="group">
          <h3 class="text-lg font-bold mb-3 flex items-center justify-between">
            Metode pembayaran apa yang tersedia?
          </h3>
          <p class="text-on-surface-variant text-sm leading-relaxed max-w-2xl">
            Kami menerima kartu kredit/debit (Visa, Mastercard), transfer bank via virtual account, serta dompet digital utama seperti GoPay dan OVO.
          </p>
        </div>
        <div class="group">
          <h3 class="text-lg font-bold mb-3 flex items-center justify-between">
            Apakah langganan Premium berlaku untuk semua perangkat?
          </h3>
          <p class="text-on-surface-variant text-sm leading-relaxed max-w-2xl">
            Tentu. Anda dapat mengakses akun Premium Anda melalui browser web di komputer, tablet, maupun aplikasi mobile kami secara bersamaan.
          </p>
        </div>
      </div>
    </section>

    <!-- Newsletter Subscription Form -->
    <section class="px-8 py-20 bg-gray-50 dark:bg-gray-900">
      <div class="max-w-2xl mx-auto text-center">
        <span class="material-symbols-outlined text-5xl text-violet-600 dark:text-violet-400 mb-4">mail</span>
        <h2 class="text-3xl md:text-4xl font-bold mb-4 text-gray-900 dark:text-white">Berlangganan Newsletter Gratis</h2>
        <p class="text-gray-600 dark:text-gray-400 mb-8">
          Dapatkan kurasi artikel terbaik, berita terkini, dan konten eksklusif langsung di inbox Anda setiap minggu.
        </p>
        
        <form id="newsletterForm" class="flex flex-col sm:flex-row gap-4 max-w-md mx-auto">
          <input
            type="email"
            name="email"
            required
            placeholder="alamat@email.com"
            class="flex-1 px-6 py-4 rounded-xl border border-gray-300 dark:border-gray-700 bg-white dark:bg-gray-800 text-gray-900 dark:text-white focus:border-violet-600 dark:focus:border-violet-400 focus:ring-2 focus:ring-violet-600/20 dark:focus:ring-violet-400/20 transition-all placeholder:text-gray-500 dark:placeholder:text-gray-400"
          />
          <button
            type="submit"
            class="bg-violet-600 hover:bg-violet-700 text-white px-8 py-4 rounded-xl font-bold transition-all whitespace-nowrap"
          >
            Berlangganan
          </button>
        </form>
        
        <p class="text-xs text-gray-600 dark:text-gray-400 mt-4">
          Kami menghormati privasi Anda. Berhenti berlangganan kapan saja.
        </p>
      </div>
    </section>
  </main>

  <!-- Footer -->
  <footer class="bg-stone-100 dark:bg-stone-900 w-full py-16 px-8 mt-auto">
    <div class="flex flex-col md:flex-row justify-between items-center gap-8 w-full max-w-7xl mx-auto">
      <div class="text-lg font-bold text-stone-900 dark:text-stone-50">Animedia</div>
      <div class="flex flex-wrap justify-center gap-8 text-sm tracking-wide leading-relaxed">
        <a class="text-stone-500 dark:text-stone-400 hover:text-stone-900 dark:hover:text-stone-50 transition-opacity opacity-80 hover:opacity-100" href="/">Beranda</a>
        <a class="text-stone-500 dark:text-stone-400 hover:text-stone-900 dark:hover:text-stone-50 transition-opacity opacity-80 hover:opacity-100" href="/artikel">Artikel</a>
        <a class="text-stone-500 dark:text-stone-400 hover:text-stone-900 dark:hover:text-stone-50 transition-opacity opacity-80 hover:opacity-100" href="/berlangganan">Newsletter</a>
        <a class="text-stone-500 dark:text-stone-400 hover:text-stone-900 dark:hover:text-stone-50 transition-opacity opacity-80 hover:opacity-100" href="/toko">Toko</a>
      </div>
      <div class="text-stone-700 dark:text-stone-300 text-sm tracking-wide leading-relaxed">
        © {new Date().getFullYear()} Animedia. All rights reserved.
      </div>
    </div>
  </footer>

  <script is:inline>
    // Newsletter form submission
    const newsletterForm = document.getElementById('newsletterForm');
    newsletterForm?.addEventListener('submit', async (e) => {
      e.preventDefault();
      
      const formData = new FormData(newsletterForm);
      const submitBtn = newsletterForm.querySelector('button[type="submit"]');
      const originalText = submitBtn.textContent;
      
      submitBtn.textContent = 'Mengirim...';
      submitBtn.disabled = true;
      
      try {
        const response = await fetch('/api/subscribe', {
          method: 'POST',
          body: formData
        });
        
        const result = await response.json();
        
        if (result.success) {
          alert('✅ ' + result.message);
          newsletterForm.reset();
        } else {
          alert('❌ ' + result.message);
        }
      } catch (error) {
        alert('❌ Terjadi kesalahan: ' + error.message);
      } finally {
        submitBtn.textContent = originalText;
        submitBtn.disabled = false;
      }
    });
  </script>
</BaseLayout>
