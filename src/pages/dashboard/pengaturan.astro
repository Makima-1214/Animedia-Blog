---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
import { getAllSettings } from '../../lib/settings.js';
import { getAdminById } from '../../lib/turso-helpers.js';

const settings = await getAllSettings();
const adminToken = Astro.cookies.get('admin_session')?.value;
import db from '../../lib/turso.js';
const adminSessionRow = adminToken ? await db.execute({
  sql: `SELECT a.* FROM admin_sessions s JOIN admins a ON s.admin_id = a.id WHERE s.token = ? AND s.expires_at > ?`,
  args: [adminToken, new Date().toISOString()]
}) : null;
const admin = adminSessionRow?.rows[0] as any || null;
const adminAvatar = admin?.avatar || `https://ui-avatars.com/api/?name=${encodeURIComponent(admin?.name || 'Admin')}&background=7c3aed&color=fff&size=200&bold=true&rounded=true`;
---

<DashboardLayout title="Pengaturan - Admin Panel" activePage="pengaturan">
  <div class="p-4 md:p-8 lg:p-12">
    <!-- Page Header -->
    <header class="mb-12 md:mb-16">
      <h2 class="font-headline text-3xl md:text-5xl font-extrabold text-on-surface tracking-tighter mb-4">Konfigurasi</h2>
      <p class="font-body text-on-surface-variant text-base md:text-lg max-w-2xl leading-relaxed">Sesuaikan pengaturan inti platform Anda. Parameter ini menentukan pengalaman membaca dan ritme konten Anda.</p>
    </header>

    <form id="settingsForm" class="space-y-16 md:space-y-24">
      <!-- ── Identitas Situs ─────────────────────────────── -->
      <section class="grid grid-cols-1 md:grid-cols-12 gap-8 md:gap-12 items-start">
        <div class="md:col-span-4">
          <h3 class="font-headline text-xl font-bold text-on-surface mb-2">Identitas Situs</h3>
          <p class="text-sm text-on-surface-variant leading-snug">Nama dan logo yang tampil di header, footer, dan halaman login.</p>
        </div>
        <div class="md:col-span-8 bg-surface-container-lowest p-6 md:p-8 rounded-xl space-y-6">
          <!-- Nama Situs -->
          <div class="space-y-2">
            <label class="font-label text-[11px] uppercase tracking-widest font-bold text-on-surface-variant">Nama Situs</label>
            <input
              name="site_name"
              type="text"
              value={settings.site_name || 'Animedia'}
              class="w-full border-b border-outline-variant bg-transparent py-2 focus:border-primary focus:ring-0 transition-colors text-sm font-mono"
              placeholder="Nama situs Anda"
            />
            <p class="text-[10px] text-on-surface-variant/70">Tampil di header, footer, tab browser, dan halaman login.</p>
          </div>
          <!-- Tagline -->
          <div class="space-y-2">
            <label class="font-label text-[11px] uppercase tracking-widest font-bold text-on-surface-variant">Tagline</label>
            <input
              name="site_tagline"
              type="text"
              value={settings.site_tagline || 'Portal Berita Teknologi & Pop Culture'}
              class="w-full border-b border-outline-variant bg-transparent py-2 focus:border-primary focus:ring-0 transition-colors text-sm font-mono"
              placeholder="Deskripsi singkat situs"
            />
            <p class="text-[10px] text-on-surface-variant/70">Tampil di halaman login dan meta description.</p>
          </div>
          <!-- Logo URL -->
          <div class="space-y-2">
            <label class="font-label text-[11px] uppercase tracking-widest font-bold text-on-surface-variant">URL Logo</label>
            <div class="flex items-center gap-3">
              <div id="logoPreviewWrap" class={`w-12 h-12 rounded-lg border border-outline-variant flex items-center justify-center overflow-hidden flex-shrink-0 ${settings.site_logo_url ? '' : 'bg-surface-container'}`}>
                {settings.site_logo_url ? (
                  <img id="logoPreview" src={settings.site_logo_url} alt="Logo" class="w-full h-full object-contain" />
                ) : (
                  <span id="logoPreview" class="material-symbols-outlined text-outline-variant">image</span>
                )}
              </div>
              <input
                id="siteLogoUrl"
                name="site_logo_url"
                type="url"
                value={settings.site_logo_url || ''}
                class="flex-1 border-b border-outline-variant bg-transparent py-2 focus:border-primary focus:ring-0 transition-colors font-mono text-sm"
                placeholder="https://example.com/logo.png"
              />
            </div>
            <p class="text-[10px] text-on-surface-variant/70">Kosongkan untuk pakai ikon + nama teks. Rekomendasi: PNG transparan, tinggi 40–60px.</p>
          </div>
          <!-- Upload Logo -->
          <div class="space-y-2">
            <label class="font-label text-[11px] uppercase tracking-widest font-bold text-on-surface-variant">Atau Upload Logo</label>
            <label class="cursor-pointer inline-flex items-center gap-2 bg-surface-container-high px-4 py-2 rounded-lg text-sm font-bold hover:bg-surface-container-highest transition-colors">
              <span class="material-symbols-outlined text-sm">upload</span>
              Pilih File Logo
              <input type="file" id="logoFile" accept="image/*" class="hidden" />
            </label>
            <p id="logoUploadStatus" class="text-xs text-on-surface-variant"></p>
          </div>
        </div>
      </section>

      <!-- Admin Profile Section -->
      <section class="grid grid-cols-1 md:grid-cols-12 gap-12 items-start">
        <div class="md:col-span-4">
          <h3 class="font-headline text-xl font-bold text-on-surface mb-2">Profil Admin</h3>
          <p class="text-sm text-on-surface-variant leading-snug">Foto dan nama yang tampil di halaman artikel.</p>
        </div>
        <div class="md:col-span-8 bg-surface-container-lowest p-8 rounded-xl space-y-6">
          <!-- Avatar Preview -->
          <div class="flex items-center gap-6">
            <div class="relative">
              <img id="avatarPreview" src={adminAvatar} alt="Avatar" class="w-20 h-20 rounded-full object-cover border-4 border-primary/20" />
            </div>
            <div class="flex-1 space-y-2">
              <label class="font-label text-[11px] uppercase tracking-widest font-bold text-on-surface-variant">Nama Tampil</label>
              <input
                id="adminName"
                type="text"
                value={admin?.name || 'Editor Utama'}
                class="w-full border-b border-outline-variant bg-transparent py-2 focus:border-primary focus:ring-0 transition-colors text-sm"
                placeholder="Nama yang tampil di artikel"
              />
            </div>
          </div>
          <!-- Avatar URL -->
          <div class="space-y-2">
            <label class="font-label text-[11px] uppercase tracking-widest font-bold text-on-surface-variant">URL Foto Profil</label>
            <input
              id="adminAvatar"
              type="url"
              value={admin?.avatar || ''}
              class="w-full border-b border-outline-variant bg-transparent py-2 focus:border-primary focus:ring-0 transition-colors font-mono text-sm"
              placeholder="https://example.com/foto.jpg"
            />
            <p class="text-[10px] text-on-surface-variant/70">Kosongkan untuk pakai avatar otomatis dari nama.</p>
          </div>
          <!-- Upload via Cloudinary -->
          <div class="space-y-2">
            <label class="font-label text-[11px] uppercase tracking-widest font-bold text-on-surface-variant">Atau Upload Foto</label>
            <label class="cursor-pointer inline-flex items-center gap-2 bg-surface-container-high px-4 py-2 rounded-lg text-sm font-bold hover:bg-surface-container-highest transition-colors">
              <span class="material-symbols-outlined text-sm">upload</span>
              Pilih Foto
              <input type="file" id="avatarFile" accept="image/*" class="hidden" />
            </label>
            <p id="uploadStatus" class="text-xs text-on-surface-variant"></p>
          </div>
          <button
            type="button"
            id="saveProfileBtn"
            class="bg-on-surface text-surface px-6 py-3 rounded-lg font-bold text-sm hover:bg-primary transition-all flex items-center gap-2"
          >
            <span class="material-symbols-outlined text-sm">save</span>
            Simpan Profil
          </button>
        </div>
      </section>

      <!-- Breaking News Section -->
      <section class="grid grid-cols-1 md:grid-cols-12 gap-12 items-start">
        <div class="md:col-span-4">
          <h3 class="font-headline text-xl font-bold text-on-surface mb-2">Breaking News</h3>
          <p class="text-sm text-on-surface-variant leading-snug">Teks yang berjalan di ticker bagian atas homepage. Pisahkan berita dengan tanda •</p>
        </div>
        <div class="md:col-span-8 space-y-4 bg-surface-container-lowest p-8 rounded-xl">
          <div class="space-y-2">
            <label class="font-label text-[11px] uppercase tracking-widest font-bold text-on-surface-variant">Teks Ticker</label>
            <textarea name="breaking_news" rows="3" class="w-full border border-outline-variant bg-transparent p-3 rounded-lg focus:border-primary focus:ring-0 transition-colors font-mono text-sm resize-none">{settings.breaking_news}</textarea>
            <p class="text-[10px] text-on-surface-variant/70">Contoh: Berita A • Berita B • Berita C</p>
          </div>
        </div>
      </section>

      <!-- General Settings Section -->
      <section class="grid grid-cols-1 md:grid-cols-12 gap-12 items-start">
        <div class="md:col-span-4">
          <h3 class="font-headline text-xl font-bold text-on-surface mb-2">Pengaturan Umum</h3>
          <p class="text-sm text-on-surface-variant leading-snug">Identitas platform editorial Anda.</p>
        </div>
        <div class="md:col-span-8 space-y-8 bg-surface-container-lowest p-8 rounded-xl">
          <div class="space-y-2">
            <label class="font-label text-[11px] uppercase tracking-widest font-bold text-on-surface-variant">Judul Situs</label>
            <input name="site_title" class="w-full border-b border-outline-variant bg-transparent py-2 focus:border-primary focus:ring-0 transition-colors font-mono text-sm" type="text" value={settings.site_title} />
          </div>
          <div class="space-y-2">
            <label class="font-label text-[11px] uppercase tracking-widest font-bold text-on-surface-variant">Tagline</label>
            <input name="site_tagline" class="w-full border-b border-outline-variant bg-transparent py-2 focus:border-primary focus:ring-0 transition-colors font-mono text-sm" placeholder="Portal Berita Teknologi & Pop Culture" type="text" value={settings.site_tagline} />
            <p class="text-[10px] text-on-surface-variant/70 italic">Tampil di bawah logo pada sebagian besar tema.</p>
          </div>
          <div class="space-y-2">
            <label class="font-label text-[11px] uppercase tracking-widest font-bold text-on-surface-variant">Breaking News Ticker</label>
            <input name="breaking_news" class="w-full border-b border-outline-variant bg-transparent py-2 focus:border-primary focus:ring-0 transition-colors font-mono text-sm" placeholder="Teks yang berjalan di ticker breaking news..." type="text" value={settings.breaking_news || ''} />
            <p class="text-[10px] text-on-surface-variant/70 italic">Kosongkan untuk menyembunyikan ticker.</p>
          </div>
          <div class="pt-4 flex items-center justify-between">
            <div>
              <span class="block text-sm font-semibold text-on-surface">Mode Pemeliharaan</span>
              <span class="text-[11px] text-on-surface-variant">Cegah akses publik saat sedang mengerjakan konten.</span>
            </div>
            <button type="button" class="toggle-switch w-10 h-5 rounded-full relative transition-colors" data-name="maintenance_mode" data-value={settings.maintenance_mode}>
              <span class="toggle-dot absolute top-1 w-3 h-3 bg-white rounded-full transition-all"></span>
            </button>
          </div>
        </div>
      </section>

      <!-- Reading Settings Section -->
      <section class="grid grid-cols-1 md:grid-cols-12 gap-12 items-start">
        <div class="md:col-span-4">
          <h3 class="font-headline text-xl font-bold text-on-surface mb-2">Pengaturan Tampilan</h3>
          <p class="text-sm text-on-surface-variant leading-snug">Atur kepadatan dan tampilan arsip konten Anda.</p>
        </div>
        <div class="md:col-span-8 space-y-8 bg-surface-container-lowest p-8 rounded-xl">
          <div class="flex flex-col md:flex-row items-center gap-8">
            <div class="w-full md:w-1/2 space-y-2">
              <label class="font-label text-[11px] uppercase tracking-widest font-bold text-on-surface-variant">Artikel Per Halaman</label>
              <input name="posts_per_page" class="w-full border-b border-outline-variant bg-transparent py-2 focus:border-primary focus:ring-0 transition-colors font-mono text-sm text-center" type="number" value={settings.posts_per_page} min="1" max="50" />
            </div>
            <div class="w-full md:w-1/2 space-y-2">
              <label class="font-label text-[11px] uppercase tracking-widest font-bold text-on-surface-variant">Gaya Paginasi</label>
              <select name="pagination_style" class="w-full border-b border-outline-variant bg-transparent py-2 focus:border-primary focus:ring-0 transition-colors font-mono text-sm appearance-none">
                <option value="numbers" selected={settings.pagination_style === 'numbers'}>Nomor Halaman</option>
                <option value="infinite" selected={settings.pagination_style === 'infinite'}>Gulir Tak Terbatas</option>
                <option value="loadmore" selected={settings.pagination_style === 'loadmore'}>Tombol Muat Lebih</option>
              </select>
            </div>
          </div>
          <div class="space-y-4">
            <label class="font-label text-[11px] uppercase tracking-widest font-bold text-on-surface-variant">Tampilan Beranda</label>
            <div class="space-y-4">
              <label class="flex items-center gap-3 cursor-pointer group">
                <input checked={settings.homepage_display === 'latest'} class="w-4 h-4 text-primary focus:ring-0 border-outline-variant bg-transparent" name="homepage_display" type="radio" value="latest" />
                <span class="text-sm text-on-surface group-hover:text-primary transition-colors">Artikel terbaru Anda</span>
              </label>
              <label class="flex items-center gap-3 cursor-pointer group">
                <input checked={settings.homepage_display === 'static'} class="w-4 h-4 text-primary focus:ring-0 border-outline-variant bg-transparent" name="homepage_display" type="radio" value="static" />
                <span class="text-sm text-on-surface group-hover:text-primary transition-colors">Halaman landing editorial statis</span>
              </label>
            </div>
          </div>
        </div>
      </section>

      <!-- Discussion Settings Section -->
      <section class="grid grid-cols-1 md:grid-cols-12 gap-12 items-start">
        <div class="md:col-span-4">
          <h3 class="font-headline text-xl font-bold text-on-surface mb-2">Diskusi & Komentar</h3>
          <p class="text-sm text-on-surface-variant leading-snug">Kelola interaksi komunitas di platform Anda.</p>
        </div>
        <div class="md:col-span-8">
          <!-- Glassmorphism Container for Discussion -->
          <div class="bg-white/40 backdrop-blur-sm border border-outline-variant/10 p-8 rounded-xl space-y-8">
            <div class="flex items-start justify-between pb-6 border-b border-stone-100">
              <div class="max-w-[80%]">
                <span class="block text-sm font-bold text-on-surface">Izinkan Komentar Pembaca</span>
                <span class="text-[11px] text-on-surface-variant leading-relaxed">Izinkan pengunjung meninggalkan komentar pada artikel baru. Ini membangun komunitas tapi memerlukan moderasi aktif.</span>
              </div>
              <button type="button" class="toggle-switch w-12 h-6 rounded-full relative transition-colors" data-name="allow_comments" data-value={settings.allow_comments}>
                <span class="toggle-dot absolute top-1 w-4 h-4 bg-white rounded-full transition-all"></span>
              </button>
            </div>
            <div class="flex items-start justify-between pb-6 border-b border-stone-100">
              <div class="max-w-[80%]">
                <span class="block text-sm font-bold text-on-surface">Komentar Bersarang</span>
                <span class="text-[11px] text-on-surface-variant">Aktifkan komentar bersarang hingga 5 level.</span>
              </div>
              <button type="button" class="toggle-switch w-12 h-6 rounded-full relative transition-colors" data-name="nested_comments" data-value={settings.nested_comments}>
                <span class="toggle-dot absolute top-1 w-4 h-4 bg-white rounded-full transition-all"></span>
              </button>
            </div>
            <div class="flex items-start justify-between">
              <div class="max-w-[80%]">
                <span class="block text-sm font-bold text-on-surface">Persetujuan Manual</span>
                <span class="text-[11px] text-on-surface-variant">Semua komentar harus disetujui admin sebelum tampil di situs.</span>
              </div>
              <button type="button" class="toggle-switch w-12 h-6 rounded-full relative transition-colors" data-name="manual_approval" data-value={settings.manual_approval}>
                <span class="toggle-dot absolute top-1 w-4 h-4 bg-white rounded-full transition-all"></span>
              </button>
            </div>
          </div>
        </div>
      </section>

      <!-- Action Bar -->
      <div class="pt-12 flex flex-col sm:flex-row justify-end gap-4 md:gap-6 border-t border-stone-200/50">
        <button type="button" onclick="window.location.reload()" class="font-label text-xs uppercase tracking-widest font-bold text-on-surface-variant hover:text-on-surface transition-colors px-4 py-2">Batalkan Perubahan</button>
        <button type="submit" class="bg-surface-container-highest text-on-surface px-6 md:px-8 py-3 rounded-md font-label text-xs uppercase tracking-widest font-bold hover:bg-on-surface hover:text-surface transition-all duration-300">Simpan Konfigurasi</button>
      </div>
    </form>
  </div>

  <script is:inline>
    // Logo preview on URL input
    document.getElementById('siteLogoUrl').addEventListener('input', function() {
      const wrap = document.getElementById('logoPreviewWrap');
      const preview = document.getElementById('logoPreview');
      if (this.value) {
        wrap.innerHTML = `<img id="logoPreview" src="${this.value}" alt="Logo" class="w-full h-full object-contain" />`;
      } else {
        wrap.innerHTML = `<span id="logoPreview" class="material-symbols-outlined text-outline-variant">image</span>`;
      }
    });

    // Upload logo
    document.getElementById('logoFile').addEventListener('change', async function() {
      const file = this.files[0];
      if (!file) return;
      const status = document.getElementById('logoUploadStatus');
      status.textContent = 'Mengupload...';
      const fd = new FormData();
      fd.append('file', file);
      try {
        const res = await fetch('/api/upload/image', { method: 'POST', body: fd });
        const result = await res.json();
        if (result.success) {
          document.getElementById('siteLogoUrl').value = result.url;
          document.getElementById('logoPreviewWrap').innerHTML = `<img id="logoPreview" src="${result.url}" alt="Logo" class="w-full h-full object-contain" />`;
          status.textContent = '✅ Upload berhasil!';
        } else {
          status.textContent = '❌ ' + result.message;
        }
      } catch (e) {
        status.textContent = '❌ Gagal upload';
      }
    });

    // Avatar preview on URL input
    document.getElementById('adminAvatar').addEventListener('input', function() {
      if (this.value) document.getElementById('avatarPreview').src = this.value;
    });

    // Upload avatar via Cloudinary
    document.getElementById('avatarFile').addEventListener('change', async function() {
      const file = this.files[0];
      if (!file) return;
      const status = document.getElementById('uploadStatus');
      status.textContent = 'Mengupload...';
      const fd = new FormData();
      fd.append('file', file);
      try {
        const res = await fetch('/api/upload/image', { method: 'POST', body: fd });
        const result = await res.json();
        if (result.success) {
          document.getElementById('adminAvatar').value = result.url;
          document.getElementById('avatarPreview').src = result.url;
          status.textContent = '✅ Upload berhasil!';
        } else {
          status.textContent = '❌ ' + result.message;
        }
      } catch (e) {
        status.textContent = '❌ Gagal upload';
      }
    });

    // Save admin profile
    document.getElementById('saveProfileBtn').addEventListener('click', async function() {
      const name = document.getElementById('adminName').value.trim();
      const avatar = document.getElementById('adminAvatar').value.trim();
      if (!name) { alert('Nama tidak boleh kosong'); return; }

      const res = await fetch('/api/admin/update-profile', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ name, avatar }) });
      const result = await res.json();
      if (result.success) {
        // Update preview with fallback to UI Avatars if no avatar
        if (!avatar) {
          document.getElementById('avatarPreview').src =
            'https://ui-avatars.com/api/?name=' + encodeURIComponent(name) + '&background=7c3aed&color=fff&size=200&bold=true&rounded=true';
        }
        alert('✅ Profil berhasil diperbarui!');
      } else {
        alert('❌ ' + result.message);
      }
    });

    // Toggle switch functionality
    document.addEventListener('DOMContentLoaded', () => {
      const toggles = document.querySelectorAll('.toggle-switch');
      
      toggles.forEach(toggle => {
        const isActive = toggle.dataset.value === 'true';
        updateToggleUI(toggle, isActive);
        
        toggle.addEventListener('click', () => {
          const currentValue = toggle.dataset.value === 'true';
          const newValue = !currentValue;
          toggle.dataset.value = newValue.toString();
          updateToggleUI(toggle, newValue);
        });
      });
      
      function updateToggleUI(toggle, isActive) {
        const dot = toggle.querySelector('.toggle-dot');
        if (isActive) {
          toggle.classList.add('bg-primary');
          toggle.classList.remove('bg-stone-200');
          if (toggle.classList.contains('w-10')) {
            dot.classList.remove('right-1');
            dot.classList.add('left-6');
          } else {
            dot.classList.remove('left-1');
            dot.classList.add('left-7');
          }
        } else {
          toggle.classList.remove('bg-primary');
          toggle.classList.add('bg-stone-200');
          if (toggle.classList.contains('w-10')) {
            dot.classList.remove('left-6');
            dot.classList.add('right-1');
          } else {
            dot.classList.remove('left-7');
            dot.classList.add('left-1');
          }
        }
      }
      
      // Form submission
      const form = document.getElementById('settingsForm');
      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        
        const formData = new FormData(form);
        
        // Add toggle values
        toggles.forEach(toggle => {
          formData.append(toggle.dataset.name, toggle.dataset.value);
        });
        const data = Object.fromEntries(formData);
        try {
          const response = await fetch('/api/settings/update', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(data)
          });
          
          const result = await response.json();
          
          if (result.success) {
            alert('✅ Pengaturan berhasil disimpan!');
            window.location.reload();
          } else {
            alert('❌ Error: ' + result.message);
          }
        } catch (error) {
          console.error('Save error:', error);
          alert('❌ Terjadi kesalahan: ' + error.message);
        }
      });
    });
  </script>
</DashboardLayout>
