---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import { getAllCategories, getAllArticles } from '../lib/turso-helpers.js';

const categories = await getAllCategories();
const articles = await getAllArticles();
const popularArticles = [...articles]
  .sort((a, b) => (Number(b.views) || 0) - (Number(a.views) || 0))
  .slice(0, 6);
---

<BaseLayout title="404 - Halaman Tidak Ditemukan" description="Halaman yang Anda cari tidak ditemukan" noindex={true}>
  <Header />
  
  <main class="min-h-screen bg-gradient-to-br from-violet-50 via-white to-blue-50 dark:from-gray-950 dark:via-gray-900 dark:to-gray-950 py-12 px-4">
    <div class="max-w-4xl mx-auto">
      <!-- Error Message -->
      <div class="text-center mb-12">
        <div class="mb-8 relative">
          <div class="text-[120px] md:text-[180px] font-black text-transparent bg-clip-text bg-gradient-to-r from-violet-600 to-blue-600 leading-none select-none">
            404
          </div>
          <div class="absolute inset-0 flex items-center justify-center">
            <span class="material-symbols-outlined text-5xl md:text-7xl text-violet-600 dark:text-violet-400 animate-bounce">
              search_off
            </span>
          </div>
        </div>
        
        <h1 class="text-2xl md:text-4xl font-bold text-gray-900 dark:text-white mb-4">
          Oops! Halaman Tidak Ditemukan
        </h1>
        
        <p class="text-base md:text-lg text-gray-600 dark:text-gray-400 mb-8 max-w-2xl mx-auto">
          Halaman yang Anda cari mungkin telah dipindahkan, dihapus, atau tidak pernah ada.
        </p>

        <!-- Action Buttons -->
        <div class="flex flex-col sm:flex-row gap-3 justify-center mb-8">
          <a 
            href="/" 
            class="inline-flex items-center justify-center gap-2 bg-violet-600 hover:bg-violet-700 text-white font-bold px-6 py-3 rounded-xl transition-all shadow-lg"
          >
            <span class="material-symbols-outlined text-lg">home</span>
            Kembali ke Beranda
          </a>
          
          <a 
            href="/artikel" 
            class="inline-flex items-center justify-center gap-2 bg-white dark:bg-gray-800 hover:bg-gray-50 dark:hover:bg-gray-700 text-gray-900 dark:text-white font-bold px-6 py-3 rounded-xl transition-all border-2 border-gray-200 dark:border-gray-700"
          >
            <span class="material-symbols-outlined text-lg">explore</span>
            Jelajahi Artikel
          </a>
        </div>

        <!-- Search Box -->
        <div class="max-w-xl mx-auto mb-8">
          <form action="/artikel" method="get" class="relative">
            <input
              type="text"
              name="q"
              placeholder="Cari artikel..."
              class="w-full px-5 py-3 pr-12 bg-white dark:bg-gray-800 border-2 border-gray-200 dark:border-gray-700 rounded-xl text-gray-900 dark:text-white placeholder:text-gray-400 focus:border-violet-500 focus:ring-2 focus:ring-violet-500 outline-none transition-all text-sm"
            />
            <button 
              type="submit"
              class="absolute right-2 top-1/2 -translate-y-1/2 w-9 h-9 bg-violet-600 hover:bg-violet-700 text-white rounded-lg flex items-center justify-center transition-colors"
            >
              <span class="material-symbols-outlined text-lg">search</span>
            </button>
          </form>
        </div>
      </div>

      <!-- Popular Articles -->
      {popularArticles.length > 0 && (
        <div class="bg-white dark:bg-gray-900 rounded-2xl p-5 md:p-6 border border-gray-200 dark:border-gray-800 shadow-lg mb-8">
          <h2 class="text-lg md:text-xl font-bold text-gray-900 dark:text-white mb-4 flex items-center gap-2">
            <span class="material-symbols-outlined text-violet-600">trending_up</span>
            Artikel Populer
          </h2>
          
          <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
            {popularArticles.map((article) => (
              <a 
                href={`/artikel/${article.slug}`}
                class="group flex gap-3 p-3 rounded-xl hover:bg-gray-50 dark:hover:bg-gray-800 transition-colors"
              >
                <div class="w-16 h-16 flex-shrink-0 rounded-lg overflow-hidden bg-gray-200 dark:bg-gray-800">
                  <img 
                    src={article.cover_image || 'https://via.placeholder.com/200'} 
                    alt={article.title}
                    class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-300"
                    loading="lazy"
                  />
                </div>
                <div class="flex-1 min-w-0">
                  <h3 class="text-sm font-bold text-gray-900 dark:text-white line-clamp-2 group-hover:text-violet-600 dark:group-hover:text-violet-400 transition-colors mb-1">
                    {article.title}
                  </h3>
                  <div class="flex items-center gap-2 text-xs text-gray-500 dark:text-gray-400">
                    <span class="flex items-center gap-0.5">
                      <span class="material-symbols-outlined text-xs">visibility</span>
                      {Number(article.views || 0).toLocaleString('id-ID')}
                    </span>
                    <span>•</span>
                    <span>{article.read_time} mnt</span>
                  </div>
                </div>
              </a>
            ))}
          </div>
        </div>
      )}

      <!-- Categories -->
      {categories.length > 0 && (
        <div class="text-center">
          <p class="text-xs font-bold uppercase tracking-widest text-gray-500 dark:text-gray-400 mb-3">
            Jelajahi Kategori
          </p>
          <div class="flex flex-wrap gap-2 justify-center">
            {categories.map((cat: any) => (
              <a 
                href={`/kategori/${cat.slug}`}
                class="px-4 py-2 bg-white dark:bg-gray-800 hover:bg-violet-100 dark:hover:bg-violet-900/30 hover:text-violet-600 dark:hover:text-violet-400 text-gray-700 dark:text-gray-300 rounded-full text-sm font-medium transition-colors border border-gray-200 dark:border-gray-700"
              >
                {cat.name}
              </a>
            ))}
          </div>
        </div>
      )}
    </div>
  </main>
</BaseLayout>

<style>
  @keyframes bounce {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-15px); }
  }
  .animate-bounce {
    animation: bounce 2s ease-in-out infinite;
  }
</style>
