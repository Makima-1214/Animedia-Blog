---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
import { getAllCategories, getAllArticles } from '../../lib/turso-helpers.js';

const categories = await getAllCategories();
const articles = await getAllArticles();
---

<DashboardLayout title="Kelola Kategori - Admin Panel" activePage="kategori">
  <div class="p-8 lg:p-12">
    <div class="max-w-6xl mx-auto">
      <!-- Page Header with Asymmetry -->
      <div class="mb-16 flex justify-between items-end">
        <div class="max-w-xl">
          <h2 class="text-5xl font-headline font-extrabold tracking-tighter text-gray-900 dark:text-white mb-4">Taksonomi</h2>
          <p class="text-lg text-gray-600 dark:text-gray-400 font-light leading-relaxed">Atur konten editorial Anda melalui kategori yang terstruktur. Setiap klasifikasi adalah pilihan kurasi yang disengaja.</p>
        </div>
        <div class="text-right">
          <span class="text-7xl font-headline font-black text-gray-200 dark:text-gray-800 select-none">{categories.length.toString().padStart(2, '0')}</span>
          <p class="text-[10px] uppercase tracking-widest text-gray-600 dark:text-gray-400 font-bold">Total Koleksi Aktif</p>
        </div>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12">
        <!-- Left: Form Section -->
        <section class="lg:col-span-4">
          <div class="bg-gray-50 dark:bg-gray-900 p-8 rounded-xl editorial-shadow border border-gray-200 dark:border-gray-800">
            <h3 class="font-headline text-xl font-bold mb-8 text-gray-900 dark:text-white">Tambah Kategori Baru</h3>
            <form id="createCategoryForm" class="space-y-8">
              <div class="space-y-2">
                <label class="text-xs font-bold uppercase tracking-widest text-on-surface-variant">Nama Kategori</label>
                <input id="categoryName" name="name" required class="w-full border-0 border-b border-outline-variant bg-transparent py-2 px-0 focus:ring-0 focus:border-primary transition-colors placeholder:text-stone-300" placeholder="contoh: Arsitektur Minimalis" type="text" />
                <p class="text-[10px] text-on-surface-variant/60">Nama yang tampil di halaman publik.</p>
              </div>
              <div class="space-y-2">
                <label class="text-xs font-bold uppercase tracking-widest text-on-surface-variant">Slug</label>
                <input id="categorySlug" name="slug" required class="w-full border-0 border-b border-outline-variant bg-transparent py-2 px-0 focus:ring-0 focus:border-primary transition-colors placeholder:text-stone-300" placeholder="arsitektur-minimalis" type="text" />
              </div>
              <div class="space-y-2">
                <label class="text-xs font-bold uppercase tracking-widest text-on-surface-variant">Deskripsi</label>
                <textarea name="description" class="w-full border-0 border-b border-outline-variant bg-transparent py-2 px-0 focus:ring-0 focus:border-primary transition-colors placeholder:text-stone-300 resize-none" placeholder="Deskripsi singkat untuk kategori ini..." rows="3"></textarea>
              </div>
              <button class="w-full py-4 bg-on-background text-surface font-bold rounded-lg hover:bg-zinc-800 transition-all active:scale-[0.98] mt-4" type="submit">
                Buat Kategori
              </button>
            </form>
          </div>
          <div class="mt-12 p-8 bg-surface-container-low rounded-xl border border-stone-200/50">
            <div class="flex items-start gap-4">
              <span class="material-symbols-outlined text-primary">auto_awesome</span>
              <div>
                <h4 class="text-sm font-bold mb-1">Tips Kurasi</h4>
                <p class="text-xs leading-relaxed text-on-surface-variant">Buat kategori yang luas tapi berbeda. Targetkan 5-8 kategori utama untuk pengalaman membaca yang bersih.</p>
              </div>
            </div>
          </div>
        </section>

        <!-- Right: Table Section -->
        <section class="lg:col-span-8">
          <div class="overflow-hidden">
            <table class="w-full text-left border-collapse">
              <thead>
                <tr class="border-b border-stone-200">
                  <th class="py-4 text-[10px] uppercase tracking-widest text-on-surface-variant font-bold">Nama Kategori</th>
                  <th class="py-4 text-[10px] uppercase tracking-widest text-on-surface-variant font-bold">Slug</th>
                  <th class="py-4 text-[10px] uppercase tracking-widest text-on-surface-variant font-bold">Jumlah Artikel</th>
                  <th class="py-4 text-[10px] uppercase tracking-widest text-on-surface-variant font-bold text-right px-4">Aksi</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-stone-100">
                {categories.map((category: any) => {
                  const articleCount = articles.filter((a: any) => a.category_id === category.id).length;
                  return (
                    <tr class="group hover:bg-surface-container-low transition-colors">
                      <td class="py-6">
                        <div class="flex items-center gap-4">
                          <div class="w-10 h-10 bg-surface-container-high overflow-hidden rounded-md flex items-center justify-center">
                            <span class="material-symbols-outlined text-outline-variant">category</span>
                          </div>
                          <div>
                            <p class="font-bold text-on-background">{category.name}</p>
                            <p class="text-xs text-on-surface-variant/70 italic">{category.description}</p>
                          </div>
                        </div>
                      </td>
                      <td class="py-6 text-sm text-on-surface-variant font-mono">{category.slug}</td>
                      <td class="py-6">
                        <span class="px-2.5 py-1 bg-surface-container-highest text-[10px] font-bold rounded-full">{articleCount} Artikel</span>
                      </td>
                      <td class="py-6 text-right px-4">
                        <div class="flex justify-end gap-2">
                          <button onclick={`editCategory('${category.id}', '${category.name.replace(/'/g, "\\'")}')`} class="p-2 hover:bg-primary/5 rounded-md transition-colors text-zinc-400 hover:text-primary">
                            <span class="material-symbols-outlined text-lg">edit</span>
                          </button>
                          <button onclick={`deleteCategory('${category.id}', '${category.name.replace(/'/g, "\\'")}')`} class="p-2 hover:bg-error/5 rounded-md transition-colors text-zinc-400 hover:text-error">
                            <span class="material-symbols-outlined text-lg">delete</span>
                          </button>
                        </div>
                      </td>
                    </tr>
                  );
                })}
              </tbody>
            </table>
          </div>

          <!-- Pagination -->
          <div class="mt-8 flex justify-between items-center text-xs">
            <p class="text-on-surface-variant">Menampilkan <span class="font-bold text-on-background">{categories.length}</span> kategori</p>
          </div>
        </section>
      </div>
    </div>
  </div>
</DashboardLayout>


  <script>
    // Auto-generate slug from category name
    const nameInput = document.getElementById('categoryName') as HTMLInputElement;
    const slugInput = document.getElementById('categorySlug') as HTMLInputElement;

    nameInput?.addEventListener('input', () => {
      const slug = nameInput.value
        .toLowerCase()
        .replace(/[^a-z0-9]+/g, '-')
        .replace(/^-+|-+$/g, '');
      slugInput.value = slug;
    });

    // Handle form submission
    const form = document.getElementById('createCategoryForm') as HTMLFormElement;
    form?.addEventListener('submit', async (e) => {
      e.preventDefault();
      
      const formData = new FormData(form);
      
      try {
        const response = await fetch('/api/categories/create', {
          method: 'POST',
          body: formData
        });

        const result = await response.json();

        if (result.success) {
          alert('Kategori berhasil dibuat!');
          window.location.reload();
        } else {
          alert('Error: ' + result.message);
        }
      } catch (error) {
        alert('Terjadi kesalahan: ' + error);
      }
    });

    // Edit category function
    async function editCategory(id: string, currentName: string) {
      const newName = prompt(`Edit nama kategori:`, currentName);
      if (!newName || newName.trim() === currentName) return;

      try {
        const formData = new FormData();
        formData.append('id', id);
        formData.append('name', newName.trim());

        const response = await fetch('/api/categories/update', {
          method: 'POST',
          body: formData
        });

        const result = await response.json();
        if (result.success) {
          window.location.reload();
        } else {
          alert('Error: ' + result.message);
        }
      } catch (error) {
        alert('Terjadi kesalahan: ' + error);
      }
    }

    (window as any).editCategory = editCategory;

    // Delete category function
    async function deleteCategory(id: string, name: string) {
      (window as any).showConfirm({
        title: 'Hapus Kategori?',
        message: `"${name}" akan dihapus. Artikel dalam kategori ini tidak akan terhapus.`,
        okText: 'Hapus',
        okIcon: 'delete',
        okClass: 'bg-red-500 hover:bg-red-600',
        iconBg: 'bg-red-100',
        iconColor: 'text-red-500',
        icon: 'delete'
      }, async (confirmed) => {
        if (!confirmed) return;
        try {
          const formData = new FormData();
          formData.append('id', id);
          const response = await fetch('/api/categories/delete', { method: 'POST', body: formData });
          const result = await response.json();
          if (result.success) {
            alert('✅ Kategori berhasil dihapus!');
            window.location.reload();
          } else {
            alert('❌ Error: ' + result.message);
          }
        } catch (error) {
          alert('❌ Terjadi kesalahan: ' + error);
        }
      });
    }

    // Make function available globally
    (window as any).deleteCategory = deleteCategory;
  </script>
