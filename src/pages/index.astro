---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import { getAllArticles, getAllCategories } from '../lib/turso-helpers.js';
import { getSetting } from '../lib/settings.js';

const articles = await getAllArticles();
const categories = await getAllCategories();
const breakingNews = await getSetting('breaking_news') || '';
const homepageDisplay = await getSetting('homepage_display') || 'latest';
const featuredArticle = articles[0];
const trendingArticles = articles.slice(0, 5);

// Pagination untuk performance
const articlesPerPage = 12;
const displayedArticles = articles.slice(0, articlesPerPage);
---

<BaseLayout title="Berita Teknologi, Game, Anime & Gadget Terkini" description="Portal berita teknologi, game, anime, film, dan gadget terkini. Temukan artikel terbaru dan terpercaya di Animedia.">
  <Header />
  
  <main class="bg-gray-50 dark:bg-gray-950">

    {homepageDisplay === 'static' && (
      <section class="min-h-[70vh] flex flex-col items-center justify-center text-center px-4 py-20 bg-gradient-to-br from-violet-700 via-violet-600 to-blue-600">
        <span class="material-symbols-outlined text-white/60 text-6xl mb-6">architecture</span>
        <h1 class="text-3xl md:text-6xl font-black text-white tracking-tight mb-4 max-w-3xl">
          Selamat Datang di Animedia
        </h1>
        <p class="text-white/80 text-lg md:text-xl max-w-xl mb-8">
          Portal berita teknologi, game, anime, film, dan gadget terkini untuk kamu.
        </p>
        <div class="flex flex-wrap gap-3 justify-center">
          <a href="/artikel" class="bg-white text-violet-700 font-bold px-6 py-3 rounded-xl hover:bg-gray-100 transition-colors">
            Baca Artikel
          </a>
          <a href="/berlangganan" class="bg-white/20 backdrop-blur-sm text-white font-bold px-6 py-3 rounded-xl hover:bg-white/30 transition-colors border border-white/30">
            Newsletter
          </a>
        </div>
      </section>
    )}

    {homepageDisplay !== 'static' && breakingNews && (
    <div class="bg-red-600 dark:bg-red-700 text-white py-2 px-4">
      <div class="max-w-7xl mx-auto flex items-center gap-3">
        <span class="bg-white text-red-600 dark:text-red-700 text-xs font-black px-2 py-1 rounded uppercase whitespace-nowrap">
          Breaking
        </span>
        <div class="text-xs md:text-sm font-medium overflow-hidden">
          <div class="animate-marquee whitespace-nowrap">
            {breakingNews}
          </div>
        </div>
      </div>
    </div>
    )}

    {homepageDisplay !== 'static' && (
    <div class="max-w-7xl mx-auto px-3 md:px-4 py-4 md:py-6">

      <!-- ═══════════════════════════════════════════════════════
           HERO ARTICLE — overlay style (mobile-first) with enhanced animations
      ════════════════════════════════════════════════════════ -->
      {featuredArticle && (
        <article class="relative rounded-2xl overflow-hidden mb-6 shadow-lg hover:shadow-2xl transition-all duration-500 group" data-animate="fade-in" data-hover="lift">
          <a href={`/artikel/${featuredArticle.slug}`} class="block">
            <!-- Image with parallax effect -->
            <div class="relative h-72 sm:h-96 md:h-[480px] overflow-hidden">
              <img
                src={String(featuredArticle.cover_image || 'https://via.placeholder.com/800x400')}
                alt={String(featuredArticle.title)}
                loading="eager"
                class="w-full h-full object-cover scale-100 group-hover:scale-110 transition-transform duration-1000 ease-out"
                data-parallax="0.3"
              />
              <!-- Enhanced gradient overlay -->
              <div class="absolute inset-0 bg-gradient-to-t from-black/95 via-black/50 to-transparent"></div>
              
              <!-- Animated glow effect on hover -->
              <div class="absolute inset-0 bg-gradient-to-t from-violet-600/20 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
            </div>
            <!-- Text overlay with better spacing -->
            <div class="absolute bottom-0 left-0 right-0 p-6 md:p-8">
              <div class="flex items-center gap-3 mb-4">
                <span class="bg-gradient-to-r from-red-600 to-red-500 text-white text-xs font-black px-4 py-2 rounded-full uppercase tracking-wider shadow-xl animate-pulse backdrop-blur-sm">
                  🔥 Headline
                </span>
                {categories.find((c: any) => c.id === featuredArticle.category_id) && (
                  <span class="bg-white/20 backdrop-blur-md text-white text-xs font-bold px-4 py-2 rounded-full uppercase tracking-wider border border-white/30 shadow-lg">
                    {categories.find((c: any) => c.id === featuredArticle.category_id)?.name}
                  </span>
                )}
              </div>
              <h1 class="text-2xl sm:text-3xl md:text-5xl font-black text-white leading-tight mb-4 line-clamp-3 drop-shadow-2xl">
                {featuredArticle.title}
              </h1>
              <p class="text-white/90 text-base sm:text-lg line-clamp-2 mb-5 hidden sm:block drop-shadow-lg font-medium">
                {featuredArticle.excerpt}
              </p>
              <div class="flex items-center gap-5 text-white/80 text-sm md:text-base">
                <span class="flex items-center gap-2 bg-black/30 backdrop-blur-sm px-3 py-1.5 rounded-full">
                  <span class="material-symbols-outlined text-lg">calendar_today</span>
                  {featuredArticle.published_at
                    ? new Date(String(featuredArticle.published_at)).toLocaleDateString('id-ID', { day: 'numeric', month: 'short', year: 'numeric' })
                    : ''}
                </span>
                <span class="flex items-center gap-2 bg-black/30 backdrop-blur-sm px-3 py-1.5 rounded-full">
                  <span class="material-symbols-outlined text-lg">schedule</span>
                  {featuredArticle.read_time} menit
                </span>
                {featuredArticle.views && Number(featuredArticle.views) > 0 && (
                  <span class="flex items-center gap-2 bg-black/30 backdrop-blur-sm px-3 py-1.5 rounded-full">
                    <span class="material-symbols-outlined text-lg">visibility</span>
                    {Number(featuredArticle.views) > 1000 ? `${(Number(featuredArticle.views) / 1000).toFixed(1)}k` : featuredArticle.views} views
                  </span>
                )}
              </div>
            </div>
          </a>
        </article>
      )}

      <!-- ═══════════════════════════════════════════════════════
           MOBILE ONLY: Trending horizontal strip
      ════════════════════════════════════════════════════════ -->
      <div class="lg:hidden mb-4">
        <div class="flex items-center gap-2 mb-3">
          <span class="text-sm font-black uppercase tracking-widest text-gray-900 dark:text-white flex items-center gap-1.5">
            <span class="text-xl">🔥</span>
            Trending
          </span>
          <div class="flex-1 h-px bg-gray-200 dark:bg-gray-800"></div>
        </div>
        <div class="flex gap-3 overflow-x-auto no-scrollbar pb-2">
          {trendingArticles.map((article: any, index: number) => (
            <a
              href={`/artikel/${article.slug}`}
              class="flex-shrink-0 w-40 group"
            >
              <div class="relative rounded-lg overflow-hidden h-24 mb-2 bg-gray-200 dark:bg-gray-800 shadow-sm">
                <img
                  src={article.cover_image || 'https://via.placeholder.com/200x150'}
                  alt={article.title}
                  loading="lazy"
                  class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500"
                />
                <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent"></div>
                <div class="absolute top-2 left-2 w-6 h-6 bg-red-600 rounded-full text-white text-xs font-black flex items-center justify-center shadow-lg">
                  {index + 1}
                </div>
                {article.views && Number(article.views) > 0 && (
                  <div class="absolute bottom-2 right-2 bg-black/70 backdrop-blur-sm text-white text-[10px] font-semibold px-1.5 py-0.5 rounded-full flex items-center gap-0.5">
                    <span class="material-symbols-outlined text-xs">visibility</span>
                    {Number(article.views) > 1000 ? `${(Number(article.views) / 1000).toFixed(1)}k` : article.views}
                  </div>
                )}
              </div>
              <p class="text-xs font-bold text-gray-800 dark:text-gray-200 line-clamp-2 leading-snug group-hover:text-violet-600 dark:group-hover:text-violet-400 transition-colors">
                {article.title}
              </p>
            </a>
          ))}
        </div>
      </div>

      <!-- ═══════════════════════════════════════════════════════
           MOBILE ONLY: Kategori horizontal pill strip
      ════════════════════════════════════════════════════════ -->
      <div class="lg:hidden mb-4 flex gap-2 overflow-x-auto no-scrollbar pb-1">
        <a href="/artikel" class="flex-shrink-0 px-3 py-1.5 bg-violet-600 text-white text-xs font-bold rounded-full">
          Semua
        </a>
        {categories.map((cat: any) => (
          <a
            href={`/kategori/${cat.slug}`}
            class="flex-shrink-0 px-3 py-1.5 bg-white dark:bg-gray-800 text-gray-700 dark:text-gray-300 text-xs font-semibold rounded-full border border-gray-200 dark:border-gray-700 hover:border-violet-400 hover:text-violet-600 dark:hover:text-violet-400 transition-colors"
          >
            {cat.name}
          </a>
        ))}
      </div>

      <!-- ═══════════════════════════════════════════════════════
           MAIN GRID
      ════════════════════════════════════════════════════════ -->
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-4 md:gap-6">

        <!-- Main Content -->
        <div class="lg:col-span-2 space-y-4 md:space-y-6">

          <!-- Article Grid: 2 kolom di mobile, 2 kolom di desktop with stagger animation -->
          <div class="grid grid-cols-2 md:grid-cols-2 gap-4 md:gap-6" data-stagger>
            {displayedArticles.slice(1, 7).map((article: any) => (
              <article class="bg-white dark:bg-gray-900 rounded-2xl overflow-hidden shadow-md hover:shadow-2xl transition-all duration-500 group card-hover" data-animate="fade-in" data-hover="lift">
                <a href={`/artikel/${article.slug}`} class="block">
                  <div class="relative aspect-[16/10] overflow-hidden bg-gray-100 dark:bg-gray-800">
                    <img
                      src={article.cover_image || 'https://via.placeholder.com/400x250'}
                      alt={article.title}
                      loading="lazy"
                      class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700 ease-out"
                    />
                    <div class="absolute inset-0 bg-gradient-to-t from-black/30 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
                    <div class="absolute top-3 left-3">
                      <span class="bg-white/95 dark:bg-gray-900/95 backdrop-blur-sm text-violet-600 dark:text-violet-400 text-xs font-black px-3 py-1.5 rounded-full uppercase tracking-wide shadow-lg border border-violet-100 dark:border-violet-800">
                        {categories.find((c: any) => c.id === article.category_id)?.name || 'Artikel'}
                      </span>
                    </div>
                    <!-- View Count Badge with better design -->
                    {article.views && Number(article.views) > 0 && (
                      <div class="absolute bottom-3 right-3 bg-black/80 backdrop-blur-md text-white text-xs font-bold px-3 py-1.5 rounded-full flex items-center gap-1.5 shadow-lg">
                        <span class="material-symbols-outlined text-sm">visibility</span>
                        {Number(article.views) > 1000 ? `${(Number(article.views) / 1000).toFixed(1)}k` : article.views}
                      </div>
                    )}
                  </div>
                  <div class="p-4 md:p-5">
                    <h3 class="text-sm md:text-base font-bold text-gray-900 dark:text-white line-clamp-2 leading-snug group-hover:text-violet-600 dark:group-hover:text-violet-400 transition-colors mb-3 min-h-[2.5rem]">
                      {article.title}
                    </h3>
                    <div class="flex items-center justify-between text-xs text-gray-500 dark:text-gray-400 pt-3 border-t border-gray-100 dark:border-gray-800">
                      <span class="flex items-center gap-1.5">
                        <span class="material-symbols-outlined text-sm">schedule</span>
                        {article.read_time} mnt
                      </span>
                      {article.published_at && (
                        <span class="text-xs">
                          {new Date(String(article.published_at)).toLocaleDateString('id-ID', { day: 'numeric', month: 'short' })}
                        </span>
                      )}
                    </div>
                  </div>
                </a>
              </article>
            ))}
          </div>

          <!-- More Articles List — horizontal card style with enhanced design -->
          <div class="bg-white dark:bg-gray-900 rounded-2xl shadow-lg overflow-hidden border border-gray-100 dark:border-gray-800" data-animate="fade-in">
            <div class="px-5 py-4 border-b border-gray-100 dark:border-gray-800 flex items-center justify-between bg-gradient-to-r from-violet-50 to-blue-50 dark:from-gray-800 dark:to-gray-800">
              <h2 class="text-base md:text-lg font-black text-gray-900 dark:text-white flex items-center gap-2">
                <span class="material-symbols-outlined text-violet-600 dark:text-violet-400 text-xl">newspaper</span>
                Berita Terbaru
              </h2>
              <a href="/artikel" class="text-xs font-bold text-violet-600 dark:text-violet-400 hover:text-violet-700 dark:hover:text-violet-300 flex items-center gap-1 transition-colors group">
                Lihat semua
                <span class="material-symbols-outlined text-sm group-hover:translate-x-1 transition-transform">arrow_forward</span>
              </a>
            </div>
            <div class="divide-y divide-gray-100 dark:divide-gray-800">
              {(displayedArticles.length > 7 ? displayedArticles.slice(7, 15) : displayedArticles.slice(0, 8)).map((article: any) => (
                <a href={`/artikel/${article.slug}`} class="flex gap-4 md:gap-5 p-4 md:p-5 hover:bg-gradient-to-r hover:from-violet-50/50 hover:to-blue-50/50 dark:hover:from-gray-800/50 dark:hover:to-gray-800/50 transition-all duration-300 group">
                  <div class="w-24 h-20 md:w-32 md:h-24 flex-shrink-0 rounded-xl overflow-hidden bg-gray-100 dark:bg-gray-800 shadow-md group-hover:shadow-xl transition-shadow">
                    <img
                      src={article.cover_image || 'https://via.placeholder.com/200x150'}
                      alt={article.title}
                      loading="lazy"
                      class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700"
                    />
                  </div>
                  <div class="flex-1 min-w-0 flex flex-col justify-center">
                    <h3 class="text-sm md:text-base font-bold text-gray-900 dark:text-white line-clamp-2 group-hover:text-violet-600 dark:group-hover:text-violet-400 transition-colors leading-snug mb-2">
                      {article.title}
                    </h3>
                    <div class="flex items-center gap-3 text-xs text-gray-500 dark:text-gray-400">
                      <span class="text-violet-600 dark:text-violet-400 font-bold text-xs uppercase bg-violet-50 dark:bg-violet-900/20 px-2 py-1 rounded">
                        {categories.find((c: any) => c.id === article.category_id)?.name || 'Artikel'}
                      </span>
                      <span class="flex items-center gap-1">
                        <span class="material-symbols-outlined text-xs">schedule</span>
                        {article.read_time} mnt
                      </span>
                      {article.views && Number(article.views) > 0 && (
                        <>
                          <span>·</span>
                          <span class="flex items-center gap-1 font-semibold">
                            <span class="material-symbols-outlined text-xs">visibility</span>
                            {Number(article.views) > 1000 ? `${(Number(article.views) / 1000).toFixed(1)}k` : article.views}
                          </span>
                        </>
                      )}
                    </div>
                  </div>
                </a>
              ))}
            </div>
          </div>
          
          <!-- Load More Button with enhanced design -->
          {articles.length > articlesPerPage && (
            <div class="text-center py-8" data-animate="fade-in">
              <a 
                href="/artikel" 
                class="inline-flex items-center gap-3 bg-gradient-to-r from-violet-600 to-blue-600 hover:from-violet-700 hover:to-blue-700 text-white font-bold px-10 py-4 rounded-2xl transition-all duration-300 shadow-xl hover:shadow-2xl transform hover:-translate-y-1 active:scale-95"
                data-ripple="true"
              >
                <span>Lihat Semua Artikel</span>
                <span class="material-symbols-outlined">arrow_forward</span>
              </a>
            </div>
          )}
        </div>

        <!-- ═══════════════════════════════════════════════════
             SIDEBAR — desktop only with enhanced design
        ════════════════════════════════════════════════════ -->
        <aside class="hidden lg:block space-y-6" data-animate="fade-in">
          <!-- Trending with gradient background -->
          <div class="bg-gradient-to-br from-red-50 to-orange-50 dark:from-gray-900 dark:to-gray-900 rounded-2xl shadow-xl p-6 border border-red-100 dark:border-red-900/30 overflow-hidden relative">
            <!-- Decorative element -->
            <div class="absolute top-0 right-0 w-32 h-32 bg-red-500/10 rounded-full -mr-16 -mt-16"></div>
            
            <h3 class="text-base md:text-lg font-black text-gray-900 dark:text-white mb-5 pb-4 border-b-2 border-red-500 flex items-center gap-2 relative z-10">
              <span class="text-2xl animate-pulse">🔥</span>
              Trending Sekarang
            </h3>
            <div class="space-y-5 relative z-10">
              {trendingArticles.map((article: any, index: number) => (
                <article class="flex gap-4 group">
                  <a href={`/artikel/${article.slug}`} class="flex gap-4 w-full">
                    <span class="text-3xl md:text-4xl font-black text-red-200 dark:text-red-900/50 group-hover:text-red-500 dark:group-hover:text-red-500 transition-colors w-10 flex-shrink-0 leading-none">
                      {(index + 1).toString().padStart(2, '0')}
                    </span>
                    <div class="flex-1 min-w-0">
                      <h4 class="text-sm font-bold text-gray-900 dark:text-white line-clamp-2 md:line-clamp-3 group-hover:text-red-600 dark:group-hover:text-red-400 transition-colors leading-snug mb-2">
                        {article.title}
                      </h4>
                      <div class="flex items-center gap-3 text-xs text-gray-500 dark:text-gray-400">
                        {article.views && Number(article.views) > 0 && (
                          <span class="flex items-center gap-1 font-bold text-red-600 dark:text-red-400">
                            <span class="material-symbols-outlined text-sm">visibility</span>
                            {Number(article.views) > 1000 ? `${(Number(article.views) / 1000).toFixed(1)}k` : article.views}
                          </span>
                        )}
                        <span>·</span>
                        <span class="flex items-center gap-1">
                          <span class="material-symbols-outlined text-sm">schedule</span>
                          {article.read_time} mnt
                        </span>
                      </div>
                    </div>
                  </a>
                </article>
              ))}
            </div>
          </div>

          <!-- Categories with hover effects -->
          <div class="bg-white dark:bg-gray-900 rounded-2xl shadow-xl p-6 border border-gray-100 dark:border-gray-800">
            <h3 class="text-base md:text-lg font-black text-gray-900 dark:text-white mb-5 pb-4 border-b-2 border-blue-500 flex items-center gap-2">
              <span class="material-symbols-outlined text-xl text-blue-500">folder</span>
              Kategori
            </h3>
            <div class="space-y-2">
              {categories.map((category: any) => (
                <a
                  href={`/kategori/${category.slug}`}
                  class="flex items-center justify-between py-3 px-4 rounded-xl hover:bg-gradient-to-r hover:from-violet-50 hover:to-blue-50 dark:hover:from-gray-800 dark:hover:to-gray-800 transition-all duration-300 group border border-transparent hover:border-violet-200 dark:hover:border-violet-800"
                >
                  <span class="text-sm font-bold text-gray-700 dark:text-gray-300 group-hover:text-violet-600 dark:group-hover:text-violet-400 transition-colors">
                    {category.name}
                  </span>
                  <span class="text-xs font-bold text-gray-400 dark:text-gray-600 bg-gray-100 dark:bg-gray-800 px-3 py-1.5 rounded-full group-hover:bg-violet-100 dark:group-hover:bg-violet-900/30 group-hover:text-violet-600 dark:group-hover:text-violet-400 transition-all min-w-[2rem] text-center">
                    {displayedArticles.filter((a: any) => a.category_id === category.id).length}
                  </span>
                </a>
              ))}
            </div>
          </div>

          <!-- Newsletter with enhanced gradient -->
          <div class="bg-gradient-to-br from-violet-600 via-violet-500 to-blue-600 rounded-2xl shadow-2xl p-8 text-white relative overflow-hidden">
            <div class="absolute top-0 right-0 w-40 h-40 bg-white/10 rounded-full -mr-20 -mt-20"></div>
            <div class="absolute bottom-0 left-0 w-32 h-32 bg-white/10 rounded-full -ml-16 -mb-16"></div>
            <div class="relative text-center">
              <span class="material-symbols-outlined text-6xl mb-4 block drop-shadow-2xl animate-bounce">mail</span>
              <h3 class="text-xl font-black mb-3">Newsletter Gratis 📬</h3>
              <p class="text-sm opacity-95 mb-6 leading-relaxed">
                Dapatkan berita terbaru langsung di inbox Anda setiap hari
              </p>
              <a
                href="/berlangganan"
                class="block w-full bg-white text-violet-600 font-bold py-4 rounded-xl text-sm hover:bg-gray-100 transition-all duration-300 shadow-2xl hover:shadow-3xl transform hover:-translate-y-1 active:scale-95"
                data-ripple="true"
              >
                Berlangganan Sekarang
              </a>
            </div>
          </div>

          <!-- Social Proof / Stats with counter animation -->
          <div class="bg-gradient-to-br from-gray-900 to-gray-800 dark:from-gray-800 dark:to-gray-900 rounded-2xl shadow-2xl p-6 text-white">
            <div class="grid grid-cols-2 gap-4 text-center">
              <div class="bg-white/10 backdrop-blur-sm rounded-xl p-4 hover:bg-white/20 transition-all duration-300 transform hover:scale-105">
                <div class="text-3xl font-black text-violet-400 mb-2" data-count={articles.length}>{articles.length}</div>
                <div class="text-xs font-semibold opacity-80">Artikel</div>
              </div>
              <div class="bg-white/10 backdrop-blur-sm rounded-xl p-4 hover:bg-white/20 transition-all duration-300 transform hover:scale-105">
                <div class="text-3xl font-black text-blue-400 mb-2" data-count={categories.length}>{categories.length}</div>
                <div class="text-xs font-semibold opacity-80">Kategori</div>
              </div>
            </div>
          </div>
        </aside>
      </div>

      <!-- ═══════════════════════════════════════════════════════
           MOBILE ONLY: Newsletter banner di bawah
      ════════════════════════════════════════════════════════ -->
      <div class="lg:hidden mt-6">
        <div class="bg-gradient-to-r from-violet-600 to-blue-600 rounded-xl p-5 flex items-center gap-4 text-white shadow-lg">
          <span class="material-symbols-outlined text-4xl flex-shrink-0">mail</span>
          <div class="flex-1 min-w-0">
            <p class="text-base font-bold mb-1">Newsletter Gratis 📬</p>
            <p class="text-xs opacity-90">Artikel terbaru langsung ke inbox kamu</p>
          </div>
          <a href="/berlangganan" class="flex-shrink-0 bg-white text-violet-600 font-bold text-sm px-4 py-2.5 rounded-lg hover:bg-gray-100 transition-all duration-300 shadow-md hover:shadow-lg whitespace-nowrap">
            Daftar
          </a>
        </div>
      </div>

    </div>
    )}
    
    <!-- Sticky Newsletter Bar (Mobile Only) -->
    <div id="sticky-newsletter" class="lg:hidden fixed bottom-0 left-0 right-0 bg-gradient-to-r from-violet-600 to-blue-600 text-white p-3 shadow-2xl transform translate-y-full transition-transform duration-300 z-40">
      <div class="flex items-center justify-between gap-3 max-w-7xl mx-auto">
        <div class="flex items-center gap-3 flex-1 min-w-0">
          <span class="material-symbols-outlined text-2xl flex-shrink-0">notifications_active</span>
          <div class="flex-1 min-w-0">
            <p class="text-sm font-bold">Jangan Lewatkan Update!</p>
            <p class="text-xs opacity-90">Subscribe newsletter gratis</p>
          </div>
        </div>
        <a href="/berlangganan" class="flex-shrink-0 bg-white text-violet-600 font-bold text-xs px-4 py-2 rounded-lg hover:bg-gray-100 transition-colors whitespace-nowrap">
          Subscribe
        </a>
        <button id="close-sticky-newsletter" class="flex-shrink-0 text-white/80 hover:text-white">
          <span class="material-symbols-outlined text-xl">close</span>
        </button>
      </div>
    </div>
  </main>

  <style>
    @keyframes marquee {
      0% { transform: translateX(0); }
      100% { transform: translateX(-50%); }
    }
    .animate-marquee {
      display: inline-block;
      animation: marquee 20s linear infinite;
    }
    
    /* Smooth scroll behavior */
    html {
      scroll-behavior: smooth;
    }
    
    /* Hide scrollbar for horizontal scroll */
    .no-scrollbar::-webkit-scrollbar {
      display: none;
    }
    .no-scrollbar {
      -ms-overflow-style: none;
      scrollbar-width: none;
    }
  </style>

  <script>
    // Sticky Newsletter Bar Logic
    let scrollTimeout: ReturnType<typeof setTimeout>;
    let hasShownSticky = false;
    const stickyNewsletter = document.getElementById('sticky-newsletter');
    const closeStickyBtn = document.getElementById('close-sticky-newsletter');
    
    function showStickyNewsletter() {
      if (!hasShownSticky && stickyNewsletter && window.innerWidth < 1024) {
        stickyNewsletter.style.transform = 'translateY(0)';
        hasShownSticky = true;
      }
    }
    
    function hideStickyNewsletter() {
      if (stickyNewsletter) {
        stickyNewsletter.style.transform = 'translateY(100%)';
      }
    }
    
    // Show sticky bar after 5 seconds of scrolling
    window.addEventListener('scroll', () => {
      clearTimeout(scrollTimeout);
      scrollTimeout = setTimeout(() => {
        if (window.scrollY > 800 && !hasShownSticky) {
          showStickyNewsletter();
        }
      }, 5000);
    });
    
    // Close button
    closeStickyBtn?.addEventListener('click', () => {
      hideStickyNewsletter();
      localStorage.setItem('newsletter-dismissed', 'true');
    });
    
    // Check if user already dismissed
    if (localStorage.getItem('newsletter-dismissed') === 'true') {
      hasShownSticky = true;
    }
    
    // Lazy loading images (native)
    if ('loading' in HTMLImageElement.prototype) {
      const images = document.querySelectorAll('img[loading="lazy"]');
      images.forEach((img) => {
        if (img instanceof HTMLImageElement) {
          img.src = img.src;
        }
      });
    }
  </script>
</BaseLayout>
