---
interface Props {
  src: string;
  alt: string;
  class?: string;
  loading?: 'lazy' | 'eager';
  width?: number;
  height?: number;
  objectFit?: 'cover' | 'contain' | 'fill' | 'none' | 'scale-down';
  priority?: boolean;
  sizes?: string;
}

const { 
  src, 
  alt, 
  class: className = '', 
  loading = 'lazy', 
  width, 
  height,
  objectFit = 'cover',
  priority = false,
  sizes = '100vw'
} = Astro.props;

const imgWidth = width || 800;
const imgHeight = height || 600;

// Generate blur placeholder (simple base64 SVG)
const blurDataURL = `data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 ${imgWidth} ${imgHeight}'%3E%3Cfilter id='b' color-interpolation-filters='sRGB'%3E%3CfeGaussianBlur stdDeviation='20'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' fill='%23e5e7eb' filter='url(%23b)'/%3E%3C/svg%3E`;

// Check if using Cloudinary
const isCloudinary = src.includes('cloudinary.com');

// Generate responsive srcset for Cloudinary
const generateSrcSet = () => {
  if (!isCloudinary) return undefined;
  
  const widths = [320, 640, 768, 1024, 1280, 1536];
  return widths
    .map(w => {
      const url = src.replace('/upload/', `/upload/w_${w},f_auto,q_auto/`);
      return `${url} ${w}w`;
    })
    .join(', ');
};

const srcSet = generateSrcSet();
const optimizedSrc = isCloudinary 
  ? src.replace('/upload/', `/upload/w_${imgWidth},f_auto,q_auto/`)
  : src;

const loadingAttr = priority ? 'eager' : loading;
const fetchPriority = priority ? 'high' : 'auto';
---

<div class={`relative overflow-hidden bg-gray-200 dark:bg-gray-800 ${className}`} style={`aspect-ratio: ${width && height ? `${width}/${height}` : '16/10'}`}>
  <!-- Blur Placeholder -->
  <img
    src={blurDataURL}
    alt=""
    class="absolute inset-0 w-full h-full blur-xl scale-110 transition-opacity duration-500"
    style={`object-fit: ${objectFit}`}
    aria-hidden="true"
    data-placeholder="true"
  />
  
  <!-- Actual Image with Responsive Support -->
  <picture>
    {isCloudinary && (
      <>
        <!-- WebP format for modern browsers -->
        <source
          type="image/webp"
          srcset={srcSet?.replace(/f_auto/g, 'f_webp')}
          sizes={sizes}
        />
        <!-- Original format fallback -->
        <source
          srcset={srcSet}
          sizes={sizes}
        />
      </>
    )}
    
    <img
      src={optimizedSrc}
      alt={alt}
      loading={loadingAttr}
      fetchpriority={fetchPriority}
      width={width}
      height={height}
      class="absolute inset-0 w-full h-full opacity-0 transition-opacity duration-500"
      style={`object-fit: ${objectFit}`}
      onload="this.style.opacity='1'; const placeholder = this.parentElement.parentElement.querySelector('[data-placeholder]'); if (placeholder) placeholder.style.opacity='0';"
      onerror="this.style.opacity='1'; this.src='https://via.placeholder.com/800x600?text=Image+Not+Found';"
    />
  </picture>
</div>

<style>
  img[loading="lazy"] {
    content-visibility: auto;
  }
  
  /* Ensure smooth loading transition */
  img[data-placeholder="true"] {
    filter: blur(20px);
  }
  
  /* Dark mode compatibility */
  .dark img[data-placeholder="true"] {
    opacity: 0.3;
  }
</style>
