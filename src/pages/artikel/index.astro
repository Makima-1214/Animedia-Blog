---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { getAllArticles, getAllCategories } from '../../lib/turso-helpers.js';
import { getAllSettings } from '../../lib/settings.js';

const allArticlesRaw = await getAllArticles();
const categories = await getAllCategories();
const settings = await getAllSettings();

const q = (Astro.url.searchParams.get('q') || '').toLowerCase().trim();
const categoryFilter = Astro.url.searchParams.get('category') || '';
const sortBy = Astro.url.searchParams.get('sort') || 'newest';

let allArticles = q
  ? allArticlesRaw.filter((a: any) =>
      a.title?.toLowerCase().includes(q) ||
      a.excerpt?.toLowerCase().includes(q)
    )
  : allArticlesRaw;

// Apply category filter
if (categoryFilter) {
  const cat = categories.find((c: any) => c.slug === categoryFilter);
  if (cat) {
    allArticles = allArticles.filter((a: any) => a.category_id === cat.id);
  }
}

// Apply sorting
if (sortBy === 'oldest') {
  allArticles = allArticles.reverse();
} else if (sortBy === 'popular') {
  allArticles = allArticles.sort((a: any, b: any) => (Number(b.views) || 0) - (Number(a.views) || 0));
} else if (sortBy === 'title') {
  allArticles = allArticles.sort((a: any, b: any) => a.title.localeCompare(b.title));
}

const PAGE_SIZE = parseInt(settings.posts_per_page || '12');
const paginationStyle = settings.pagination_style || 'numbers';
const page = Math.max(1, parseInt(Astro.url.searchParams.get('page') || '1'));
const totalPages = Math.ceil(allArticles.length / PAGE_SIZE);
const articles = allArticles.slice((page - 1) * PAGE_SIZE, page * PAGE_SIZE);
const featured = !q && page === 1 ? articles[0] : null;
const featuredCategory = featured ? categories.find((c: any) => c.id === featured.category_id) : null;
const gridArticles = featured ? articles.slice(1) : articles;

const pageNumbers: number[] = [];
for (let i = 0; i < Math.min(totalPages, 7); i++) {
  let pageNum: number;
  if (totalPages <= 7) pageNum = i + 1;
  else if (page <= 4) pageNum = i + 1;
  else if (page >= totalPages - 3) pageNum = totalPages - 6 + i;
  else pageNum = page - 3 + i;
  pageNumbers.push(pageNum);
}
---

<BaseLayout title="Semua Artikel">
  <Header />

  <main class="bg-gray-50 dark:bg-gray-950 min-h-screen">
    <!-- Hero -->
    <section class="bg-gradient-to-br from-violet-700 via-violet-600 to-blue-600 py-10 md:py-20">
      <div class="max-w-7xl mx-auto px-4 md:px-6">
        <div class="max-w-2xl mb-6 md:mb-8">
          <h1 class="text-2xl md:text-5xl font-black tracking-tight text-white mb-2 md:mb-3">
            Jelajahi Semua Artikel
          </h1>
          <p class="text-white/80 text-sm md:text-lg">
            {allArticlesRaw.length} artikel tersedia untuk kamu baca
          </p>
        </div>
        <!-- Search di hero -->
        <form action="/artikel" method="get" class="flex gap-2 max-w-xl">
          <div class="relative flex-1">
            <span class="material-symbols-outlined absolute left-3 md:left-4 top-1/2 -translate-y-1/2 text-gray-400 text-lg">search</span>
            <input
              type="text"
              name="q"
              placeholder="Cari artikel..."
              value={q}
              class="w-full pl-10 md:pl-11 pr-3 md:pr-4 py-3 md:py-3.5 bg-white dark:bg-gray-900 rounded-xl text-sm outline-none text-gray-900 dark:text-white placeholder:text-gray-400 shadow-lg"
            />
          </div>
          <button type="submit" class="bg-white text-violet-700 font-bold px-4 md:px-6 py-3 md:py-3.5 rounded-xl text-sm hover:bg-gray-100 transition-colors shadow-lg whitespace-nowrap flex-shrink-0">
            Cari
          </button>
        </form>
      </div>
    </section>

    <div class="max-w-7xl mx-auto px-3 md:px-6 py-5 md:py-10">
      <Breadcrumbs items={[
        { label: 'Artikel' }
      ]} />
      
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-6 md:gap-8">

        <!-- Main Content -->
        <div class="lg:col-span-9">

          <!-- Mobile: Stats + Kategori strip -->
          <div class="lg:hidden mb-4 space-y-3">
            <!-- Stats compact -->
            <div class="grid grid-cols-2 gap-2">
              <div class="bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-800 p-3 flex items-center gap-3">
                <div class="text-xl font-black text-violet-600">{allArticlesRaw.length}</div>
                <div class="text-xs text-gray-500 dark:text-gray-400">Artikel</div>
              </div>
              <div class="bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-800 p-3 flex items-center gap-3">
                <div class="text-xl font-black text-blue-600">{categories.length}</div>
                <div class="text-xs text-gray-500 dark:text-gray-400">Kategori</div>
              </div>
            </div>
          </div>

          <!-- Filter Tabs -->
          <div class="flex items-center gap-2 mb-6 overflow-x-auto pb-1 scrollbar-hide">
            <a href="/artikel" class={`px-4 py-2 rounded-full text-sm font-bold whitespace-nowrap transition-colors ${!q ? 'bg-violet-600 text-white' : 'bg-white dark:bg-gray-800 text-gray-600 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-gray-700 border border-gray-200 dark:border-gray-700'}`}>
              Semua
            </a>
            {categories.slice(0, 6).map((cat: any) => (
              <a
                href={`/kategori/${cat.slug}`}
                class="px-4 py-2 bg-white dark:bg-gray-800 text-gray-600 dark:text-gray-300 hover:bg-violet-50 dark:hover:bg-gray-700 hover:text-violet-600 border border-gray-200 dark:border-gray-700 rounded-full text-sm font-medium whitespace-nowrap transition-colors"
              >
                {cat.name}
              </a>
            ))}
          </div>

          <!-- Advanced Filters -->
          <div class="mb-6 bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-800 rounded-xl p-4">
            <div class="flex flex-wrap items-center gap-3">
              <span class="text-xs font-bold text-gray-600 dark:text-gray-400 uppercase tracking-wider">Filter:</span>
              
              <!-- Category Filter -->
              <select id="category-filter" class="px-3 py-1.5 bg-gray-50 dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg text-sm text-gray-700 dark:text-gray-300 focus:ring-2 focus:ring-violet-500 outline-none">
                <option value="">Semua Kategori</option>
                {categories.map((cat: any) => (
                  <option value={cat.slug} selected={categoryFilter === cat.slug}>{cat.name}</option>
                ))}
              </select>

              <!-- Sort Filter -->
              <select id="sort-filter" class="px-3 py-1.5 bg-gray-50 dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg text-sm text-gray-700 dark:text-gray-300 focus:ring-2 focus:ring-violet-500 outline-none">
                <option value="newest" selected={sortBy === 'newest'}>Terbaru</option>
                <option value="oldest" selected={sortBy === 'oldest'}>Terlama</option>
                <option value="popular" selected={sortBy === 'popular'}>Terpopuler</option>
                <option value="title" selected={sortBy === 'title'}>Judul A-Z</option>
              </select>

              <!-- Active Filters Display -->
              {(categoryFilter || sortBy !== 'newest') && (
                <div class="flex items-center gap-2 ml-auto">
                  <span class="text-xs text-gray-500 dark:text-gray-400">Filter aktif:</span>
                  {categoryFilter && (
                    <span class="bg-violet-100 dark:bg-violet-900/30 text-violet-700 dark:text-violet-300 px-2 py-1 rounded-full text-xs font-medium flex items-center gap-1">
                      {categories.find((c: any) => c.slug === categoryFilter)?.name}
                      <a href={`/artikel?${sortBy !== 'newest' ? `sort=${sortBy}` : ''}`} class="hover:text-violet-900 dark:hover:text-violet-100">×</a>
                    </span>
                  )}
                  {sortBy !== 'newest' && (
                    <span class="bg-blue-100 dark:bg-blue-900/30 text-blue-700 dark:text-blue-300 px-2 py-1 rounded-full text-xs font-medium flex items-center gap-1">
                      {sortBy === 'oldest' ? 'Terlama' : sortBy === 'popular' ? 'Terpopuler' : 'A-Z'}
                      <a href={`/artikel?${categoryFilter ? `category=${categoryFilter}` : ''}`} class="hover:text-blue-900 dark:hover:text-blue-100">×</a>
                    </span>
                  )}
                  <a href="/artikel" class="text-xs text-gray-500 dark:text-gray-400 hover:text-violet-600 dark:hover:text-violet-400 font-medium">Reset</a>
                </div>
              )}
            </div>
          </div>

          <!-- Search Result Info -->
          {q && (
            <div class="mb-6 flex items-center gap-2 bg-violet-50 dark:bg-violet-900/20 border border-violet-200 dark:border-violet-800 rounded-xl px-4 py-3 text-sm">
              <span class="material-symbols-outlined text-violet-600 text-base">search</span>
              <span class="text-gray-700 dark:text-gray-300">
                Hasil untuk <strong class="text-violet-600">"{q}"</strong> — {allArticles.length} artikel ditemukan
              </span>
              <a href="/artikel" class="ml-auto text-violet-600 hover:underline font-medium flex items-center gap-1">
                <span class="material-symbols-outlined text-sm">close</span>
                Hapus
              </a>
            </div>
          )}

          <!-- Empty State -->
          {articles.length === 0 && (
            <div class="text-center py-20">
              <span class="material-symbols-outlined text-6xl text-gray-300 dark:text-gray-700 block mb-4">search_off</span>
              <h3 class="text-xl font-bold text-gray-700 dark:text-gray-300 mb-2">Artikel tidak ditemukan</h3>
              <p class="text-gray-500 dark:text-gray-500 mb-6">Coba kata kunci lain atau lihat semua artikel</p>
              <a href="/artikel" class="inline-flex items-center gap-2 bg-violet-600 text-white px-6 py-3 rounded-xl font-bold text-sm hover:bg-violet-700 transition-colors">
                Lihat Semua Artikel
              </a>
            </div>
          )}

          <!-- Featured Article (hanya halaman 1, bukan search) -->
          {featured && (
            <a href={`/artikel/${featured.slug}`} class="group block mb-8 bg-white dark:bg-gray-900 rounded-2xl overflow-hidden border border-gray-200 dark:border-gray-800 hover:border-violet-300 dark:hover:border-violet-700 shadow-sm hover:shadow-md transition-all">
              <div class="grid md:grid-cols-2">
                <div class="relative aspect-[16/10] md:aspect-auto bg-gray-200 dark:bg-gray-800">
                  <img
                    src={featured.cover_image || 'https://via.placeholder.com/800x500'}
                    alt={featured.title}
                    class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                  />
                  <div class="absolute top-3 left-3">
                    <span class="bg-violet-600 text-white px-3 py-1 rounded-full text-xs font-bold uppercase tracking-wide">
                      Featured
                    </span>
                  </div>
                </div>
                <div class="p-6 md:p-8 flex flex-col justify-center">
                  <span class="text-xs font-bold text-violet-600 uppercase tracking-widest mb-2">{featuredCategory?.name || 'Artikel'}</span>
                  <h2 class="text-xl md:text-2xl font-black text-gray-900 dark:text-white mb-3 group-hover:text-violet-600 transition-colors line-clamp-3">
                    {featured.title}
                  </h2>
                  <p class="text-sm text-gray-500 dark:text-gray-400 line-clamp-3 mb-4">{featured.excerpt}</p>
                  <div class="flex items-center gap-4 text-xs text-gray-400 dark:text-gray-500">
                    <span class="flex items-center gap-1">
                      <span class="material-symbols-outlined text-sm">schedule</span>
                      {featured.read_time} menit
                    </span>
                    <span class="flex items-center gap-1">
                      <span class="material-symbols-outlined text-sm">visibility</span>
                      {featured.views || 0}
                    </span>
                    <span class="flex items-center gap-1">
                      <span class="material-symbols-outlined text-sm">calendar_today</span>
                      {featured.published_at ? new Date(featured.published_at).toLocaleDateString('id-ID', { day: 'numeric', month: 'short', year: 'numeric' }) : ''}
                    </span>
                  </div>
                </div>
              </div>
            </a>
          )}

          <!-- Articles Grid -->
          {gridArticles.length > 0 && (
            <div id="articles-grid" class="grid grid-cols-2 md:grid-cols-2 lg:grid-cols-3 gap-3 md:gap-5">
              {gridArticles.map((article: any) => {
                const category = categories.find((c: any) => c.id === article.category_id);
                return (
                  <a href={`/artikel/${article.slug}`} class="group bg-white dark:bg-gray-900 rounded-xl md:rounded-2xl overflow-hidden border border-gray-200 dark:border-gray-800 hover:border-violet-300 dark:hover:border-violet-700 shadow-sm hover:shadow-md transition-all flex flex-col">
                    <div class="relative aspect-[16/10] bg-gray-200 dark:bg-gray-800 overflow-hidden">
                      <img
                        src={article.cover_image || 'https://via.placeholder.com/800x500'}
                        alt={article.title}
                        class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                      />
                      <div class="absolute top-2 left-2">
                        <span class="bg-white/95 dark:bg-gray-900/95 backdrop-blur-sm text-violet-600 dark:text-violet-400 px-1.5 md:px-2.5 py-0.5 md:py-1 rounded-full text-[9px] md:text-xs font-bold uppercase tracking-wide">
                          {category?.name || 'Artikel'}
                        </span>
                      </div>
                    </div>
                    <div class="p-2.5 md:p-4 flex flex-col flex-1">
                      <h2 class="text-xs md:text-base font-bold text-gray-900 dark:text-white mb-1 md:mb-2 line-clamp-2 group-hover:text-violet-600 dark:group-hover:text-violet-400 transition-colors flex-1 leading-snug">
                        {article.title}
                      </h2>
                      <p class="text-[10px] md:text-xs text-gray-500 dark:text-gray-400 line-clamp-2 mb-2 md:mb-3 hidden sm:block">{article.excerpt}</p>
                      <div class="flex items-center gap-2 text-[10px] md:text-xs text-gray-400 dark:text-gray-500 pt-2 md:pt-3 border-t border-gray-100 dark:border-gray-800">
                        <span class="flex items-center gap-0.5">
                          <span class="material-symbols-outlined text-xs">schedule</span>
                          {article.read_time} mnt
                        </span>
                        <span class="ml-auto hidden sm:block">
                          {article.published_at ? new Date(article.published_at).toLocaleDateString('id-ID', { day: 'numeric', month: 'short' }) : ''}
                        </span>
                      </div>
                    </div>
                  </a>
                );
              })}
            </div>
          )}

          <!-- Pagination -->
          {totalPages > 1 && paginationStyle === 'numbers' && (
            <div class="mt-8 md:mt-10 flex justify-center items-center gap-1.5">
              <a
                href={page > 1 ? `/artikel?page=${page - 1}${q ? `&q=${q}` : ''}` : '#'}
                class={`p-2 rounded-lg transition-colors ${page <= 1 ? 'text-gray-300 dark:text-gray-700 pointer-events-none' : 'text-gray-700 dark:text-gray-300 hover:bg-white dark:hover:bg-gray-800 border border-gray-200 dark:border-gray-700'}`}
              >
                <span class="material-symbols-outlined">chevron_left</span>
              </a>
              {pageNumbers.map((pageNum) => (
                <a
                  href={`/artikel?page=${pageNum}${q ? `&q=${q}` : ''}`}
                  class={`w-9 h-9 md:w-10 md:h-10 flex items-center justify-center rounded-lg font-bold text-sm transition-all ${pageNum === page ? 'bg-violet-600 text-white shadow-md shadow-violet-600/30' : 'bg-white dark:bg-gray-800 text-gray-700 dark:text-gray-300 hover:bg-violet-50 dark:hover:bg-gray-700 border border-gray-200 dark:border-gray-700'}`}
                >
                  {pageNum}
                </a>
              ))}
              <a
                href={page < totalPages ? `/artikel?page=${page + 1}${q ? `&q=${q}` : ''}` : '#'}
                class={`p-2 rounded-lg transition-colors ${page >= totalPages ? 'text-gray-300 dark:text-gray-700 pointer-events-none' : 'text-gray-700 dark:text-gray-300 hover:bg-white dark:hover:bg-gray-800 border border-gray-200 dark:border-gray-700'}`}
              >
                <span class="material-symbols-outlined">chevron_right</span>
              </a>
            </div>
          )}

          {totalPages > 1 && paginationStyle === 'loadmore' && page < totalPages && (
            <div class="mt-8 md:mt-10 flex justify-center">
              <a
                href={`/artikel?page=${page + 1}${q ? `&q=${q}` : ''}`}
                class="flex items-center gap-2 bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 text-gray-700 dark:text-gray-300 hover:bg-violet-50 dark:hover:bg-gray-700 hover:text-violet-600 dark:hover:text-violet-400 font-bold px-6 py-3 rounded-xl transition-all text-sm"
              >
                <span class="material-symbols-outlined text-lg">expand_more</span>
                Muat Lebih Banyak
              </a>
            </div>
          )}

          {paginationStyle === 'infinite' && page < totalPages && (
            <div id="infinite-sentinel" class="h-10 mt-8" data-next-page={page + 1} data-q={q}></div>
          )}

          <!-- Mobile: Newsletter banner -->
          <div class="lg:hidden mt-6">
            <div class="bg-gradient-to-r from-violet-600 to-blue-600 rounded-xl p-4 flex items-center gap-4 text-white">
              <span class="material-symbols-outlined text-3xl flex-shrink-0">mail</span>
              <div class="flex-1 min-w-0">
                <p class="text-sm font-bold">Newsletter Gratis</p>
                <p class="text-xs opacity-80">Artikel terbaru langsung ke inbox kamu</p>
              </div>
              <a href="/berlangganan" class="flex-shrink-0 bg-white text-violet-600 font-bold text-xs px-3 py-2 rounded-lg hover:bg-gray-100 transition-colors whitespace-nowrap">
                Daftar
              </a>
            </div>
          </div>
        </div>

        <!-- Sidebar -->
        <aside class="hidden lg:block lg:col-span-3 space-y-5">
          <!-- Stats -->
          <div class="bg-white dark:bg-gray-900 rounded-2xl border border-gray-200 dark:border-gray-800 p-5">
            <div class="grid grid-cols-2 gap-3">
              <div class="bg-violet-50 dark:bg-violet-900/20 rounded-xl p-3 text-center">
                <div class="text-2xl font-black text-violet-600">{allArticlesRaw.length}</div>
                <div class="text-xs text-gray-500 dark:text-gray-400 mt-0.5">Artikel</div>
              </div>
              <div class="bg-blue-50 dark:bg-blue-900/20 rounded-xl p-3 text-center">
                <div class="text-2xl font-black text-blue-600">{categories.length}</div>
                <div class="text-xs text-gray-500 dark:text-gray-400 mt-0.5">Kategori</div>
              </div>
            </div>
          </div>

          <!-- Categories -->
          <div class="bg-white dark:bg-gray-900 rounded-2xl border border-gray-200 dark:border-gray-800 p-5">
            <h3 class="text-sm font-bold text-gray-900 dark:text-white mb-3 flex items-center gap-2">
              <span class="material-symbols-outlined text-violet-600 text-lg">category</span>
              Kategori
            </h3>
            <div class="space-y-1">
              {categories.map((category: any) => {
                const count = allArticlesRaw.filter((a: any) => a.category_id === category.id).length;
                return (
                  <a
                    href={`/kategori/${category.slug}`}
                    class="flex items-center justify-between py-2 px-3 rounded-xl hover:bg-violet-50 dark:hover:bg-gray-800 transition-colors group"
                  >
                    <span class="text-sm text-gray-700 dark:text-gray-300 group-hover:text-violet-600 dark:group-hover:text-violet-400 font-medium">
                      {category.name}
                    </span>
                    <span class="text-xs font-bold bg-gray-100 dark:bg-gray-800 group-hover:bg-violet-100 dark:group-hover:bg-violet-900/30 group-hover:text-violet-600 text-gray-500 px-2 py-0.5 rounded-full transition-colors">
                      {count}
                    </span>
                  </a>
                );
              })}
            </div>
          </div>

          <!-- Newsletter -->
          <div class="bg-gradient-to-br from-violet-600 to-blue-600 p-5 rounded-2xl text-white">
            <span class="material-symbols-outlined text-3xl mb-2 block">mail</span>
            <h3 class="text-base font-bold mb-1">Newsletter Gratis</h3>
            <p class="text-xs text-white/80 mb-4 leading-relaxed">
              Dapatkan artikel terbaru langsung di inbox kamu setiap minggu.
            </p>
            <a
              href="/berlangganan"
              class="block w-full bg-white text-violet-600 font-bold py-2.5 rounded-xl text-sm hover:bg-gray-100 transition-colors text-center"
            >
              Berlangganan Sekarang
            </a>
          </div>
        </aside>

      </div>
    </div>
  </main>
</BaseLayout>

<!-- Newsletter Popup -->
<div id="newsletter-popup" class="fixed inset-0 bg-black/50 backdrop-blur-sm z-[100] flex items-center justify-center p-4 opacity-0 pointer-events-none transition-opacity duration-300">
  <div id="newsletter-popup-content" class="bg-white dark:bg-gray-900 rounded-2xl max-w-md w-full p-8 relative transform scale-95 transition-transform duration-300 shadow-2xl">
    <button id="close-popup" class="absolute top-4 right-4 w-8 h-8 flex items-center justify-center rounded-full hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors">
      <span class="material-symbols-outlined text-gray-500 dark:text-gray-400">close</span>
    </button>
    
    <div class="text-center mb-6">
      <div class="w-16 h-16 bg-gradient-to-br from-violet-600 to-blue-600 rounded-full flex items-center justify-center mx-auto mb-4">
        <span class="material-symbols-outlined text-white text-3xl">mail</span>
      </div>
      <h3 class="text-2xl font-bold text-gray-900 dark:text-white mb-2">Jangan Lewatkan!</h3>
      <p class="text-gray-600 dark:text-gray-400 text-sm">
        Dapatkan artikel terbaru dan konten eksklusif langsung di inbox kamu setiap minggu.
      </p>
    </div>

    <form action="/api/subscribe" method="POST" class="space-y-3">
      <input
        type="email"
        name="email"
        required
        placeholder="Email kamu"
        class="w-full px-4 py-3 bg-gray-50 dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-xl text-gray-900 dark:text-white placeholder:text-gray-400 focus:ring-2 focus:ring-violet-500 outline-none"
      />
      <button type="submit" class="w-full bg-gradient-to-r from-violet-600 to-blue-600 text-white font-bold py-3 rounded-xl hover:from-violet-700 hover:to-blue-700 transition-all flex items-center justify-center gap-2">
        <span class="material-symbols-outlined">send</span>
        Berlangganan Gratis
      </button>
    </form>

    <p class="text-xs text-gray-500 dark:text-gray-400 text-center mt-4">
      Gratis selamanya. Bisa berhenti kapan saja.
    </p>
  </div>
</div>

<script is:inline>
  // Filter functionality
  const categoryFilter = document.getElementById('category-filter');
  const sortFilter = document.getElementById('sort-filter');
  
  function applyFilters() {
    const category = categoryFilter.value;
    const sort = sortFilter.value;
    const params = new URLSearchParams(window.location.search);
    
    if (category) params.set('category', category);
    else params.delete('category');
    
    if (sort && sort !== 'newest') params.set('sort', sort);
    else params.delete('sort');
    
    window.location.href = '/artikel' + (params.toString() ? '?' + params.toString() : '');
  }
  
  categoryFilter?.addEventListener('change', applyFilters);
  sortFilter?.addEventListener('change', applyFilters);

  // Newsletter Popup
  const popup = document.getElementById('newsletter-popup');
  const popupContent = document.getElementById('newsletter-popup-content');
  const closeBtn = document.getElementById('close-popup');
  const POPUP_STORAGE_KEY = 'newsletter_popup_shown';
  const POPUP_DELAY = 15000; // 15 seconds
  const SCROLL_THRESHOLD = 50; // 50% scroll

  function showPopup() {
    if (localStorage.getItem(POPUP_STORAGE_KEY)) return;
    popup.classList.remove('pointer-events-none');
    popup.classList.remove('opacity-0');
    popupContent.classList.remove('scale-95');
    popupContent.classList.add('scale-100');
  }

  function hidePopup() {
    popup.classList.add('opacity-0');
    popupContent.classList.add('scale-95');
    popupContent.classList.remove('scale-100');
    setTimeout(() => {
      popup.classList.add('pointer-events-none');
    }, 300);
    localStorage.setItem(POPUP_STORAGE_KEY, 'true');
  }

  // Close on button click
  closeBtn?.addEventListener('click', hidePopup);

  // Close on backdrop click
  popup?.addEventListener('click', (e) => {
    if (e.target === popup) hidePopup();
  });

  // Show after delay (time-based trigger)
  setTimeout(showPopup, POPUP_DELAY);

  // Show on scroll (scroll-based trigger)
  let scrollTriggered = false;
  window.addEventListener('scroll', () => {
    if (scrollTriggered) return;
    const scrollPercent = (window.scrollY / (document.documentElement.scrollHeight - window.innerHeight)) * 100;
    if (scrollPercent >= SCROLL_THRESHOLD) {
      scrollTriggered = true;
      showPopup();
    }
  }, { passive: true });

  // Show on exit intent (mouse leave trigger)
  let exitTriggered = false;
  document.addEventListener('mouseleave', (e) => {
    if (exitTriggered) return;
    if (e.clientY <= 0) {
      exitTriggered = true;
      showPopup();
    }
  });
</script>

{paginationStyle === 'infinite' && (
  <script is:inline>
    const sentinel = document.getElementById('infinite-sentinel');
    if (sentinel) {
      const grid = document.getElementById('articles-grid');
      let loading = false;
      const observer = new IntersectionObserver(async (entries) => {
        if (!entries[0].isIntersecting || loading) return;
        const nextPage = sentinel.dataset.nextPage;
        const q = sentinel.dataset.q || '';
        if (!nextPage) return;
        loading = true;
        sentinel.innerHTML = '<div style="display:flex;justify-content:center;padding:1rem"><span style="width:24px;height:24px;border:3px solid #7c3aed;border-top-color:transparent;border-radius:50%;animation:spin 0.8s linear infinite;display:inline-block"></span></div>';
        try {
          const res = await fetch(`/artikel?page=${nextPage}${q ? '&q=' + q : ''}`);
          const html = await res.text();
          const doc = new DOMParser().parseFromString(html, 'text/html');
          const newGrid = doc.getElementById('articles-grid');
          const newSentinel = doc.getElementById('infinite-sentinel');
          if (newGrid && grid) newGrid.querySelectorAll('a').forEach(card => grid.appendChild(card));
          if (newSentinel) { sentinel.dataset.nextPage = newSentinel.dataset.nextPage || ''; sentinel.innerHTML = ''; }
          else sentinel.remove();
        } catch { sentinel.innerHTML = ''; }
        loading = false;
      }, { rootMargin: '200px' });
      observer.observe(sentinel);
    }
  </script>
)}
