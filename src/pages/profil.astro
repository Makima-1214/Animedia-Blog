---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import { getSession, getUserById } from '../lib/simple-auth';
import db from '../lib/turso.js';

// Check if user is logged in
const token = Astro.cookies.get('session_token')?.value;
if (!token) {
  return Astro.redirect('/login');
}

const session = await getSession(token);
if (!session) {
  return Astro.redirect('/login');
}

const user: any = await getUserById(session.user_id);

// Ambil komentar user
const commentsResult = await db.execute({
  sql: `SELECT c.*, a.title as article_title, a.slug as article_slug 
        FROM comments c 
        LEFT JOIN articles a ON c.article_id = a.id 
        WHERE c.author_email = ? 
        ORDER BY c.created_at DESC 
        LIMIT 20`,
  args: [user.email]
});
const userComments = commentsResult.rows;
---

<BaseLayout title="Profil Saya">
  <Header />

  <!-- Toast -->
  <div id="toast" class="fixed bottom-4 left-4 right-4 md:bottom-auto md:top-6 md:left-auto md:right-6 md:w-auto md:min-w-[340px] z-50 transform transition-all duration-500 ease-out">
    <div class="bg-white dark:bg-gray-800 rounded-2xl shadow-2xl p-4 flex items-center gap-3 border border-gray-100 dark:border-gray-700">
      <span id="toastIcon" class="material-symbols-outlined text-2xl"></span>
      <p id="toastMessage" class="text-sm font-medium flex-1"></p>
    </div>
  </div>

  <main class="max-w-7xl mx-auto px-4 md:px-6 py-8 md:py-12">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-6 md:gap-8">
      <!-- Sidebar -->
      <aside class="lg:col-span-4">
        <div class="bg-white dark:bg-gray-900 p-6 md:p-8 rounded-2xl shadow-sm border border-gray-100 dark:border-gray-800 lg:sticky lg:top-24">
          <!-- Avatar -->
          <div class="flex flex-col items-center text-center mb-6">
            <div class="w-24 h-24 rounded-full bg-gradient-to-br from-violet-500 to-blue-500 flex items-center justify-center text-white mb-4 shadow-lg">
              <span class="material-symbols-outlined" style="font-size: 48px;">person</span>
            </div>
            <h2 class="text-2xl font-bold text-gray-900 dark:text-white">{user.name}</h2>
            <p class="text-sm text-gray-600 dark:text-gray-400">{user.email}</p>
            <div class="mt-2 flex items-center gap-2">
              {user.email_verified === 1 ? (
                <span class="text-xs bg-green-100 dark:bg-green-900/30 text-green-700 dark:text-green-400 px-2 py-1 rounded-full flex items-center gap-1">
                  <span class="material-symbols-outlined text-sm">verified</span>
                  Terverifikasi
                </span>
              ) : (
                <span class="text-xs bg-yellow-100 dark:bg-yellow-900/30 text-yellow-700 dark:text-yellow-400 px-2 py-1 rounded-full">
                  Belum Terverifikasi
                </span>
              )}
            </div>
            <p class="text-xs text-gray-500 dark:text-gray-500 mt-3">
              Bergabung {new Date(user.created_at).toLocaleDateString('id-ID', { day: 'numeric', month: 'long', year: 'numeric' })}
            </p>
          </div>

          <!-- Quick Actions -->
          <div class="flex lg:flex-col gap-1 overflow-x-auto lg:overflow-x-visible pb-1 lg:pb-0 -mx-1 px-1 lg:mx-0 lg:px-0 no-scrollbar">
            <button
              data-tab="edit"
              class="tab-btn flex-shrink-0 lg:w-full flex items-center gap-2 lg:gap-3 px-3 lg:px-4 py-2.5 lg:py-3 rounded-xl hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors text-left whitespace-nowrap"
            >
              <span class="material-symbols-outlined text-violet-600 dark:text-violet-400 text-lg">edit</span>
              <span class="font-medium text-gray-700 dark:text-gray-300 text-sm">Edit Profil</span>
            </button>
            <button
              data-tab="password"
              class="tab-btn flex-shrink-0 lg:w-full flex items-center gap-2 lg:gap-3 px-3 lg:px-4 py-2.5 lg:py-3 rounded-xl hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors text-left whitespace-nowrap"
            >
              <span class="material-symbols-outlined text-violet-600 dark:text-violet-400 text-lg">lock</span>
              <span class="font-medium text-gray-700 dark:text-gray-300 text-sm">Ganti Password</span>
            </button>
            <button
              data-tab="preferences"
              class="tab-btn flex-shrink-0 lg:w-full flex items-center gap-2 lg:gap-3 px-3 lg:px-4 py-2.5 lg:py-3 rounded-xl hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors text-left whitespace-nowrap"
            >
              <span class="material-symbols-outlined text-violet-600 dark:text-violet-400 text-lg">settings</span>
              <span class="font-medium text-gray-700 dark:text-gray-300 text-sm">Preferensi</span>
            </button>
            <button
              data-tab="comments"
              class="tab-btn flex-shrink-0 lg:w-full flex items-center gap-2 lg:gap-3 px-3 lg:px-4 py-2.5 lg:py-3 rounded-xl hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors text-left whitespace-nowrap"
            >
              <span class="material-symbols-outlined text-violet-600 dark:text-violet-400 text-lg">forum</span>
              <span class="font-medium text-gray-700 dark:text-gray-300 text-sm">Komentar</span>
              {userComments.length > 0 && (
                <span class="ml-auto text-xs font-bold bg-violet-100 dark:bg-violet-900/30 text-violet-600 dark:text-violet-400 px-2 py-0.5 rounded-full">{String(userComments.length)}</span>
              )}
            </button>
          </div>
        </div>
      </aside>

      <!-- Main Content -->
      <div class="lg:col-span-8">
        <!-- Edit Profile Tab -->
        <div id="edit-tab" class="tab-content bg-white dark:bg-gray-900 p-6 md:p-8 rounded-2xl shadow-sm border border-gray-100 dark:border-gray-800">
          <h3 class="text-xl md:text-2xl font-bold text-gray-900 dark:text-white mb-6">Edit Profil</h3>
          
          <form id="updateProfileForm" class="space-y-5">
            <div>
              <label class="text-xs font-semibold text-gray-600 dark:text-gray-400 uppercase tracking-wider mb-2 block">Nama Lengkap</label>
              <input
                type="text"
                name="name"
                value={user.name}
                required
                class="w-full px-4 py-3 bg-gray-50 dark:bg-gray-800 border-2 border-transparent rounded-xl focus:border-violet-400 focus:bg-white dark:focus:bg-gray-900 transition-all outline-none text-gray-900 dark:text-white"
              />
            </div>

            <div>
              <label class="text-xs font-semibold text-gray-600 dark:text-gray-400 uppercase tracking-wider mb-2 block">Email</label>
              <input
                type="email"
                value={user.email}
                disabled
                class="w-full px-4 py-3 bg-gray-100 dark:bg-gray-800 border-2 border-gray-200 dark:border-gray-700 rounded-xl text-gray-500 dark:text-gray-500 cursor-not-allowed"
              />
              <p class="text-xs text-gray-500 dark:text-gray-500 mt-1">Email tidak dapat diubah</p>
            </div>

            <button
              type="submit"
              class="w-full bg-gradient-to-r from-violet-600 to-blue-600 text-white py-3.5 rounded-xl font-bold hover:shadow-lg hover:shadow-violet-500/30 active:scale-[0.98] transition-all"
            >
              <span id="updateBtnText">Simpan Perubahan</span>
              <span id="updateBtnLoader" class="hidden">Menyimpan...</span>
            </button>
          </form>
        </div>

        <!-- Change Password Tab -->
        <div id="password-tab" class="tab-content hidden bg-white dark:bg-gray-900 p-6 md:p-8 rounded-2xl shadow-sm border border-gray-100 dark:border-gray-800">
          <h3 class="text-xl md:text-2xl font-bold text-gray-900 dark:text-white mb-6">Ganti Password</h3>
          
          <form id="changePasswordForm" class="space-y-5">
            <div>
              <label class="text-xs font-semibold text-gray-600 dark:text-gray-400 uppercase tracking-wider mb-2 block">Password Lama</label>
              <div class="relative">
                <input
                  type="password"
                  name="oldPassword"
                  id="oldPassword"
                  required
                  class="w-full px-4 py-3 bg-gray-50 dark:bg-gray-800 border-2 border-transparent rounded-xl focus:border-violet-400 focus:bg-white dark:focus:bg-gray-900 transition-all outline-none text-gray-900 dark:text-white pr-12"
                  placeholder="Masukkan password lama"
                />
                <button
                  type="button"
                  class="toggle-password absolute right-4 top-1/2 -translate-y-1/2 text-gray-400 hover:text-gray-600"
                  data-target="oldPassword"
                >
                  <span class="material-symbols-outlined text-xl">visibility</span>
                </button>
              </div>
            </div>

            <div>
              <label class="text-xs font-semibold text-gray-600 dark:text-gray-400 uppercase tracking-wider mb-2 block">Password Baru</label>
              <div class="relative">
                <input
                  type="password"
                  name="newPassword"
                  id="newPassword"
                  required
                  minlength="6"
                  class="w-full px-4 py-3 bg-gray-50 dark:bg-gray-800 border-2 border-transparent rounded-xl focus:border-violet-400 focus:bg-white dark:focus:bg-gray-900 transition-all outline-none text-gray-900 dark:text-white pr-12"
                  placeholder="Minimal 6 karakter"
                />
                <button
                  type="button"
                  class="toggle-password absolute right-4 top-1/2 -translate-y-1/2 text-gray-400 hover:text-gray-600"
                  data-target="newPassword"
                >
                  <span class="material-symbols-outlined text-xl">visibility</span>
                </button>
              </div>
            </div>

            <div>
              <label class="text-xs font-semibold text-gray-600 dark:text-gray-400 uppercase tracking-wider mb-2 block">Konfirmasi Password Baru</label>
              <div class="relative">
                <input
                  type="password"
                  name="confirmPassword"
                  id="confirmPassword"
                  required
                  minlength="6"
                  class="w-full px-4 py-3 bg-gray-50 dark:bg-gray-800 border-2 border-transparent rounded-xl focus:border-violet-400 focus:bg-white dark:focus:bg-gray-900 transition-all outline-none text-gray-900 dark:text-white pr-12"
                  placeholder="Ulangi password baru"
                />
                <button
                  type="button"
                  class="toggle-password absolute right-4 top-1/2 -translate-y-1/2 text-gray-400 hover:text-gray-600"
                  data-target="confirmPassword"
                >
                  <span class="material-symbols-outlined text-xl">visibility</span>
                </button>
              </div>
            </div>

            <button
              type="submit"
              class="w-full bg-gradient-to-r from-violet-600 to-blue-600 text-white py-3.5 rounded-xl font-bold hover:shadow-lg hover:shadow-violet-500/30 active:scale-[0.98] transition-all"
            >
              <span id="passwordBtnText">Ganti Password</span>
              <span id="passwordBtnLoader" class="hidden">Memproses...</span>
            </button>
          </form>
        </div>

        <!-- Preferences Tab -->
        <div id="preferences-tab" class="tab-content hidden bg-white dark:bg-gray-900 p-6 md:p-8 rounded-2xl shadow-sm border border-gray-100 dark:border-gray-800">
          <h3 class="text-xl md:text-2xl font-bold text-gray-900 dark:text-white mb-6">Preferensi</h3>
          
          <div class="space-y-6">
            <!-- Newsletter -->
            <div class="flex items-start justify-between p-4 bg-gray-50 dark:bg-gray-800 rounded-xl">
              <div class="flex-1">
                <h4 class="font-semibold text-gray-900 dark:text-white mb-1">Newsletter</h4>
                <p class="text-sm text-gray-600 dark:text-gray-400">Terima update artikel terbaru via email</p>
              </div>
              <label class="relative inline-flex items-center cursor-pointer">
                <input type="checkbox" id="newsletterToggle" class="sr-only peer" checked>
                <div class="w-11 h-6 bg-gray-300 peer-focus:outline-none peer-focus:ring-4 peer-focus:ring-violet-300 dark:peer-focus:ring-violet-800 rounded-full peer dark:bg-gray-700 peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all dark:border-gray-600 peer-checked:bg-violet-600"></div>
              </label>
            </div>

            <!-- Theme -->
            <div class="p-4 bg-gray-50 dark:bg-gray-800 rounded-xl">
              <h4 class="font-semibold text-gray-900 dark:text-white mb-3">Tema</h4>
              <div class="flex gap-3">
                <button class="theme-btn flex-1 p-3 rounded-lg border-2 border-gray-200 dark:border-gray-700 hover:border-violet-400 transition-colors" data-theme="light">
                  <span class="material-symbols-outlined text-2xl mb-1">light_mode</span>
                  <p class="text-sm font-medium">Terang</p>
                </button>
                <button class="theme-btn flex-1 p-3 rounded-lg border-2 border-gray-200 dark:border-gray-700 hover:border-violet-400 transition-colors" data-theme="dark">
                  <span class="material-symbols-outlined text-2xl mb-1">dark_mode</span>
                  <p class="text-sm font-medium">Gelap</p>
                </button>
                <button class="theme-btn flex-1 p-3 rounded-lg border-2 border-gray-200 dark:border-gray-700 hover:border-violet-400 transition-colors" data-theme="auto">
                  <span class="material-symbols-outlined text-2xl mb-1">brightness_auto</span>
                  <p class="text-sm font-medium">Auto</p>
                </button>
              </div>
            </div>

            <!-- Danger Zone -->
            <div class="p-4 bg-red-50 dark:bg-red-900/20 rounded-xl border-2 border-red-200 dark:border-red-800">
              <h4 class="font-semibold text-red-900 dark:text-red-400 mb-2">Zona Berbahaya</h4>
              <p class="text-sm text-red-700 dark:text-red-400 mb-4">Tindakan ini tidak dapat dibatalkan</p>
              <button
                id="deleteAccountBtn"
                class="px-4 py-2 bg-red-600 text-white rounded-lg font-semibold hover:bg-red-700 transition-colors text-sm"
              >
                Hapus Akun
              </button>
            </div>
          </div>
        </div>

        <!-- Comments Tab -->
        <div id="comments-tab" class="tab-content hidden bg-white dark:bg-gray-900 p-6 md:p-8 rounded-2xl shadow-sm border border-gray-100 dark:border-gray-800">
          <h3 class="text-xl md:text-2xl font-bold text-gray-900 dark:text-white mb-6">Komentar Saya</h3>
          {userComments.length === 0 ? (
            <div class="text-center py-12">
              <span class="material-symbols-outlined text-5xl text-gray-300 dark:text-gray-700 block mb-3">forum</span>
              <p class="text-gray-500 dark:text-gray-400">Belum ada komentar</p>
              <a href="/artikel" class="mt-4 inline-block text-sm text-violet-600 dark:text-violet-400 hover:underline">Mulai berdiskusi di artikel</a>
            </div>
          ) : (
            <div class="space-y-4">
              {userComments.map((c: any) => (
                <div class="p-4 bg-gray-50 dark:bg-gray-800 rounded-xl border border-gray-200 dark:border-gray-700">
                  <div class="flex items-start justify-between gap-3 mb-2">
                    <a href={`/artikel/${c.article_slug}`} class="text-sm font-bold text-violet-600 dark:text-violet-400 hover:underline line-clamp-1 flex-1">
                      {c.article_title || 'Artikel'}
                    </a>
                    <span class="text-xs text-gray-400 dark:text-gray-500 whitespace-nowrap flex-shrink-0">
                      {new Date(c.created_at).toLocaleDateString('id-ID', { day: 'numeric', month: 'short', year: 'numeric' })}
                    </span>
                  </div>
                  <p class="text-sm text-gray-700 dark:text-gray-300 leading-relaxed">{c.content}</p>
                  {c.parent_id && (
                    <span class="mt-2 inline-flex items-center gap-1 text-xs text-gray-400 dark:text-gray-500">
                      <span class="material-symbols-outlined text-sm">reply</span> Balasan
                    </span>
                  )}
                </div>
              ))}
            </div>
          )}
        </div>
      </div>
    </div>
  </main>

  <script is:inline>
    // Toast function
    function showToast(message, type = 'success') {
      const toast = document.getElementById('toast');
      const toastIcon = document.getElementById('toastIcon');
      const toastMessage = document.getElementById('toastMessage');
      
      if (type === 'success') {
        toastIcon.textContent = 'check_circle';
        toastIcon.className = 'material-symbols-outlined text-2xl text-emerald-500';
      } else {
        toastIcon.textContent = 'error';
        toastIcon.className = 'material-symbols-outlined text-2xl text-rose-500';
      }
      
      toastMessage.textContent = message;

      const isMobile = window.innerWidth < 768;
      toast.style.transform = isMobile ? 'translateY(0)' : 'translateX(0)';
      
      setTimeout(() => {
        toast.style.transform = isMobile ? 'translateY(100px)' : 'translateX(420px)';
      }, 4000);
    }

    // Set initial hidden state based on viewport
    (function() {
      const toast = document.getElementById('toast');
      if (window.innerWidth < 768) {
        toast.style.transform = 'translateY(100px)';
      } else {
        toast.style.transform = 'translateX(420px)';
      }
    })();

    // Tab switching
    const tabBtns = document.querySelectorAll('.tab-btn');
    const tabContents = document.querySelectorAll('.tab-content');
    
    tabBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        const tab = btn.dataset.tab;
        
        // Remove active state
        tabBtns.forEach(b => b.classList.remove('bg-violet-100', 'dark:bg-violet-900/30'));
        tabContents.forEach(c => c.classList.add('hidden'));
        
        // Add active state
        btn.classList.add('bg-violet-100', 'dark:bg-violet-900/30');
        document.getElementById(`${tab}-tab`).classList.remove('hidden');
      });
    });
    
    // Set first tab as active
    tabBtns[0]?.click();

    // Toggle password visibility
    document.querySelectorAll('.toggle-password').forEach(btn => {
      btn.addEventListener('click', () => {
        const targetId = btn.dataset.target;
        const input = document.getElementById(targetId);
        const icon = btn.querySelector('span');
        
        if (input.type === 'password') {
          input.type = 'text';
          icon.textContent = 'visibility_off';
        } else {
          input.type = 'password';
          icon.textContent = 'visibility';
        }
      });
    });

    // Update profile
    const updateForm = document.getElementById('updateProfileForm');
    updateForm?.addEventListener('submit', async (e) => {
      e.preventDefault();
      
      const name = updateForm.querySelector('input[name="name"]').value.trim();
      const btnText = document.getElementById('updateBtnText');
      const btnLoader = document.getElementById('updateBtnLoader');
      const submitBtn = updateForm.querySelector('button[type="submit"]');
      
      btnText.classList.add('hidden');
      btnLoader.classList.remove('hidden');
      submitBtn.disabled = true;
      
      try {
        const response = await fetch('/api/auth/update-profile', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ name })
        });
        
        const result = await response.json();
        
        if (result.success) {
          showToast(result.message, 'success');
          setTimeout(() => window.location.reload(), 1500);
        } else {
          showToast(result.message, 'error');
        }
      } catch (error) {
        showToast('Terjadi kesalahan: ' + error.message, 'error');
      } finally {
        btnText.classList.remove('hidden');
        btnLoader.classList.add('hidden');
        submitBtn.disabled = false;
      }
    });

    // Change password
    const passwordForm = document.getElementById('changePasswordForm');
    passwordForm?.addEventListener('submit', async (e) => {
      e.preventDefault();
      
      const oldPassword = passwordForm.querySelector('input[name="oldPassword"]').value;
      const newPassword = passwordForm.querySelector('input[name="newPassword"]').value;
      const confirmPassword = passwordForm.querySelector('input[name="confirmPassword"]').value;
      
      if (newPassword !== confirmPassword) {
        showToast('Password baru tidak cocok', 'error');
        return;
      }
      
      const btnText = document.getElementById('passwordBtnText');
      const btnLoader = document.getElementById('passwordBtnLoader');
      const submitBtn = passwordForm.querySelector('button[type="submit"]');
      
      btnText.classList.add('hidden');
      btnLoader.classList.remove('hidden');
      submitBtn.disabled = true;
      
      try {
        const response = await fetch('/api/auth/change-password', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ oldPassword, newPassword })
        });
        
        const result = await response.json();
        
        if (result.success) {
          showToast(result.message, 'success');
          passwordForm.reset();
        } else {
          showToast(result.message, 'error');
        }
      } catch (error) {
        showToast('Terjadi kesalahan: ' + error.message, 'error');
      } finally {
        btnText.classList.remove('hidden');
        btnLoader.classList.add('hidden');
        submitBtn.disabled = false;
      }
    });

    // Theme switcher
    document.querySelectorAll('.theme-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const theme = btn.dataset.theme;
        const html = document.documentElement;
        
        if (theme === 'dark') {
          html.classList.add('dark');
          localStorage.setItem('theme', 'dark');
        } else if (theme === 'light') {
          html.classList.remove('dark');
          localStorage.setItem('theme', 'light');
        } else {
          localStorage.removeItem('theme');
          if (window.matchMedia('(prefers-color-scheme: dark)').matches) {
            html.classList.add('dark');
          } else {
            html.classList.remove('dark');
          }
        }
        
        showToast('Tema berhasil diubah', 'success');
      });
    });

    // Delete account
    const deleteBtn = document.getElementById('deleteAccountBtn');
    deleteBtn?.addEventListener('click', async () => {
      const input = prompt('Ketik "HAPUS" untuk konfirmasi penghapusan akun:');
      if (input !== 'HAPUS') {
        if (input !== null) showToast('Konfirmasi tidak sesuai', 'error');
        return;
      }

      deleteBtn.disabled = true;
      deleteBtn.textContent = 'Menghapus...';

      try {
        const res = await fetch('/api/auth/delete-account', { method: 'POST' });
        const result = await res.json();
        if (result.success) {
          window.location.href = '/';
        } else {
          showToast(result.message || 'Gagal menghapus akun', 'error');
          deleteBtn.disabled = false;
          deleteBtn.textContent = 'Hapus Akun';
        }
      } catch {
        showToast('Terjadi kesalahan', 'error');
        deleteBtn.disabled = false;
        deleteBtn.textContent = 'Hapus Akun';
      }
    });
  </script>
</BaseLayout>
