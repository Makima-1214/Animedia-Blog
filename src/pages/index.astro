---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import { getAllArticles, getAllCategories } from '../lib/turso-helpers.js';
import { getSetting } from '../lib/settings.js';

const articles = await getAllArticles();
const categories = await getAllCategories();
const breakingNews = await getSetting('breaking_news') || '';
const featuredArticle = articles[0];
const trendingArticles = articles.slice(0, 5);
---

<BaseLayout title="Berita Teknologi, Game, Anime & Gadget Terkini" description="Portal berita teknologi, game, anime, film, dan gadget terkini. Temukan artikel terbaru dan terpercaya di Animedia.">
  <Header />
  
  <main class="bg-gray-50 dark:bg-gray-950">
    <!-- Breaking News Ticker -->
    {breakingNews && (
    <div class="bg-red-600 dark:bg-red-700 text-white py-2 px-4">
      <div class="max-w-7xl mx-auto flex items-center gap-3">
        <span class="bg-white text-red-600 dark:text-red-700 text-xs font-black px-2 py-1 rounded uppercase whitespace-nowrap">
          Breaking
        </span>
        <div class="text-xs md:text-sm font-medium overflow-hidden">
          <div class="animate-marquee whitespace-nowrap">
            {breakingNews}
          </div>
        </div>
      </div>
    </div>
    )}

    <div class="max-w-7xl mx-auto px-3 md:px-4 py-4 md:py-6">

      <!-- ═══════════════════════════════════════════════════════
           HERO ARTICLE — overlay style (mobile-first)
      ════════════════════════════════════════════════════════ -->
      {featuredArticle && (
        <article class="relative rounded-xl overflow-hidden mb-4 md:mb-6 shadow-md">
          <a href={`/artikel/${featuredArticle.slug}`} class="block">
            <!-- Image -->
            <div class="relative h-64 sm:h-80 md:h-[420px] overflow-hidden">
              <img
                src={String(featuredArticle.cover_image || 'https://via.placeholder.com/800x400')}
                alt={String(featuredArticle.title)}
                class="w-full h-full object-cover scale-100 hover:scale-105 transition-transform duration-700"
              />
              <!-- Gradient overlay -->
              <div class="absolute inset-0 bg-gradient-to-t from-black/85 via-black/30 to-transparent"></div>
            </div>
            <!-- Text overlay -->
            <div class="absolute bottom-0 left-0 right-0 p-4 md:p-6">
              <div class="flex items-center gap-2 mb-2">
                <span class="bg-violet-600 text-white text-[10px] font-black px-2 py-0.5 rounded uppercase tracking-wider">
                  Headline
                </span>
                {categories.find((c: any) => c.id === featuredArticle.category_id) && (
                  <span class="bg-white/20 backdrop-blur-sm text-white text-[10px] font-bold px-2 py-0.5 rounded uppercase tracking-wider">
                    {categories.find((c: any) => c.id === featuredArticle.category_id)?.name}
                  </span>
                )}
              </div>
              <h1 class="text-lg sm:text-2xl md:text-3xl font-black text-white leading-tight mb-2 line-clamp-3">
                {featuredArticle.title}
              </h1>
              <p class="text-white/75 text-xs sm:text-sm line-clamp-2 mb-3 hidden sm:block">
                {featuredArticle.excerpt}
              </p>
              <div class="flex items-center gap-3 text-white/60 text-xs">
                <span>
                  {featuredArticle.published_at
                    ? new Date(String(featuredArticle.published_at)).toLocaleDateString('id-ID', { day: 'numeric', month: 'short', year: 'numeric' })
                    : ''}
                </span>
                <span>•</span>
                <span>{featuredArticle.read_time} menit baca</span>
              </div>
            </div>
          </a>
        </article>
      )}

      <!-- ═══════════════════════════════════════════════════════
           MOBILE ONLY: Trending horizontal strip
      ════════════════════════════════════════════════════════ -->
      <div class="lg:hidden mb-4">
        <div class="flex items-center gap-2 mb-2.5">
          <span class="text-xs font-black uppercase tracking-widest text-gray-500 dark:text-gray-400">🔥 Trending</span>
          <div class="flex-1 h-px bg-gray-200 dark:bg-gray-800"></div>
        </div>
        <div class="flex gap-3 overflow-x-auto no-scrollbar pb-1">
          {trendingArticles.map((article: any, index: number) => (
            <a
              href={`/artikel/${article.slug}`}
              class="flex-shrink-0 w-36 group"
            >
              <div class="relative rounded-lg overflow-hidden h-20 mb-1.5 bg-gray-200 dark:bg-gray-800">
                <img
                  src={article.cover_image || 'https://via.placeholder.com/200x150'}
                  alt={article.title}
                  class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                />
                <div class="absolute top-1.5 left-1.5 w-5 h-5 bg-black/60 rounded text-white text-[10px] font-black flex items-center justify-center">
                  {index + 1}
                </div>
              </div>
              <p class="text-xs font-semibold text-gray-800 dark:text-gray-200 line-clamp-2 leading-snug group-hover:text-violet-600 dark:group-hover:text-violet-400 transition-colors">
                {article.title}
              </p>
            </a>
          ))}
        </div>
      </div>

      <!-- ═══════════════════════════════════════════════════════
           MOBILE ONLY: Kategori horizontal pill strip
      ════════════════════════════════════════════════════════ -->
      <div class="lg:hidden mb-4 flex gap-2 overflow-x-auto no-scrollbar pb-1">
        <a href="/artikel" class="flex-shrink-0 px-3 py-1.5 bg-violet-600 text-white text-xs font-bold rounded-full">
          Semua
        </a>
        {categories.map((cat: any) => (
          <a
            href={`/kategori/${cat.slug}`}
            class="flex-shrink-0 px-3 py-1.5 bg-white dark:bg-gray-800 text-gray-700 dark:text-gray-300 text-xs font-semibold rounded-full border border-gray-200 dark:border-gray-700 hover:border-violet-400 hover:text-violet-600 dark:hover:text-violet-400 transition-colors"
          >
            {cat.name}
          </a>
        ))}
      </div>

      <!-- ═══════════════════════════════════════════════════════
           MAIN GRID
      ════════════════════════════════════════════════════════ -->
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-4 md:gap-6">

        <!-- Main Content -->
        <div class="lg:col-span-2 space-y-4 md:space-y-6">

          <!-- Article Grid: 2 kolom di mobile, 2 kolom di desktop -->
          <div class="grid grid-cols-2 md:grid-cols-2 gap-3 md:gap-4">
            {articles.slice(1, 7).map((article: any) => (
              <article class="bg-white dark:bg-gray-900 rounded-xl overflow-hidden shadow-sm hover:shadow-md transition-shadow group">
                <a href={`/artikel/${article.slug}`} class="block">
                  <div class="relative aspect-[16/10] overflow-hidden bg-gray-100 dark:bg-gray-800">
                    <img
                      src={article.cover_image || 'https://via.placeholder.com/400x250'}
                      alt={article.title}
                      class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                    />
                    <div class="absolute top-2 left-2">
                      <span class="bg-white/90 dark:bg-gray-900/90 backdrop-blur-sm text-violet-600 dark:text-violet-400 text-[9px] font-black px-1.5 py-0.5 rounded uppercase tracking-wide">
                        {categories.find((c: any) => c.id === article.category_id)?.name || 'Artikel'}
                      </span>
                    </div>
                  </div>
                  <div class="p-2.5 md:p-3">
                    <h3 class="text-xs md:text-sm font-bold text-gray-900 dark:text-white line-clamp-2 leading-snug group-hover:text-violet-600 dark:group-hover:text-violet-400 transition-colors mb-1.5">
                      {article.title}
                    </h3>
                    <span class="text-[10px] text-gray-400 dark:text-gray-500">{article.read_time} mnt baca</span>
                  </div>
                </a>
              </article>
            ))}
          </div>

          <!-- More Articles List — horizontal card style -->
          <div class="bg-white dark:bg-gray-900 rounded-xl shadow-sm overflow-hidden">
            <div class="px-4 py-3 border-b border-gray-100 dark:border-gray-800 flex items-center justify-between">
              <h2 class="text-sm md:text-base font-black text-gray-900 dark:text-white">Berita Terbaru</h2>
              <a href="/artikel" class="text-xs font-semibold text-violet-600 dark:text-violet-400 hover:underline">Lihat semua</a>
            </div>
            <div class="divide-y divide-gray-100 dark:divide-gray-800">
              {(articles.length > 7 ? articles.slice(7, 15) : articles.slice(0, 8)).map((article: any) => (
                <a href={`/artikel/${article.slug}`} class="flex gap-3 p-3 md:p-4 hover:bg-gray-50 dark:hover:bg-gray-800/50 transition-colors group">
                  <div class="w-16 h-14 md:w-24 md:h-16 flex-shrink-0 rounded-lg overflow-hidden bg-gray-100 dark:bg-gray-800">
                    <img
                      src={article.cover_image || 'https://via.placeholder.com/200x150'}
                      alt={article.title}
                      class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-300"
                    />
                  </div>
                  <div class="flex-1 min-w-0 flex flex-col justify-center">
                    <h3 class="text-xs md:text-sm font-semibold text-gray-900 dark:text-white line-clamp-2 group-hover:text-violet-600 dark:group-hover:text-violet-400 transition-colors leading-snug mb-1">
                      {article.title}
                    </h3>
                    <div class="flex items-center gap-2 text-[10px] text-gray-400 dark:text-gray-500">
                      <span class="text-violet-500 dark:text-violet-400 font-semibold">
                        {categories.find((c: any) => c.id === article.category_id)?.name || 'Artikel'}
                      </span>
                      <span>·</span>
                      <span>{article.read_time} mnt</span>
                    </div>
                  </div>
                </a>
              ))}
            </div>
          </div>
        </div>

        <!-- ═══════════════════════════════════════════════════
             SIDEBAR — desktop only
        ════════════════════════════════════════════════════ -->
        <aside class="hidden lg:block space-y-4 md:space-y-6">
          <!-- Trending -->
          <div class="bg-white dark:bg-gray-900 rounded-xl shadow-sm p-4 md:p-5">
            <h3 class="text-sm md:text-base font-bold text-gray-900 dark:text-white mb-3 md:mb-4 pb-2 border-b-2 border-red-500">
              🔥 Trending
            </h3>
            <div class="space-y-3 md:space-y-4">
              {trendingArticles.map((article: any, index: number) => (
                <article class="flex gap-3">
                  <a href={`/artikel/${article.slug}`} class="flex gap-3 w-full group">
                    <span class="text-xl md:text-2xl font-black text-gray-200 dark:text-gray-700 group-hover:text-violet-600 dark:group-hover:text-violet-400 transition-colors w-6 md:w-8 flex-shrink-0">
                      {(index + 1).toString().padStart(2, '0')}
                    </span>
                    <div class="flex-1 min-w-0">
                      <h4 class="text-sm font-semibold text-gray-900 dark:text-white line-clamp-2 md:line-clamp-3 group-hover:text-violet-600 dark:group-hover:text-violet-400 transition-colors leading-snug">
                        {article.title}
                      </h4>
                      <div class="flex items-center gap-2 mt-1 text-xs text-gray-500 dark:text-gray-500">
                        <span class="material-symbols-outlined text-sm">visibility</span>
                        <span>{article.views || 0} views</span>
                      </div>
                    </div>
                  </a>
                </article>
              ))}
            </div>
          </div>

          <!-- Categories -->
          <div class="bg-white dark:bg-gray-900 rounded-xl shadow-sm p-4 md:p-5">
            <h3 class="text-sm md:text-base font-bold text-gray-900 dark:text-white mb-3 md:mb-4 pb-2 border-b-2 border-blue-500">
              📂 Kategori
            </h3>
            <div class="space-y-1 md:space-y-2">
              {categories.map((category: any) => (
                <a
                  href={`/kategori/${category.slug}`}
                  class="flex items-center justify-between py-2 px-3 rounded-lg hover:bg-gray-50 dark:hover:bg-gray-800 transition-colors group"
                >
                  <span class="text-sm font-medium text-gray-700 dark:text-gray-300 group-hover:text-violet-600 dark:group-hover:text-violet-400">
                    {category.name}
                  </span>
                  <span class="text-xs font-semibold text-gray-400 dark:text-gray-600">
                    {articles.filter((a: any) => a.category_id === category.id).length}
                  </span>
                </a>
              ))}
            </div>
          </div>

          <!-- Newsletter -->
          <div class="bg-gradient-to-br from-violet-600 to-blue-600 rounded-xl shadow-sm p-5 md:p-6 text-white">
            <div class="text-center">
              <span class="material-symbols-outlined text-3xl md:text-4xl mb-2 md:mb-3 block">mail</span>
              <h3 class="text-base md:text-lg font-bold mb-2">Newsletter</h3>
              <p class="text-sm opacity-90 mb-3 md:mb-4">
                Dapatkan berita terbaru langsung di inbox Anda
              </p>
              <a
                href="/berlangganan"
                class="block w-full bg-white text-violet-600 font-bold py-2.5 md:py-3 rounded-lg text-sm hover:bg-gray-100 transition-colors"
              >
                Berlangganan Gratis
              </a>
            </div>
          </div>

          <!-- Lihat semua -->
          <div class="bg-gradient-to-br from-violet-600 to-blue-600 rounded-xl shadow-sm p-5 text-white text-center">
            <span class="material-symbols-outlined text-3xl mb-2 block">auto_stories</span>
            <p class="text-sm font-bold mb-1">Baca lebih banyak</p>
            <a href="/artikel" class="text-xs underline opacity-80 hover:opacity-100">Lihat semua artikel</a>
          </div>
        </aside>
      </div>

      <!-- ═══════════════════════════════════════════════════════
           MOBILE ONLY: Newsletter banner di bawah
      ════════════════════════════════════════════════════════ -->
      <div class="lg:hidden mt-4">
        <div class="bg-gradient-to-r from-violet-600 to-blue-600 rounded-xl p-4 flex items-center gap-4 text-white">
          <span class="material-symbols-outlined text-3xl flex-shrink-0">mail</span>
          <div class="flex-1 min-w-0">
            <p class="text-sm font-bold">Newsletter Gratis</p>
            <p class="text-xs opacity-80">Artikel terbaru langsung ke inbox kamu</p>
          </div>
          <a href="/berlangganan" class="flex-shrink-0 bg-white text-violet-600 font-bold text-xs px-3 py-2 rounded-lg hover:bg-gray-100 transition-colors whitespace-nowrap">
            Daftar
          </a>
        </div>
      </div>

    </div>
  </main>

  <style>
    @keyframes marquee {
      0% { transform: translateX(0); }
      100% { transform: translateX(-50%); }
    }
    .animate-marquee {
      display: inline-block;
      animation: marquee 20s linear infinite;
    }
  </style>
</BaseLayout>
