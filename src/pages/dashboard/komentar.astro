---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
import { getAllComments, getCommentStats, getArticleById } from '../../lib/turso-helpers.js';

const comments = await getAllComments();
const commentStats = await getCommentStats();

const enrichedComments = await Promise.all(comments.map(async (c: any) => {
  const article = await getArticleById(c.article_id);
  return { ...c, articleSlug: article?.slug || null, articleTitle: article?.title || `Artikel #${c.article_id}` };
}));
---

<DashboardLayout title="Kelola Komentar - Admin Panel" activePage="komentar">
  <div class="p-8 lg:p-12">
      <!-- Page Header -->
      <div class="mb-16">
        <h2 class="text-4xl font-extrabold tracking-tight text-on-background mb-4">Moderasi Komentar</h2>
        <p class="text-on-surface-variant max-w-xl leading-relaxed">
          Tinjau keterlibatan pembaca terbaru. Jaga kualitas diskusi dengan memoderasi komentar yang sesuai standar editorial.
        </p>
      </div>

      <!-- Stats Bar -->
      <div class="grid grid-cols-1 gap-4 mb-12 max-w-xs">
        <div class="bg-surface-container-low p-6 rounded-lg">
          <p class="text-xs font-bold text-on-surface-variant tracking-widest uppercase mb-2">Total Komentar</p>
          <p class="text-3xl font-headline font-extrabold">{commentStats.total}</p>
        </div>
      </div>

      <!-- Moderation List -->
      <div class="space-y-0">
        {enrichedComments.map((comment: any) => (
          <div class="group py-12 flex flex-col md:flex-row gap-12 hover:bg-surface-container-low transition-all duration-300 px-6 -mx-6 border-t border-outline-variant/10 first:border-t-0">
            <div class="md:w-1/4">
              <div class="flex items-start gap-4">
                <div class="w-12 h-12 rounded-full overflow-hidden bg-stone-200 flex items-center justify-center">
                  <span class="material-symbols-outlined text-outline-variant">person</span>
                </div>
                <div>
                  <h4 class="font-bold text-on-background">{comment.author_name}</h4>
                  <p class="text-xs text-on-surface-variant">{comment.author_email}</p>
                  <span class="inline-block mt-3 px-2 py-0.5 text-[10px] font-bold uppercase tracking-wider rounded bg-surface-container text-on-secondary-container">
                    Komentar
                  </span>
                </div>
              </div>
              <p class="mt-6 text-xs font-medium text-outline">{new Date(comment.created_at).toLocaleDateString('id-ID', { day: 'numeric', month: 'short', year: 'numeric' })} • {new Date(comment.created_at).toLocaleTimeString('id-ID', { hour: '2-digit', minute: '2-digit' })}</p>
            </div>
            <div class="md:w-1/2">
              <div class="mb-4">
                <p class="text-xs font-bold text-tertiary mb-1">RE: Artikel</p>
                {comment.articleSlug 
                  ? <a class="text-sm font-semibold hover:underline underline-offset-4 decoration-outline-variant" href={`/artikel/${comment.articleSlug}`}>{comment.articleTitle}</a>
                  : <span class="text-sm font-semibold text-on-surface-variant">{comment.articleTitle}</span>
                }
              </div>
              <p class="text-lg text-on-surface leading-relaxed font-body italic">
                "{comment.content}"
              </p>
            </div>
            <div class="md:w-1/4 flex md:flex-col justify-end items-end gap-3">
              <button onclick={`deleteComment('${comment.id}')`} class="w-full py-2 px-4 text-error font-medium text-xs rounded hover:bg-error/5 transition-all flex items-center justify-center gap-2">
                <span class="material-symbols-outlined text-sm">delete</span> Hapus
              </button>
            </div>
          </div>
        ))}
      </div>

      <!-- Pagination removed - all comments shown, no pagination needed for admin -->
    </div>
</DashboardLayout>


  <script>
    async function deleteComment(id: string) {
      (window as any).showConfirm({
        title: 'Hapus Komentar?',
        message: 'Komentar ini akan dihapus permanen.',
        okText: 'Hapus',
        okIcon: 'delete',
        okClass: 'bg-red-500 hover:bg-red-600',
        iconBg: 'bg-red-100',
        iconColor: 'text-red-500',
        icon: 'delete'
      }, async (confirmed) => {
        if (!confirmed) return;
        try {
          const formData = new FormData();
          formData.append('id', id);
          const response = await fetch('/api/comments/delete', { method: 'POST', body: formData });
          const result = await response.json();
          if (result.success) {
            alert('✅ Komentar berhasil dihapus!');
            window.location.reload();
          } else {
            alert('❌ Error: ' + result.message);
          }
        } catch (error) {
          alert('❌ Terjadi kesalahan: ' + error);
        }
      });
    }

    // Make functions available globally
    (window as any).deleteComment = deleteComment;
  </script>
