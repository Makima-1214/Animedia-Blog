---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import { getArticlesByCategory, getCategoryBySlug, getAllCategories, getAllArticles, getAllTags } from '../../lib/turso-helpers.js';

const { slug } = Astro.params;
if (!slug) return Astro.redirect('/');

const category: any = await getCategoryBySlug(slug);
if (!category) return Astro.redirect('/');

const allArticles = await getArticlesByCategory(category.id);
const allCategories = await getAllCategories();
const allArticlesAll = await getAllArticles();
const allTags: any[] = await getAllTags();

const PAGE_SIZE = 10;
const page = Math.max(1, parseInt(Astro.url.searchParams.get('page') || '1'));
const totalPages = Math.ceil(allArticles.length / PAGE_SIZE);
const articles = allArticles.slice((page - 1) * PAGE_SIZE, page * PAGE_SIZE);

const title = `${category.name} - Animedia`;
const description = category.description || `Artikel tentang ${category.name}`;
---

<BaseLayout title={title} description={description}>
  <Header />

  <!-- Mobile horizontal strip: Kategori pills + Tag pills (hidden on lg+) -->
  <div class="lg:hidden border-b border-gray-200 dark:border-gray-800 bg-white dark:bg-gray-950">
    <!-- Kategori pills -->
    <div class="px-3 pt-3 pb-1">
      <p class="text-[10px] font-black tracking-widest text-gray-500 dark:text-gray-400 uppercase mb-2">Kategori</p>
      <div class="flex gap-2 overflow-x-auto pb-2 scrollbar-hide">
        {allCategories.map((cat: any) => (
          <a
            href={`/kategori/${cat.slug}`}
            class={`shrink-0 px-3 py-1 rounded-full text-xs font-bold transition-all ${
              cat.id === category.id
                ? 'bg-blue-600 text-white dark:bg-blue-500'
                : 'bg-gray-100 dark:bg-gray-800 text-gray-600 dark:text-gray-300 border border-gray-200 dark:border-gray-700 hover:border-blue-500 hover:text-blue-600 dark:hover:text-blue-400'
            }`}
          >{cat.name}</a>
        ))}
      </div>
    </div>
    <!-- Tag pills -->
    {allTags.length > 0 && (
      <div class="px-3 pb-3">
        <p class="text-[10px] font-black tracking-widest text-gray-500 dark:text-gray-400 uppercase mb-2">Tags</p>
        <div class="flex gap-2 overflow-x-auto pb-1 scrollbar-hide">
          {allTags.slice(0, 8).map((tag: any) => (
            <a
              href={`/tag/${tag.slug}`}
              class="shrink-0 px-3 py-1 bg-white dark:bg-gray-800 text-gray-600 dark:text-gray-300 text-xs font-semibold rounded-full border border-gray-200 dark:border-gray-700 hover:border-blue-500 hover:text-blue-600 dark:hover:text-blue-400 transition-all"
            >#{tag.name}</a>
          ))}
        </div>
      </div>
    )}
  </div>

  <!-- Main Content Canvas -->
  <main class="flex-grow max-w-7xl mx-auto px-3 md:px-6 py-6 md:py-12 w-full">
    <!-- Breadcrumb & Title -->
    <div class="mb-12">
      <div class="flex flex-wrap items-center gap-2 text-xs font-bold tracking-widest text-gray-500 dark:text-gray-400 mb-2 uppercase">
        <a class="hover:text-blue-600 dark:hover:text-blue-400 shrink-0" href="/">BERANDA</a>
        <span class="material-symbols-outlined text-xs shrink-0">chevron_right</span>
        <span class="text-blue-600 dark:text-blue-400 truncate">{category.name.toUpperCase()}</span>
      </div>
      <h1 class="text-2xl md:text-4xl lg:text-5xl font-extrabold tracking-tighter text-gray-900 dark:text-white">
        Katalog {category.name} & <span class="text-blue-600 dark:text-blue-400">Ulasan Eksklusif</span>
      </h1>
      <p class="mt-4 text-gray-600 dark:text-gray-400 max-w-2xl leading-relaxed">
        {category.description || `Menjelajahi dunia ${category.name} melalui sudut pandang editorial yang tajam.`}
      </p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12">
      <!-- Main Feed (8 cols) -->
      <div class="lg:col-span-8 space-y-12">
        <!-- Featured News (Asymmetric Layout) -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          {/* Card pertama: full width di mobile, col-span-1 di md+ */}
          {articles.slice(0, 1).map((article: any) => (
            <article class="bg-white dark:bg-gray-900 rounded-xl overflow-hidden group border border-gray-100 dark:border-gray-800">
              <div class="relative h-64 overflow-hidden">
                <img
                  alt={article.title}
                  class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
                  src={article.cover_image || 'https://via.placeholder.com/800x400'}
                />
                <div class="absolute top-4 left-4 bg-blue-600 text-white text-[10px] font-black px-3 py-1 rounded-full uppercase tracking-widest">
                  UTAMA
                </div>
              </div>
              <div class="p-4 md:p-8">
                <div class="flex items-center gap-3 mb-4 text-xs font-semibold text-gray-500 dark:text-gray-400">
                  <span>{article.published_at ? new Date(article.published_at).toLocaleDateString('id-ID', { day: 'numeric', month: 'short', year: 'numeric' }).toUpperCase() : ''}</span>
                  <span class="w-1 h-1 rounded-full bg-gray-300 dark:bg-gray-600"></span>
                  <span>ARTIKEL</span>
                </div>
                <h2 class="text-2xl font-bold leading-tight mb-4 text-gray-900 dark:text-white group-hover:text-blue-600 dark:group-hover:text-blue-400 transition-colors">
                  {article.title}
                </h2>
                <p class="text-gray-600 dark:text-gray-400 text-sm leading-relaxed mb-6">
                  {article.excerpt}
                </p>
                <a href={`/artikel/${article.slug}`} class="inline-flex items-center gap-2 text-blue-600 dark:text-blue-400 font-bold text-sm">
                  BACA SELENGKAPNYA <span class="material-symbols-outlined text-sm">arrow_forward</span>
                </a>
              </div>
            </article>
          ))}

          {/* 3 card berikutnya: list horizontal di mobile, flex-col di md+ */}
          <div class="flex flex-col gap-6">
            {articles.slice(1, 4).map((article: any) => (
              <article class="bg-white dark:bg-gray-900 rounded-xl p-4 flex gap-4 hover:bg-gray-50 dark:hover:bg-gray-800 transition-colors border border-gray-100 dark:border-gray-800">
                <div class="w-20 h-20 md:w-24 md:h-24 shrink-0 rounded-lg overflow-hidden">
                  <img alt={article.title} class="w-full h-full object-cover" src={article.cover_image || 'https://via.placeholder.com/200'} />
                </div>
                <div class="flex-1 min-w-0">
                  <a href={`/artikel/${article.slug}`}>
                    <h3 class="font-bold leading-snug mb-2 line-clamp-2 text-gray-900 dark:text-white hover:text-blue-600 dark:hover:text-blue-400 text-sm md:text-base">{article.title}</h3>
                  </a>
                  <div class="text-[10px] font-bold text-gray-500 dark:text-gray-400 uppercase tracking-wider">
                    {category.name.toUpperCase()}
                  </div>
                </div>
              </article>
            ))}
          </div>
        </div>

        <!-- Review Grid (Editorial Style) -->
        <div class="space-y-8">
          <div class="flex items-center justify-between">
            <h2 class="text-xl font-black tracking-tight flex items-center gap-2 text-gray-900 dark:text-white">
              <span class="w-2 h-8 bg-blue-600 dark:bg-blue-500"></span>
              ARTIKEL TERBARU
            </h2>
            <a class="text-xs font-bold text-blue-600 dark:text-blue-400 hover:underline" href="/artikel">LIHAT SEMUA</a>
          </div>

          <div class="space-y-6">
            {articles.map((article: any) => (
              <article class="flex gap-4 group cursor-pointer">
                <a href={`/artikel/${article.slug}`} class="flex gap-4 w-full">
                  <div class="w-32 md:w-56 h-32 md:h-40 flex-shrink-0 overflow-hidden rounded-xl bg-gray-100 dark:bg-gray-800 shadow-sm border border-gray-200 dark:border-gray-700">
                    <img
                      alt={article.title}
                      class="w-full h-full object-cover transition-transform group-hover:scale-105"
                      src={article.cover_image || 'https://via.placeholder.com/800x400'}
                    />
                  </div>
                  <div class="flex-grow">
                    <div class="flex items-center gap-2 mb-1 md:mb-2">
                      <span class="text-[10px] font-bold text-blue-600 dark:text-blue-400 uppercase tracking-wider">
                        {category.name}
                      </span>
                      <span class="text-[10px] text-gray-400 dark:text-gray-500 font-medium uppercase hidden md:inline">
                        {article.published_at ? new Date(article.published_at).toLocaleDateString('id-ID', { day: 'numeric', month: 'short', year: 'numeric' }) : ''}
                      </span>
                    </div>
                    <h4 class="text-base md:text-xl font-extrabold text-gray-900 dark:text-white group-hover:text-blue-600 dark:group-hover:text-blue-400 transition-colors leading-tight mb-1 md:mb-2 line-clamp-2">
                      {article.title}
                    </h4>
                    <p class="text-gray-600 dark:text-gray-400 text-xs md:text-sm leading-relaxed line-clamp-2 mb-2 md:mb-4 hidden md:block">
                      {article.excerpt}
                    </p>
                    <div class="flex items-center text-[10px] font-bold text-gray-500 dark:text-gray-400 uppercase tracking-wider">
                      <span class="material-symbols-outlined text-sm mr-1">person</span> Editor •
                      <span class="material-symbols-outlined text-sm mx-1">schedule</span> {article.read_time} Menit
                    </div>
                  </div>
                </a>
              </article>
            ))}
          </div>
        </div>

        <!-- Pagination -->
        {totalPages > 1 && (
          <div class="pt-8 border-t border-gray-200 dark:border-gray-800 flex justify-between items-center">
            <a
              href={page > 1 ? `/kategori/${slug}?page=${page - 1}` : '#'}
              class={`flex items-center gap-2 text-sm font-bold transition-colors ${page <= 1 ? 'text-gray-300 dark:text-gray-600 pointer-events-none' : 'text-gray-500 dark:text-gray-400 hover:text-blue-600 dark:hover:text-blue-400'}`}
            >
              <span class="material-symbols-outlined">west</span>
              <span class="hidden sm:inline">SEBELUMNYA</span>
            </a>
            <div class="flex items-center gap-2">
              {Array.from({ length: totalPages }, (_, i) => i + 1).map(p => (
                <a
                  href={`/kategori/${slug}?page=${p}`}
                  class={`w-9 h-9 flex items-center justify-center rounded-lg font-bold text-sm transition-all ${
                    p === page ? 'bg-blue-600 text-white shadow-md' : 'text-gray-700 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-gray-800'
                  }`}
                >{p}</a>
              ))}
            </div>
            <a
              href={page < totalPages ? `/kategori/${slug}?page=${page + 1}` : '#'}
              class={`flex items-center gap-2 text-sm font-bold transition-colors ${page >= totalPages ? 'text-gray-300 dark:text-gray-600 pointer-events-none' : 'text-gray-500 dark:text-gray-400 hover:text-blue-600 dark:hover:text-blue-400'}`}
            >
              <span class="hidden sm:inline">BERIKUTNYA</span>
              <span class="material-symbols-outlined">east</span>
            </a>
          </div>
        )}
      </div>

      <!-- Sidebar (4 cols) — hidden on mobile, shown on lg+ -->
      <aside class="hidden lg:block lg:col-span-4 space-y-10">
        <!-- Trending Topics -->
        <div class="bg-white dark:bg-gray-900 rounded-2xl p-8 border border-gray-100 dark:border-gray-800">
          <h3 class="text-sm font-black tracking-widest text-gray-900 dark:text-white uppercase mb-6">Trending Tags</h3>
          {allTags.length > 0 ? (
            <div class="flex flex-wrap gap-2">
              {allTags.slice(0, 8).map((tag: any) => (
                <a class="px-4 py-2 bg-gray-50 dark:bg-gray-800 text-gray-600 dark:text-gray-300 text-xs font-semibold rounded-full border border-gray-200 dark:border-gray-700 hover:border-blue-500 hover:text-blue-600 dark:hover:text-blue-400 transition-all" href={`/tag/${tag.slug}`}>#{tag.name}</a>
              ))}
            </div>
          ) : (
            <p class="text-xs text-gray-500 dark:text-gray-400">Belum ada tag tersedia.</p>
          )}
        </div>

        <!-- Newsletter -->
        <div class="bg-blue-600 dark:bg-blue-700 rounded-2xl p-8 text-white">
          <h3 class="text-xl font-black leading-tight mb-4">Dapatkan Update Mingguan</h3>
          <p class="text-sm opacity-80 mb-6">Kurasi artikel terbaik dan berita terbaru langsung ke inbox Anda.</p>
          <a href="/berlangganan" class="block w-full bg-white text-blue-600 font-bold py-3 rounded-xl shadow-lg hover:bg-gray-100 transition-all text-center text-sm">
            BERLANGGANAN
          </a>
        </div>

        <!-- All Categories -->
        <div class="bg-gray-50 dark:bg-gray-900 rounded-2xl p-6 border border-gray-200 dark:border-gray-800">
          <h3 class="text-[11px] font-black tracking-[0.2em] text-gray-500 dark:text-gray-400 uppercase mb-4 border-l-4 border-gray-400 dark:border-gray-600 pl-4">Indeks Kategori</h3>
          <div class="flex flex-col gap-1">
            {allCategories.map((cat: any) => (
              <a
                href={`/kategori/${cat.slug}`}
                class={`flex items-center justify-between py-2 px-3 rounded-lg transition-all group ${
                  cat.id === category.id
                    ? 'bg-blue-600 dark:bg-blue-700 text-white shadow-md'
                    : 'hover:bg-white dark:hover:bg-gray-800 hover:shadow-sm'
                }`}
              >
                <span class={`text-sm font-bold ${
                  cat.id === category.id ? 'text-white' : 'text-gray-800 dark:text-gray-200 group-hover:text-blue-600 dark:group-hover:text-blue-400'
                }`}>{cat.name}</span>
                <span class={`text-xs px-2 py-0.5 rounded-full font-bold ${
                  cat.id === category.id ? 'bg-white/20 text-white' : 'bg-blue-100 dark:bg-blue-900/30 text-blue-700 dark:text-blue-400'
                }`}>
                  {allArticlesAll.filter((a: any) => a.category_id === cat.id).length}
                </span>
              </a>
            ))}
          </div>
        </div>
      </aside>
    </div>
  </main>
</BaseLayout>
