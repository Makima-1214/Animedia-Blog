---
import { getAllCategories } from '../lib/turso-helpers.js';
const { pathname } = Astro.url;
const categories = await getAllCategories();
---

<header class="bg-white dark:bg-gray-900 border-b border-gray-200 dark:border-gray-800 sticky top-0 z-50 transition-colors">
  <div class="max-w-7xl mx-auto px-4 md:px-6">
    <!-- Top Row: Logo & Actions -->
    <div class="flex justify-between items-center py-4">
      <a href="/" class="text-2xl font-black tracking-tighter text-gray-900 dark:text-white flex items-center gap-2">
        <span class="material-symbols-outlined text-violet-600 dark:text-violet-400 text-3xl">architecture</span>
        Animedia
      </a>

      <div class="flex items-center gap-2">
        <!-- Search -->
        <div class="hidden sm:flex items-center bg-gray-100 dark:bg-gray-800 rounded-full px-4 py-2 border border-gray-200 dark:border-gray-700 relative">
          <input
            id="search-input"
            class="bg-transparent border-none focus:ring-0 text-sm w-48 text-gray-900 dark:text-white placeholder:text-gray-500 outline-none"
            placeholder="Cari artikel..."
            type="text"
            autocomplete="off"
          />
          <span class="material-symbols-outlined text-gray-500 dark:text-gray-400 text-lg cursor-pointer">search</span>
          <div id="search-results" class="absolute top-full left-0 right-0 mt-2 bg-white dark:bg-gray-800 rounded-xl shadow-lg border border-gray-200 dark:border-gray-700 z-50 hidden max-h-80 overflow-y-auto"></div>
        </div>
        
        <!-- Toko -->
        <a
          href="/toko"
          class={`p-2 rounded-full hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors flex items-center justify-center ${pathname === '/toko' ? 'text-violet-600 dark:text-violet-400' : 'text-gray-700 dark:text-gray-300'}`}
          aria-label="Toko Afiliasi"
          title="Toko"
        >
          <span class="material-symbols-outlined text-xl">shopping_bag</span>
        </a>

        <!-- Dark Mode Toggle -->
        <button
          id="theme-toggle"
          class="p-2 rounded-full hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors flex items-center justify-center"
          aria-label="Toggle dark mode"
        >
          <span id="theme-icon-light" class="material-symbols-outlined text-gray-700 dark:hidden text-xl">light_mode</span>
          <span id="theme-icon-dark" class="material-symbols-outlined text-gray-300 hidden dark:block text-xl">dark_mode</span>
        </button>

        <!-- User Menu -->
        <div class="relative flex items-center">
          <a
            id="login-btn"
            href="/login"
            class="flex items-center gap-2 px-3 py-2 rounded-full hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors"
          >
            <span class="material-symbols-outlined text-gray-700 dark:text-gray-300 text-xl">person</span>
            <span class="hidden md:inline text-sm font-semibold text-gray-700 dark:text-gray-300">Login</span>
          </a>
          <div id="user-menu" class="hidden relative">
            <button id="user-btn" class="flex items-center gap-2 px-3 py-2 rounded-full hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors">
              <span class="material-symbols-outlined text-violet-600 dark:text-violet-400 text-xl">person</span>
              <span id="user-name" class="hidden md:inline font-semibold text-sm text-gray-900 dark:text-white max-w-[120px] truncate"></span>
            </button>
            <div id="user-dropdown" class="hidden absolute right-0 mt-2 w-48 bg-white dark:bg-gray-800 rounded-lg shadow-lg border border-gray-200 dark:border-gray-700 py-2 z-50">
              <div class="px-4 py-2 border-b border-gray-200 dark:border-gray-700">
                <p id="dropdown-name" class="text-sm font-semibold text-gray-900 dark:text-white truncate"></p>
                <p id="dropdown-email" class="text-xs text-gray-500 dark:text-gray-400 truncate"></p>
              </div>
              <a href="/profil" class="block px-4 py-2 text-sm text-gray-700 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-gray-700 transition-colors">Profil</a>
              <button id="logout-btn" class="block w-full text-left px-4 py-2 text-sm text-red-600 dark:text-red-400 hover:bg-gray-100 dark:hover:bg-gray-700 transition-colors">Logout</button>
            </div>
          </div>
        </div>

        <!-- Hamburger Menu -->
        <button
          id="mobile-menu-toggle"
          class="lg:hidden p-2 rounded-full hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors flex items-center justify-center"
          aria-label="Toggle menu"
        >
          <span class="material-symbols-outlined text-gray-700 dark:text-gray-300 text-xl" style="font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;">menu</span>
        </button>
      </div>
    </div>
    
    <!-- Bottom Row: Categories -->
    <nav class="flex items-center space-x-6 py-2 overflow-x-auto no-scrollbar border-t border-gray-100 dark:border-gray-800">
      <a
        class={`font-bold text-xs uppercase tracking-widest whitespace-nowrap transition-colors ${pathname === '/' ? 'text-violet-600 dark:text-violet-400' : 'text-gray-600 dark:text-gray-400 hover:text-violet-600 dark:hover:text-violet-400'}`}
        href="/"
      >
        Home
      </a>
      <a
        class={`font-bold text-xs uppercase tracking-widest whitespace-nowrap transition-colors ${pathname === '/artikel' ? 'text-violet-600 dark:text-violet-400' : 'text-gray-600 dark:text-gray-400 hover:text-violet-600 dark:hover:text-violet-400'}`}
        href="/artikel"
      >
        Semua Artikel
      </a>
      {categories.map((cat: any) => (
        <a
          class={`font-bold text-xs uppercase tracking-widest whitespace-nowrap transition-colors ${pathname.includes(`/kategori/${cat.slug}`) ? 'text-violet-600 dark:text-violet-400' : 'text-gray-600 dark:text-gray-400 hover:text-violet-600 dark:hover:text-violet-400'}`}
          href={`/kategori/${cat.slug}`}
        >
          {cat.name}
        </a>
      ))}
    </nav>
    
    <!-- Mobile Menu (Extra Features) -->
    <div id="mobile-menu" class="overflow-hidden transition-all duration-300 ease-in-out max-h-0 border-t border-gray-100 dark:border-gray-800 bg-gray-50 dark:bg-gray-900">
      <div class="flex flex-col space-y-1 py-3 opacity-0 transition-opacity duration-300">
        <a href="/profil" class="flex items-center gap-3 px-4 py-2.5 text-sm font-medium text-gray-700 dark:text-gray-300 hover:bg-white dark:hover:bg-gray-800 rounded-lg transition-colors">
          <span class="material-symbols-outlined text-lg">person</span>
          Profil
        </a>
        <a href="/berlangganan" class="flex items-center gap-3 px-4 py-2.5 text-sm font-medium text-gray-700 dark:text-gray-300 hover:bg-white dark:hover:bg-gray-800 rounded-lg transition-colors">
          <span class="material-symbols-outlined text-lg">mail</span>
          Newsletter
        </a>
        <a href="/toko" class="flex items-center gap-3 px-4 py-2.5 text-sm font-medium text-gray-700 dark:text-gray-300 hover:bg-white dark:hover:bg-gray-800 rounded-lg transition-colors">
          <span class="material-symbols-outlined text-lg">shopping_bag</span>
          Toko
        </a>
      </div>
    </div>
  </div>
</header>

<script>
  import Fuse from 'fuse.js';

  // Dark Mode Toggle
  const themeToggle = document.getElementById('theme-toggle');
  const html = document.documentElement;
  
  // Check for saved theme preference or default to light mode
  const currentTheme = localStorage.getItem('theme') || 'light';
  if (currentTheme === 'dark') {
    html.classList.add('dark');
  }

  themeToggle?.addEventListener('click', () => {
    html.classList.toggle('dark');
    const theme = html.classList.contains('dark') ? 'dark' : 'light';
    localStorage.setItem('theme', theme);
  });

  // Mobile Menu Toggle
  const mobileMenuToggle = document.getElementById('mobile-menu-toggle');
  const mobileMenu = document.getElementById('mobile-menu');
  const mobileMenuContent = mobileMenu?.querySelector('div');
  
  mobileMenuToggle?.addEventListener('click', () => {
    const isOpen = mobileMenu?.style.maxHeight && mobileMenu.style.maxHeight !== '0px';
    
    if (isOpen) {
      // Close
      mobileMenuContent?.classList.remove('opacity-100');
      mobileMenuContent?.classList.add('opacity-0');
      setTimeout(() => {
        if (mobileMenu) mobileMenu.style.maxHeight = '0px';
      }, 150);
    } else {
      // Open
      if (mobileMenu) mobileMenu.style.maxHeight = '400px';
      setTimeout(() => {
        mobileMenuContent?.classList.remove('opacity-0');
        mobileMenuContent?.classList.add('opacity-100');
      }, 50);
    }
  });

  // Auth - Check if user is logged in
  const loginBtn = document.getElementById('login-btn') as HTMLElement;
  const userMenu = document.getElementById('user-menu') as HTMLElement;
  const userName = document.getElementById('user-name') as HTMLElement;
  const dropdownName = document.getElementById('dropdown-name') as HTMLElement;
  const dropdownEmail = document.getElementById('dropdown-email') as HTMLElement;
  const userBtn = document.getElementById('user-btn') as HTMLElement;
  const userDropdown = document.getElementById('user-dropdown') as HTMLElement;
  const logoutBtn = document.getElementById('logout-btn') as HTMLElement;

  async function checkAuth() {
    try {
      const response = await fetch('/api/auth/me');
      const result = await response.json();
      
      if (result.success && result.user) {
        loginBtn.style.display = 'none';
        userMenu.classList.remove('hidden');
        userName.textContent = result.user.name;
        dropdownName.textContent = result.user.name;
        dropdownEmail.textContent = result.user.email;
      } else {
        loginBtn.style.display = 'flex';
        userMenu.classList.add('hidden');
      }
    } catch (error) {
      console.error('Auth check error:', error);
    }
  }

  checkAuth();

  // Toggle user dropdown
  userBtn?.addEventListener('click', () => {
    userDropdown.classList.toggle('hidden');
  });

  // Close dropdown when clicking outside
  document.addEventListener('click', (e) => {
    if (!userBtn?.contains(e.target as Node) && !userDropdown?.contains(e.target as Node)) {
      userDropdown?.classList.add('hidden');
    }
  });

  // Logout
  logoutBtn?.addEventListener('click', async () => {
    try {
      const response = await fetch('/api/auth/logout', { method: 'POST' });
      const result = await response.json();
      
      if (result.success) {
        window.location.reload();
      }
    } catch (error) {
      console.error('Logout error:', error);
    }
  });

  // Search
  const searchInput = document.getElementById('search-input') as HTMLInputElement;
  const searchResults = document.getElementById('search-results') as HTMLElement;
  let fuse: any = null;

  async function initSearch() {
    const res = await fetch('/api/articles/search');
    const articles = await res.json();
    fuse = new Fuse(articles, {
      keys: ['title', 'excerpt', 'category'],
      threshold: 0.4
    });
  }

  initSearch();

  searchInput?.addEventListener('input', () => {
    const query = searchInput.value.trim();
    if (!query || !fuse) {
      searchResults.classList.add('hidden');
      return;
    }
    const results = fuse.search(query).slice(0, 5);
    if (results.length === 0) {
      searchResults.innerHTML = '<p class="p-4 text-sm text-gray-500 dark:text-gray-400">Tidak ada hasil</p>';
    } else {
      searchResults.innerHTML = results.map(({ item }: any) => `
        <a href="/artikel/${item.slug}" class="flex items-center gap-3 p-3 hover:bg-gray-100 dark:hover:bg-gray-700 transition-colors">
          <img src="${item.cover_image || 'https://via.placeholder.com/60'}" class="w-10 h-10 rounded-lg object-cover flex-shrink-0" />
          <div>
            <p class="text-sm font-bold text-gray-900 dark:text-white line-clamp-1">${item.title}</p>
            <p class="text-[10px] text-violet-600 dark:text-violet-400 font-bold uppercase">${item.category}</p>
          </div>
        </a>
      `).join('');
    }
    searchResults.classList.remove('hidden');
  });

  document.addEventListener('click', (e) => {
    if (!searchInput?.contains(e.target as Node) && !searchResults?.contains(e.target as Node)) {
      searchResults?.classList.add('hidden');
    }
  });
</script>
