# Turso Database
TURSO_DATABASE_URL=your-turso-database-url
TURSO_AUTH_TOKEN=your-turso-auth-token

# ========================================
# CLOUDINARY (Upload Gambar Artikel)
# ========================================
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ========================================
# EMAIL CONFIGURATION (WAJIB UNTUK REGISTRASI)
# ========================================
# CARA SETUP (5 MENIT):
# 1. Aktifkan 2FA Gmail: https://myaccount.google.com/security
# 2. Buat App Password: https://myaccount.google.com/apppasswords
# 3. Copy App Password (16 karakter, contoh: abcd efgh ijkl mnop)
# 4. Paste di bawah (ganti your-email@gmail.com dan your-app-password)
# 5. Restart server: npm run dev
#
# PANDUAN LENGKAP: Baca file EMAIL_SETUP.md
# ========================================

EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-password

# ========================================
# TINYMCE (Rich Text Editor)
# ========================================
# Daftar gratis di: https://www.tiny.cloud/
# Ambil API key dari dashboard TinyMCE
TINYMCE_API_KEY=your-tinymce-api-key

# ========================================
# SEO
# ========================================
# Google Search Console verification code
# Dapatkan dari: https://search.google.com/search-console
# Pilih "HTML tag" method, copy value dari content="..."
GOOGLE_SITE_VERIFICATION=your-verification-code

# ========================================
# GOOGLE ANALYTICS
# ========================================
# Dapatkan dari: https://analytics.google.com/
# Buat property baru → Data Streams → Web → copy Measurement ID
# Format: G-XXXXXXXXXX
GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX

# ========================================
# INDEXNOW (Auto-Submit ke Search Engines)
# ========================================
# IndexNow key untuk submit URL ke Bing, Yandex, dll
# Key sudah di-generate otomatis, tinggal tambahkan ke Vercel
# Cara tambah di Vercel:
# 1. Buka Vercel Dashboard → Project Settings → Environment Variables
# 2. Tambahkan: INDEXNOW_KEY = b63c32a5ec6be18ba71cc1d0c8aefb0ed2719087d42418206828e63b2398dd17
# 3. Redeploy project
INDEXNOW_KEY=b63c32a5ec6be18ba71cc1d0c8aefb0ed2719087d42418206828e63b2398dd17
