---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import { getActiveAffiliates } from '../../lib/turso-helpers.js';

const products = await getActiveAffiliates();
const platforms = [...new Set(products.map((p: any) => p.platform).filter(Boolean))] as string[];
---

<BaseLayout
  title="Toko — Animedia"
  description="Produk pilihan editor Animedia. Temukan rekomendasi terbaik dari kami."
>
  <Header />

  <main class="bg-gray-50 dark:bg-gray-950 min-h-screen">

    <!-- Hero Header -->
    <div class="bg-white dark:bg-gray-900 border-b border-gray-100 dark:border-gray-800">
      <div class="max-w-6xl mx-auto px-4 md:px-6 pt-10 pb-8">
        <div class="flex items-center gap-3 mb-3">
          <span class="material-symbols-outlined text-violet-600 dark:text-violet-400 text-3xl">storefront</span>
          <h1 class="text-2xl md:text-3xl font-extrabold text-gray-900 dark:text-white tracking-tight">Toko Rekomendasi</h1>
        </div>
        <p class="text-gray-500 dark:text-gray-400 text-sm max-w-md">
          Produk pilihan editor — dikurasi langsung dari artikel kami.
        </p>

        <!-- Filter Pills -->
        {platforms.length > 0 && (
          <div class="flex flex-wrap gap-2 mt-5" id="platformFilters">
            <button
              class="platform-btn text-xs font-bold px-4 py-2 rounded-full transition-all bg-violet-600 text-white border border-violet-600"
              data-platform=""
            >
              Semua
              <span class="ml-1 opacity-70">({products.length})</span>
            </button>
            {platforms.map((p: any) => {
              const count = products.filter((pr: any) => pr.platform === p).length;
              return (
                <button
                  class="platform-btn text-xs font-bold px-4 py-2 rounded-full transition-all bg-white dark:bg-gray-800 text-gray-600 dark:text-gray-300 border border-gray-200 dark:border-gray-700 hover:border-violet-400 hover:text-violet-600 dark:hover:text-violet-400"
                  data-platform={p}
                >
                  {p}
                  <span class="ml-1 opacity-60">({count})</span>
                </button>
              );
            })}
          </div>
        )}
      </div>
    </div>

    <div class="max-w-6xl mx-auto px-4 md:px-6 py-8">
      {products.length === 0 ? (
        <div class="flex flex-col items-center justify-center py-32 text-center">
          <span class="material-symbols-outlined text-7xl text-gray-200 dark:text-gray-800 mb-4">shopping_bag</span>
          <p class="text-lg font-bold text-gray-400 dark:text-gray-600">Belum ada produk</p>
          <p class="text-sm text-gray-300 dark:text-gray-700 mt-1">Tambahkan produk afiliasi di halaman edit artikel</p>
        </div>
      ) : (
        <>
          <!-- Count info -->
          <p id="countInfo" class="text-xs text-gray-400 dark:text-gray-500 mb-5 font-medium">
            Menampilkan <span id="countNum">{products.length}</span> produk
          </p>

          <!-- Product Grid -->
          <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-3 md:gap-5" id="productsGrid">
            {products.map((product: any) => (
              <div class="product-card group bg-white dark:bg-gray-900 rounded-2xl overflow-hidden border border-gray-100 dark:border-gray-800 hover:shadow-lg hover:-translate-y-0.5 transition-all duration-200 flex flex-col" data-platform={product.platform || ''}>

                <!-- Image -->
                <a
                  href={`/toko/${product.id}`}
                  class="block relative overflow-hidden bg-gray-50 dark:bg-gray-800 aspect-square"
                >
                  {product.image ? (
                    <img
                      src={product.image}
                      alt={product.name}
                      class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                      loading="lazy"
                    />
                  ) : (
                    <div class="w-full h-full flex items-center justify-center">
                      <span class="material-symbols-outlined text-5xl text-gray-200 dark:text-gray-700">inventory_2</span>
                    </div>
                  )}
                  {product.platform && (
                    <span class="absolute top-2 left-2 text-[9px] font-black uppercase tracking-wider bg-white/90 dark:bg-gray-900/90 backdrop-blur-sm text-gray-600 dark:text-gray-300 px-2 py-0.5 rounded-full border border-gray-100 dark:border-gray-700">
                      {product.platform}
                    </span>
                  )}
                </a>

                <!-- Info -->
                <div class="p-3 md:p-4 flex flex-col flex-1 gap-2">
                  <!-- Nama produk -->
                  <a href={`/toko/${product.id}`}>
                    <h2 class="font-bold text-sm text-gray-900 dark:text-white leading-snug line-clamp-2 hover:text-violet-600 dark:hover:text-violet-400 transition-colors">
                      {product.name}
                    </h2>
                  </a>

                  <!-- Harga + Tombol beli -->
                  <div class="mt-auto flex items-center justify-between gap-2 pt-1">
                    {product.price ? (
                      <p class="font-black text-sm text-violet-600 dark:text-violet-400 truncate">
                        Rp {product.price}
                      </p>
                    ) : (
                      <span class="text-xs text-gray-400 dark:text-gray-500">Cek harga</span>
                    )}
                    <a
                      href={product.affiliate_url}
                      target="_blank"
                      rel="noopener noreferrer sponsored"
                      class="flex-shrink-0 flex items-center gap-1 bg-violet-600 hover:bg-violet-700 text-white text-[10px] font-bold px-2.5 py-1.5 rounded-lg transition-colors"
                    >
                      Beli
                      <span class="material-symbols-outlined text-[12px]">arrow_forward</span>
                    </a>
                  </div>

                  <!-- Artikel sumber — subtle, di bawah -->
                  {product.article_title && (
                    <a
                      href={`/artikel/${product.article_slug}`}
                      class="text-[10px] text-gray-400 dark:text-gray-600 hover:text-violet-500 dark:hover:text-violet-400 transition-colors truncate flex items-center gap-1 border-t border-gray-50 dark:border-gray-800 pt-2 mt-1"
                    >
                      <span class="material-symbols-outlined text-[11px]">article</span>
                      <span class="truncate">{product.article_title}</span>
                    </a>
                  )}
                </div>
              </div>
            ))}
          </div>

          <!-- Empty state saat filter aktif -->
          <div id="emptyFilter" class="hidden flex-col items-center justify-center py-20 text-center">
            <span class="material-symbols-outlined text-5xl text-gray-200 dark:text-gray-800 mb-3">filter_list_off</span>
            <p class="font-bold text-gray-400 dark:text-gray-600">Tidak ada produk di platform ini</p>
          </div>

          <!-- Disclosure -->
          <p class="text-[11px] text-gray-300 dark:text-gray-700 mt-14 text-center max-w-md mx-auto leading-relaxed">
            Link di halaman ini adalah link afiliasi. Kami mendapat komisi kecil dari setiap pembelian — tanpa biaya tambahan buat kamu. ❤️
          </p>
        </>
      )}
    </div>
  </main>
</BaseLayout>

<script is:inline>
  const btns = document.querySelectorAll('.platform-btn');
  const cards = document.querySelectorAll('.product-card');
  const countNum = document.getElementById('countNum');
  const emptyFilter = document.getElementById('emptyFilter');
  const grid = document.getElementById('productsGrid');

  btns.forEach(btn => {
    btn.addEventListener('click', () => {
      // Reset semua tombol
      btns.forEach(b => {
        b.classList.remove('bg-violet-600', 'text-white', 'border-violet-600');
        b.classList.add('bg-white', 'dark:bg-gray-800', 'text-gray-600', 'dark:text-gray-300', 'border-gray-200', 'dark:border-gray-700');
      });

      // Aktifkan tombol yang diklik
      btn.classList.add('bg-violet-600', 'text-white', 'border-violet-600');
      btn.classList.remove('bg-white', 'dark:bg-gray-800', 'text-gray-600', 'dark:text-gray-300', 'border-gray-200', 'dark:border-gray-700');

      const platform = btn.getAttribute('data-platform');
      let visible = 0;

      cards.forEach(card => {
        const match = !platform || card.getAttribute('data-platform') === platform;
        card.style.display = match ? '' : 'none';
        if (match) visible++;
      });

      if (countNum) countNum.textContent = visible;

      if (emptyFilter && grid) {
        if (visible === 0) {
          grid.classList.add('hidden');
          emptyFilter.classList.remove('hidden');
          emptyFilter.classList.add('flex');
        } else {
          grid.classList.remove('hidden');
          emptyFilter.classList.add('hidden');
          emptyFilter.classList.remove('flex');
        }
      }
    });
  });
</script>
