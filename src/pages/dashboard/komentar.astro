---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
import { getAllComments, getCommentStats, getArticleById } from '../../lib/turso-helpers.js';

const comments = await getAllComments();
const commentStats = await getCommentStats();

const enrichedComments = await Promise.all(comments.map(async (c: any) => {
  const article = await getArticleById(c.article_id);
  return { ...c, articleSlug: article?.slug || null, articleTitle: article?.title || `Artikel #${c.article_id}` };
}));
---

<DashboardLayout title="Kelola Komentar - Admin Panel" activePage="komentar">
  <div class="p-4 md:p-8 lg:p-12">
      <!-- Page Header -->
      <div class="mb-8 md:mb-12">
        <h2 class="text-2xl md:text-4xl font-extrabold tracking-tight text-on-background mb-2 md:mb-4">Moderasi Komentar</h2>
        <p class="text-sm text-on-surface-variant max-w-xl leading-relaxed">
          Tinjau keterlibatan pembaca terbaru. Jaga kualitas diskusi dengan memoderasi komentar yang sesuai standar editorial.
        </p>
      </div>

      <!-- Stats Bar -->
      <div class="grid grid-cols-2 sm:grid-cols-3 gap-3 mb-8 md:mb-12 max-w-xs">
        <div class="bg-surface-container-low p-4 md:p-6 rounded-lg">
          <p class="text-xs font-bold text-on-surface-variant tracking-widest uppercase mb-1 md:mb-2">Total Komentar</p>
          <p class="text-2xl md:text-3xl font-headline font-extrabold">{commentStats.total}</p>
        </div>
      </div>

      <!-- Moderation List -->
      <div class="space-y-0 divide-y divide-outline-variant/10">
        {enrichedComments.map((comment: any) => (
          <div class="group py-5 md:py-10 flex flex-col md:flex-row gap-4 md:gap-10 hover:bg-surface-container-low transition-all duration-300 px-3 md:px-6 -mx-3 md:-mx-6">
            <!-- Author info -->
            <div class="flex items-start gap-3 md:w-1/4">
              <div class="w-10 h-10 rounded-full overflow-hidden bg-stone-200 flex items-center justify-center flex-shrink-0">
                <span class="material-symbols-outlined text-outline-variant">person</span>
              </div>
              <div class="min-w-0">
                <h4 class="font-bold text-on-background text-sm truncate">{comment.author_name}</h4>
                <p class="text-xs text-on-surface-variant truncate">{comment.author_email}</p>
                <p class="text-xs font-medium text-outline mt-1">
                  {new Date(comment.created_at).toLocaleDateString('id-ID', { day: 'numeric', month: 'short', year: 'numeric' })}
                </p>
              </div>
            </div>
            <!-- Comment content -->
            <div class="flex-1 min-w-0">
              <div class="mb-2">
                <p class="text-xs font-bold text-tertiary mb-0.5">RE: Artikel</p>
                {comment.articleSlug 
                  ? <a class="text-sm font-semibold hover:underline underline-offset-4 decoration-outline-variant line-clamp-1" href={`/artikel/${comment.articleSlug}`}>{comment.articleTitle}</a>
                  : <span class="text-sm font-semibold text-on-surface-variant line-clamp-1">{comment.articleTitle}</span>
                }
              </div>
              <p class="text-sm md:text-base text-on-surface leading-relaxed font-body italic line-clamp-3 md:line-clamp-none">
                "{comment.content}"
              </p>
            </div>
            <!-- Actions -->
            <div class="flex md:flex-col justify-end items-end gap-2 md:w-auto">
              <button onclick={`deleteComment('${comment.id}')`} class="flex items-center gap-1.5 py-2 px-3 text-error font-medium text-xs rounded hover:bg-error/5 transition-all border border-error/20">
                <span class="material-symbols-outlined text-sm">delete</span>
                <span>Hapus</span>
              </button>
            </div>
          </div>
        ))}
      </div>
    </div>
</DashboardLayout>


  <script>
    async function deleteComment(id: string) {
      (window as any).showConfirm({
        title: 'Hapus Komentar?',
        message: 'Komentar ini akan dihapus permanen.',
        okText: 'Hapus',
        okIcon: 'delete',
        okClass: 'bg-red-500 hover:bg-red-600',
        iconBg: 'bg-red-100',
        iconColor: 'text-red-500',
        icon: 'delete'
      }, async (confirmed) => {
        if (!confirmed) return;
        try {
          const formData = new FormData();
          formData.append('id', id);
          const response = await fetch('/api/comments/delete', { method: 'POST', body: formData });
          const result = await response.json();
          if (result.success) {
            alert('✅ Komentar berhasil dihapus!');
            window.location.reload();
          } else {
            alert('❌ Error: ' + result.message);
          }
        } catch (error) {
          alert('❌ Terjadi kesalahan: ' + error);
        }
      });
    }

    // Make functions available globally
    (window as any).deleteComment = deleteComment;
  </script>
